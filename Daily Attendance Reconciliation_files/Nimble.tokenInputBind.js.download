//multiple AutoComplete for Working Employees or All based on Checked on Resigned check box with permission
var bindAutoCompleteWithCheckboxEmployeeMultiplePermission = function () {
    var url = "";
    function getUrl() {
        var isResigned = $(".resign-chk").is(':checked');
        if (isResigned == null || !isResigned || isResigned == false) {
            url = EmployeeServices + 'EmpAutoComplete?w=1';
            $(".ischeckResigned").attr('value', false);
        }
        else {
            url = EmployeeServices + 'EmpAutoComplete';
            $(".ischeckResigned").attr('value', true);
        }
        return url;
    }

    $(".tokeninput-searchEmp-working").tokenInput(getUrl, {
        theme: "facebook",
        preventDuplicates: true,
        method: "POST",
        minChars:3,
        onAdd: function (item) {
            return false;
        }
    });
}

