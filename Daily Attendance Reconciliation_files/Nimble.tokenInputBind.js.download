var CommonUrlService = '/Common/WebServices/';
var EmployeeServices = '/Hrm/Employee/';
var AttendanceServices = '/Attendance/Attendance/';

//Multiple AutoComplete for Country
var bindAutoCompleteCountryMultiple = function () {
    var url = CommonUrlService + 'CountryAutoComplete';
    $("#tokeninput-searchCountry").tokenInput(url, {
        theme: "facebook",
        preventDuplicates: true,
        method: "POST",
        onAdd: function (item) {
            return false;
        }
    });
}

//Multiple AutoComplete for Employees
var bindAutoCompleteEmployeeMultiple = function () {
    var url = EmployeeServices + 'EmpAutoComplete';
    $("#tokeninput-searchEmp").tokenInput(url, {
        theme: "facebook",
        preventDuplicates: true,
        method: "POST",
        minChars: 3,
        onAdd: function (item) {
            $('#ProjectID').val(item.ProjectID);
            return false;
        }
    });
}

