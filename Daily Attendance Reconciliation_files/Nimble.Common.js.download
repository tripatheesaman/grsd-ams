var CommonUrl = '/Common/WebServices/';
var EmployeeServices = '/Hrm/Employee/';

// Ledger Auto Complete
var bindAutoCompleteLedger = function () {
    var url = CommonUrl + 'LedgerAutoComplete';

    $('#searchLedger').autocomplete({
        source: function (request, response) {
            $.ajax({
                url: url,
                dataType: 'json',
                type: 'POST',
                data: { term: request.term },
                success: function (data) {
                    response($.map(data,
                        function (item) {
                            return {
                                label: item.LedgerName,
                                value: item.LedgerName,
                                selectedValue: item.LedgerID
                            }
                        }));
                }
            })
        },
        select:
            function (event, ui) {
                $('#searchLedger').val(ui.item.label);
                $('#LedgerID').val(ui.item.selectedValue);

                return false;
            },
        change: function (event, ui) {
            $("#LedgerID").val(ui.item ? ui.item.selectedValue : 0);
        },
        minLength: 1
    });
}

