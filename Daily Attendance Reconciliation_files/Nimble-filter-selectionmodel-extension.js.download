    var handleUnbindAndBindPagingButton = function (element) {
        var $pageWrap = $(element).data("options").pageWraper;
        const $btnNextPage = $(".btn-next-page", $pageWrap);
        const $btnGo = $(".btn-page-to-go", $pageWrap);
        const $btnPreviour = $(".btn-prev-page", $pageWrap);

        $btnPreviour.unbind().bind("click", handleBtnPrevPageClick($($btnPreviour), element));
        $btnNextPage.unbind().bind("click", handleBtnNextPageClick($($btnNextPage), element));
        $btnGo.unbind().bind("click", handleBtnPageToGoClick($($btnGo), element));
    };

    var setMaximizeGridHeight = function () {

        var divPrint = $("#reload-alls").length;
        if (divPrint >= 1) {
            var profile = 0;

            var nav = $(".navbar-default").length;
            if (nav >= 1) {
                profile = profile + 52;
            } else {
                profile = profile - 0;
            }
            var page = $(".box-footer", $("#reload-alls")).length;
            if (page >= 1) {
                profile = profile + 50;
            } else {
                profile = profile - 10;
            }
            //profile = profile + 166 + 24;
            var heightOfGrid = $(window).height() - profile;
            if (heightOfGrid <= 100) {
                heightOfGrid = 150;
            }
            $('.hands-on-table').height(heightOfGrid);
        }
    }

    var handleWindowPageSizeControl = function (element) {
        if (hsGridGlobal.hsGridMode && hsGridGlobal.hsGridMode === 1) {
            setMaximizeGridHeight();
        }
        else {

            var options = $(element).data("options");
            if (typeof options !== "undefined")
                if (options !== null) {
                    if (typeof (options.setGridHeight) !== "undefined") {
                        $('.hands-on-table').height(options.setGridHeight);
                    } else {
                        var divPrint = $("#reload-alls, .reload-alls").length;
                        if (divPrint >= 1) {
                            var pageHeaderHeight = $(".main-header").outerHeight() || 0;
                            var profileHeight = $(".profileheader").outerHeight() || 0;
                            var profileLeftMenuHeight = 0;
                            if (profileHeight > 0) {
                                profileHeight += 25;
                            }
                            var headerContHeight = $('.content-header').outerHeight() || 0;
                            var tabHeight = $(".nav-tabs-custom>.nav.nav-tabs").outerHeight() || 0;
                            var navHeight = $(".navbar-default:visible").outerHeight() || 0;
                            var gridPagerHeight = $(".grid-pager").outerHeight() || 0;
                            var gridFooterHeight = $(".grid-footer").outerHeight() || 0;
                            var pageFooterHeight = $(".main-footer").outerHeight() || 0;
                            var gridPageTitleHeight = $(".grid-page-title").outerHeight() || 0;

                            var isPopup = IsWindowPopup();

                            var profile = profileHeight + headerContHeight + tabHeight + navHeight + gridPagerHeight + gridFooterHeight + gridPageTitleHeight;
                            if (!isPopup)
                                profile += pageHeaderHeight + pageFooterHeight;
                            var windowHeight = $(window).height();
                            var gridHeight = windowHeight - profile - 3;

                            if (gridHeight < profileLeftMenuHeight && profileHeight > 0)
                                gridHeight = profileLeftMenuHeight - navHeight - tabHeight - gridFooterHeight;

                            if (gridHeight > (windowHeight - pageHeaderHeight - pageFooterHeight))
                                gridHeight = (windowHeight - pageHeaderHeight - pageFooterHeight);

                            if (gridHeight < 250) {
                                gridHeight = 250;
                            }

                            $('.hands-on-table').height(gridHeight);
                        }
                    }
                }
        }
    };

    var inithandleWindowPageSizeControl = function (element) {
        handleWindowPageSizeControl(element);
    };

    var getInstance = function (element) {
        return $(element).handsontable("getInstance");
    };
    var handlefirstColumnSize = function (element) {
        var instance = getInstance(element);
        var settings = $(element).data("options");
        var colgroup = instance.rootElement.querySelectorAll("colgroup col:nth-child(2)");
        if (settings.useCheckBox)
            $(colgroup).css({ width: '50px' });
    };
    var getSelectedRow = function (instance) {
        var $this = instance.element;
        var settings = $($this).data("options");
        if (settings.onRowClick === null && settings.onRowClick === undefined) {
            return "";
        }
        var index = $.data($this, "header").indexOf(settings.onRowClick);
        var handInstance = getInstance($this);
        var selectedCell = handInstance.getSelected();
        if (typeof selectedCell === "undefined") {
            return "";
        }

        var selection = handInstance.getSelected()[0];
        var data = handInstance.getDataAtRow(selection)[index];
        return data;
    };
    var getSelectedRowWithCol = function (instance, columnName) {
        var $this = instance.element;
        var index = $.data($this, "header").indexOf(columnName);
        var handInstance = getInstance($this);
        var selection = handInstance.getSelected()[0];
        var data = handInstance.getDataAtRow(selection)[index];
        return data;
    };

    var getCheckDataInArray = function (element) {
        var data = [];
        var instance = getInstance(element);
        $("input.htCheckboxRendererInput", $(element)).each(function (index, value) {
            var checkStatus = $(value).get(0).checked;
            var row = $(this).attr("data-row"), col = $(this).attr("data-col");
            if (checkStatus) {
                const checkedData = instance.getData(index, col, index, instance.countCols() - 1);
                const getData = checkedData[0];
                if (getData[0] !== null)
                    data.push(getData);
            }
        });
        return data;
    };
    var checkedData = function (element) {
        var $context = $(element).closest("div").find(".ht_master");
        var data = [];
        data = $(element).data("selectedValue");
        return data;
    }
    var mappedData = function (element) {
        var data1 = [];
        data1 = $(element).data("mappedValue");
        return data1;
    }

    var init = function (setting, element) {
        $rootUrl = setting.url !== null || setting.url !== undefined || setting.url !== "" ? setting.url : "";
        useCheckBoxs = setting.useCheckBox !== null || setting.useCheckBox !== undefined ? setting.useCheckBox : true;
        $mainContainer = setting.mainContainer;
        $pageWraper = setting.pageWraper;
        var enableSortingAndFiltering = true
        if (setting.enableSortingAndFiltering === "undefined")
            if (setting.enableSortingAndFiltering === null)
                enableSortingAndFiltering = true;
        setting.enableSortingAndFiltering = true;

        if (setting.formType === "Index" || setting.formType === undefined) {
            pagingTemplate.initTemplate($pageWraper);
            handleSubAjaxRequestFormMethod(element);
        } else if (setting.formType === "Child") {
            pagingTemplate.initTemplate($pageWraper);
            handleSubAjaxRequestFormMethod(element);
        } else if (setting.formType === "Selection") {
            handleSearchButtonClick($("#btnSearch"), element);
            pagingTemplate.initTemplate($pageWraper);
            $("#btnSearch").trigger("click");
        } else {
            return;
        }
    };

    var handleReInitHotInstances = function ($element) {
        var elem = document.getElementById($element.id);
        var $containers = $(elem);
        var options = $containers.data("options");
        var filter = $containers.data("filterArray");
        var nimble = $containers.data("nimble");
        var checkedValue = $containers.data("selectedValue");
        var mappedValue = $containers.data("mappedValue");
        var nimbleConfig = $containers.data("nimbleConfig");
        $.data(elem, "options", options);
        $.data(elem, "filterArray", filter);
        $.data(elem, "nimble", nimble);
        $.data(elem, "nimbleConfig", nimbleConfig);
        $.data(elem, "selectedValue", checkedValue);
        $.data(elem, "mappedValue", mappedValue);
        const hotInstance = $containers.handsontable("getInstance");
        if (hotInstance !== undefined && hotInstance !== null) {
            hotInstance.destroy(true);
        }

        $.data($element, "options", options);
        $.data($element, "filterArray", filter);
        $.data($element, "nimble", nimble);
        $.data($element, "nimbleConfig", nimbleConfig);
        $.data($element, "selectedValue", checkedValue);
        $.data($element, "mappedValue", mappedValue);
        return $element;
    };

    var handleGetColumnAccordingToName = function (array, columnNames, header) {

        var cols;
        var arr = [];
        if (typeof columnNames === "string") {
            if (columnNames.indexOf(",") > -1) {
                columnNames = columnNames.split(",");
            }
        }

        if (Array.isArray(columnNames)) {
            for (let l = 0; l < columnNames.length; l++) {
                cols = header.indexOf(columnNames[l]);
                var jLen = 0;
                for (let i = 0; i < array.length; i++) {
                    for (let j = 0; j < array[i].length; j++) {
                        if (j === jLen) {
                            arr.push([]);
                            jLen++;
                        }
                        if (j === cols)
                            arr[i].push(array[i][j]);
                    }
                }
            }
        } else {

        }
        const finalDataArray = [];
        for (let k = 0; k < arr.length; k++) {
            if ($.isEmptyObject(arr[k]) === false) {
                finalDataArray.push(arr[k]);
            }
        }
        return finalDataArray;
    };

