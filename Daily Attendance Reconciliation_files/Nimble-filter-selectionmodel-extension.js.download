            colWidths: void 0,
            rowHeaders: void 0,
            manualRowResize: false,
            renderAllRows: true,
            colHeaders: void 0,
            fixedColumnsLeft: 0,
            afterRenderAll: void 0,
            outsideClickDeselects: false,
            afterSelectionEnd: void 0,
            wordWrap: true,
            getHeaderArray: function () { },
