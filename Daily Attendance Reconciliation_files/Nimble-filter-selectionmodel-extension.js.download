    var handleHotJsonDataRequests = function (url, params, tableId, status) {
        //console.time("handleHotJsonDataRequests");

        var options = $(tableId).data("options");
        handleBlockUiForTable(options.mainContainer);
        const config = {
            url: url,
            data: JSON.stringify(params)
        };

        setTimeout(function () {
            handleAjaxRequest(config,
                function (results) {
                    const objArr = results;
                    if (objArr.StatusType === "error") {
                        const clientMessage = { title: objArr.Title, type: objArr.StatusType, content: objArr.Message && objArr.Message.length > 0 ? objArr.Message : "Unable To Load Data!!" };
                        window.UIToastr.init(clientMessage);
                    } else {
                        const dt = objArr.Object[0];
                        const virtualData = objArr.Object[0];
                        const modifiedDt = dt.slice(1);
                        var virtualWithOutHeader = virtualData.slice(1);
                        const header = dt[0];
                        const columnName = objArr.Object[1].ColumnName;
                        const sortIcon = objArr.Object[1].SortIcon;
                        const sortOrder = objArr.Object[1].SortOrder;
                        const icon = columnName === undefined || columnName === "" ? "fa-sort" : sortIcon;
                        var dataTypes = [];
                        if (typeof objArr.Object[1].DataTypes !== "undefined") {
                            dataTypes = objArr.Object[1].DataTypes.split(",");
                        }
                        var columnsName;
                        global.header = header;
                        var $tbl = $(tableId);
                        var scsrollLeftPosition = $($tbl).scrollLeft();
                        var test = $($tbl).data("selectedValue");
                        var test1 = $($tbl).data("mappedValue");
                        $tbl = $(tableId).data("nimble").reInitAllData();
                        $handsonTable = $($tbl);
                        global.orderByCol = columnName;
                        $handsonTable.data("orderByCol", columnName);
                        $handsonTable.data("dataTypes", dataTypes);
                        var controlName;
                        if (objArr.Object[1].ColumnsName !== undefined) {
                            columnsName = objArr.Object[1].ColumnsName.split(',');
                            $($tbl).data("controlName", objArr.Object[1].ControlName);
                            controlName = objArr.Object[1].ControlName;
                            control = objArr.Object[1].ControlName;

                            var userType = parseInt(objArr.Object[1].type, 10);

                            if (userType <= 2) {
                                $("#gridManager").show();
                            }
                        } else {
                            columnsName = header;
                            $($tbl).data("gridManager", false);
                        }
                        $handsonTable.data("header", columnsName);
                        $handsonTable.data("parentHeader", columnsName);
                        var width = void 0;
                        var settings = $($tbl).data("options");
                        if (typeof settings !== "undefined") {
                            if (typeof settings.onSuccess !== "undefined") {
                                var virtual = virtualWithOutHeader;
                                var columnNameap = columnsName;
                                virtual.unshift(columnsName);
                                settings.onSuccess(virtual, columnNameap, objArr);
                            }
                        }
                        settings.element = $($tbl);
                        var isFrozen = 0;
                        if (settings.fixedColumnsLeft !== 0 || settings.fixedColumnsLeft !== void 0) {
                            isFrozen = settings.fixedColumnsLeft;
                        }
                        if (objArr.Object[1].WidthOfColumn !== undefined) {
                            width = objArr.Object[1].WidthOfColumn.split(",");
                            var frozen = objArr.Object[1].IsFrozen.split(",");
                            for (var i = 0; i < frozen.length; i++) {
                                if (frozen[i] === "1") {
                                    if (columnsName.indexOf("SN") !== -1) {
                                        isFrozen = i + 2;
                                    } else
                                        isFrozen = i + 1;
                                    break;
                                }
                            }
                            if (columnsName.indexOf("SN") !== -1) {
                                width.unshift(50);
                            }
                            //KRG: Code seems not usable.
                            //for (let j = 0; j < width.length; j++) {
                            //    var wid = parseInt(width[j], 10);
                            //    if (wid < 21 && wid !== 1) {
                            //        //width[j] = "28";
                            //    }
                            //}
                        }
                        $pageWraper = settings.pageWraper;
                        settings.allowFilteringAndPaging = settings.allowFilteringAndPaging === undefined ? true : settings.allowFilteringAndPaging;
                        $.extend($.fn.selectionAppModel.configGetData, settings);
                        $.extend(configGetData, settings);
                        settings.isEditAble = settings.isEditAble === undefined || settings.isEditAble === "false"
                            ? false
                            : settings.isEditAble;
                        useCheckBoxs = settings.useCheckBox;
                        $($tbl).data("data", modifiedDt);
                        var nimFrame = $($tbl).data("selectedValue");
                        $($tbl).data("selectedValue", test);
                        $($tbl).data("mappedValue", test1);
                        const hotConfig = handleHotJsonDataRequestsPreparation(modifiedDt, header, columnName, sortOrder, sortIcon, dataTypes, icon, useCheckBoxs, columnsName, width, isFrozen, settings, $tbl, status, nimFrame);
                        $.extend(hotConfig, settings);
                        $($tbl).removeData("handsontable");
                        $($tbl).handsontable(hotConfig);
                        hot = $($tbl).handsontable("getInstance");
                        handleGridManagerFromPage.inithandleConfigGridClick($("#gridManager", settings.pageWraper), control, $($tbl));

                        //$(hot.view.wt.wtScrollbars.horizontal.scrollHandler).scrollLeft(scsrollLeftPosition);
                        settings.handsontableInstance = $($tbl).handsontable("getInstance");;
                        handlefirstColumnSize($tbl);
                    }

                },
                function (results) {
                    //console.log(results);
                },
                function (results) {

                    const objArr = JSON.parse(results.responseText);
                    if (objArr.Object[0].length > 0) {
                        handlePopoversToggleOnBodyClick();
                        handlePopOverMove();
                        const currentPage = parseInt(objArr.Object[1].CurrentPage);
                        const nextPage = parseInt(objArr.Object[1].NextPage);
                        const totalItems = parseInt(objArr.Object[1].TotalItems);
                        const sortOrder = objArr.Object[1].SortIcon === "fa-sort-asc" ? "ASC" : "DESC";
                        const colName = objArr.Object[1].ColumnName == null
                            ? ""
                            : objArr.Object[1].ColumnName;
                        const sortData = colName + ":" + sortOrder;

                        var start = (currentPage - 1) * itemsPerPage(options) + 1, end = totalItems;
                        if (itemsPerPage(options) < totalItems) {
                            end = itemsPerPage(options) * currentPage;
                            if (end > totalItems) {
                                end = totalItems;
                            }
                        }
                        $(".btn-prev-page", options.pageWraper)
                            .attr("data-page", currentPage === 1 ? currentPage : currentPage - 1)
                            .data("sort", sortData);
                        currentPage <= 1
                            ? $(".btn-prev-page", options.pageWraper).addClass("disabled")
                            : $(".btn-prev-page", options.pageWraper).removeClass("disabled");
                        //input
                        $(".currentPageInput", options.pageWraper)
                            .val(currentPage)
                            .attr("readonly", end === totalItems ? true : false);
                        //next
                        end === totalItems
                            ? $(".btn-next-page", options.pageWraper).addClass("disabled")
                            : $(".btn-next-page", options.pageWraper).removeClass("disabled");
                        $(".btn-next-page", options.pageWraper).attr("data-page", nextPage).data("sort", sortData);
                        // e.g. "21-30 of 193 items" Display record's info
                        $("#record-info-text", options.pageWraper)
                            .html(`<b>${totalItems === 0 ? 0 : start}</b> to <b>${end}</b> of <b>${totalItems}</b> records.`);
                        $(".btn-page-to-go", options.pageWraper).data("sort", sortData);
                    }
                    $(options.mainContainer).unblock();
                }
            );
        }, 400);
        //console.timeEnd("handleHotJsonDataRequests");

    };

    var handleSubAjaxRequestFormMethod = function (element, clear) {
        var settings = $(element).data("options");
        $mainContainer = settings.mainContainer;
        $handsonTable = element;
        $rootUrl = settings.url;
        if (settings.paramsData !== undefined) {
            $.extend($.fn.selectionAppModel.configGetData.paramsData, settings.paramsData);
        }
        if (typeof clear === "undefined") {
            $(element).data("sort", []);
            $(element).data("selectedValue", []);
            $(element).data("mappedValue", []);
        }
        var sortElem = $(element).data("sort");
        var sortOrd = clear === "btnClear" && sortElem !== undefined ? sortElem[1] : "",
            orderCol = clear === "btnClear" && sortElem !== undefined ? sortElem[0] : "";
        const objParam = {
            currentPage: $(".currentPageInput", settings.mainContainer).val(),
            sortOrder: sortOrd,
            orderColumn: orderCol,
            itemsPerPage: $("select.items-per-page.select3 :selected", settings.mainContainer).val(),
            filterExpression: $(element).data("filterArray"),
            postData: postData,
            hrmPostData: postData
        };
        $.extend(objParam, settings.paramsData);
        setImmediate(handleHotJsonDataRequests($rootUrl, objParam, element, clear));

    };

    var handleFilterApplyClick = function (selector, columnOptionsValue, element) {
        $(selector).on("click", function (e) {
            e.preventDefault();
            var options = $(element).data("options");
            $rootUrl = options.url;
            $mainContainer = options.mainContainer;
            if (options.paramsData !== undefined) {
                $.extend($.fn.selectionAppModel.configGetData.paramsData, options.paramsData);
            }
            const $this = $(this);

            handleBlockUiForTable($mainContainer);
            const elems = $this.parents("div.popover-content").find("input, select");
            const filterColumn = $(elems[1]).data('column');
            var notPushed = true;

            const arr = $(element).data("filterArray").length;//filterExpression.length;
            for (let i = 0; i < arr; i++) {
                if ($(element).data("filterArray")[i][0] === filterColumn) {
                    $(element).data("filterArray")[1] = elems[0].value;
                    $(element).data("filterArray")[2] = elems[1].value;
                    $(element).data("filterArray")[3] = elems[2].value;
                    $(element).data("filterArray").splice(i);
                    break;
                } else {
                    if (notPushed) {
                        $(element).data("filterArray").push([filterColumn, elems[0].value, elems[1].value, elems[2].value]);
                        notPushed = false;
                    }
                }
            }

            if ($(element).data("filterArray").length <= 0) {
                $(element).data("filterArray").push([filterColumn, elems[0].value, elems[1].value, elems[2].value]);
            }

            const column = function () {
                return columnOptionsValue[3].length > 0 ? columnOptionsValue[0] : "";
            },
                sortOrder = function () {
                    if (columnOptionsValue[3].length > 0) {
                        return columnOptionsValue[2] === "fa-sort-asc" ? "ASC" : "DESC";
                    }
                    return "";
                };


            var sortElem = $(element).data("sort");
            var sortOrd = sortElem !== undefined ? sortElem[1] : sortOrder,
                orderCol = sortElem !== undefined ? sortElem[0] : column;
            setImmediate(handleHotJsonDataRequests($rootUrl,
                getParameterForAjax(null, sortOrd, orderCol, element),
                element,
                "filter"));

            $("button.data-filter.popovers", $mainContainer).popover("hide");
            return false;
        });
    };

