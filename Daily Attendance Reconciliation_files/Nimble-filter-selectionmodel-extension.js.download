    var getParameterForAjax = function (currentPage, sortOrder, orderColumn, element) {
        const currPage = currentPage == null ? $(".currentPageInput", $mainContainer).val() : currentPage;
        const sort = sortOrder == null ? "" : sortOrder;
        const order = orderColumn == null ? "" : orderColumn;
        var options = $(element).data("options");
        var objParam = {
            currentPage: currPage,
            sortOrder: sort,
            orderColumn: order,
            itemsPerPage: $("select.items-per-page.select3 :selected", $mainContainer).val(),
            filterExpression: $(element).data("filterArray"),//filterExpression,
            postData: postData,
            hrmPostData: postData
        };
        if (options.paramsData !== undefined) {
            $.extend(objParam, options.paramsData);
        }
        return objParam;
    }

    var handleDataSortingCol = function (selector, element) {
        $(selector).on("click", function (e) {
            e.preventDefault();
            const $this = $(this);
            var tableId = $(element);//$this.offsetParent("div.column-filter").parents("div.handsontable").find("div.ht_clone_top").parents("div.handsontable");           
            var options = $(tableId).data("options");
            $(tableId).data("sort", $this.data("sort").split(":"));
            $rootUrl = options.url;
            $mainContainer = options.mainContainer;
            if (options.paramsData !== undefined) {
                $.extend($.fn.selectionAppModel.configGetData.paramsData, options.paramsData);
            }
            $("button.data-filter").each(function () { $(this).popover("hide"); });
            const iconElem = this.children[0];
            const orderCol = $this.data("sort").split(":");
            var column = orderCol[0];
            var sortOrder = orderCol[1] === "undefined" ? "ASC" : orderCol[1];
            setTimeout(function () {
                return handleHotJsonDataRequests($rootUrl, getParameterForAjax(null, sortOrder, column, tableId), tableId, "btnSort");
            }, 300);

            return false;
        });
    }

