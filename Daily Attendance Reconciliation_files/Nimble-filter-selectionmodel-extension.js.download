    var onChange = function (event, instances, options, coords) {
        const $that = $(event.target);
        setImmediate(function () {
            var val;
            const freezeColumnLeft = instances.view.settings.fixedColumnsLeft;
            if (freezeColumnLeft !== 0) {
                //handleCheckedObjectSingle(event, instances);
            }
            const values = $that.val();
            var rowIndex = coords.row;//$that.data("row");
            var colIndex = coords.col;//$that.data("col");
            var checkBox;//= $($(".htCheckboxRendererInput", $(".ht_clone_top"))[rowIndex])
            var hello = instances.getCell(rowIndex, colIndex);
            checkBox = hello.querySelectorAll('input[type=checkbox]');
            if ($that.is(":checked")) {
                $that.prop("checked", "checked")
                $($(".htCheckboxRendererInput", $(".ht_clone_top", $(instances.rootElement)))[rowIndex]).prop("checked", "checked");
                $($(".htCheckboxRendererInput", $(".ht_clone_corner", $(instances.rootElement)))[rowIndex]).prop("checked", "checked");
                $($(".htCheckboxRendererInput", $(".ht_clone_left", $(instances.rootElement)))[rowIndex]).prop("checked", "checked");
                $($(".htCheckboxRendererInput", $(".ht_master", $(instances.rootElement)))[rowIndex]).prop("checked", "checked");
                val = values; //currenetrow[1];
                $(this).parents("td").addClass("checked");
                if (selectedEmpCode.indexOf(val.toString()) === -1) {
                    selectedEmpCode.push(val.toString());
                }
                var mappedcols = options.mappedCol !== void 0 ? $(instances.rootElement).data('nimble').getHeaderArray().indexOf(options.mappedCol) : 1;
                var mapval = instances.getDataAtCell(rowIndex, mappedcols)
                if (mapval) {
                    if (mappedItems.indexOf(mapval.toString()) === -1) {
                        mappedItems.push(mapval.toString());
                    }
                }
                if ($(instances.rootElement).data("selectedValue").indexOf(val.toString()) === -1) {
                    $(instances.rootElement).data("selectedValue").push(val.toString());
                }
                if (mapval) {
                    if ($(instances.rootElement).data("mappedValue").indexOf(mapval.toString()) === -1) {
                        $(instances.rootElement).data("mappedValue").push(mapval.toString());
                    }
                }
            } else {
                val = values; //currenetrow[1];
                $that.prop("checked", "checked")
                $($(".htCheckboxRendererInput", $(".ht_clone_top", $(instances.rootElement)))[rowIndex]).prop("checked", "");
                $($(".htCheckboxRendererInput", $(".ht_clone_corner", $(instances.rootElement)))[rowIndex]).prop("checked", "");
                $($(".htCheckboxRendererInput", $(".ht_clone_left", $(instances.rootElement)))[rowIndex]).prop("checked", "");
                $($(".htCheckboxRendererInput", $(".ht_master", $(instances.rootElement)))[rowIndex]).prop("checked", "");
                $(this).parents("td").removeClass("checked");
                const indx = selectedEmpCode.indexOf(val.toString());
                selectedEmpCode.splice(indx, 1);

                var selIndex = $(instances.rootElement).data("selectedValue").indexOf(val.toString());
                $(instances.rootElement).data("selectedValue").splice(selIndex, 1);

                var mappedcols = options.mappedCol !== void 0 ? $(instances.rootElement).data('nimble').getHeaderArray().indexOf(options.mappedCol) : 1;
                var mapval = instances.getDataAtCell(rowIndex, mappedcols)

                if (mapval) {
                    const mapindx = mappedItems.indexOf(mapval.toString());
                    mappedItems.splice(mapindx, 1);


                    var selmappedIndex = $(instances.rootElement).data("mappedValue").indexOf(mapval.toString());
                    $(instances.rootElement).data("mappedValue").splice(selmappedIndex, 1);
                }
            }
        });
        $(event.target).unbind().bind("change", handleCheck($that, instances, options, coords));
    };

    var handleCheck = function (sender, instance, options, coords) {
        $(sender).off("change").on("change", function (event) {
            event.preventDefault();
            if (options.isEditAble === true) {
