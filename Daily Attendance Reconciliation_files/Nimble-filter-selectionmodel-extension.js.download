    var configGetData;
    var getValueFromArayOfObject = function (width, header, col, settings) {
        var headerCols = [];
        if (settings.widthOfColumn !== undefined) {
            $.each(settings.widthOfColumn, function (index, value) {
                $.each(value, function (i, val) {
                    if (header[col] === i) {
                        width = parseInt(val, 10);
                        headerCols.push(i);
                    }
                });
            });
        }

        if (headerCols.indexOf(header[col] > -1)) {

        } else {
            width = 80;
        }
        if (header[col] === "SN") {
            width = 50;
        }
        return width;
    }

    var getCustomHeaderName = function (col, header, original, settings) {
        var colText = void 0;
        if (settings.headerText !== undefined) {
            for (var j = 0; j < settings.headerText.length; j++) {
                var obj = settings.headerText[j];
                $.each(obj, function (ab, cd) {
                    if (header[col] === ab) {
                        colText = cd;
                    }
                });
            }
        }
        if (colText === void 0) {
            colText = header[col];
        }
        return colText;
