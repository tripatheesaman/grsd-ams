                       <div class ="form-group" style="margin-top:5px;">
                         <a href="" class="text-muted pull-right" id="gridManager" data-url='/CoreExtension/GridManager/Edit' data-action="configGrid" data-width="75%" style="display:none;"><i class="fa fa-gear"></i></a>
