            onSuccess: function (data, header) { },
            setGridHeight: void 0,
            mappedCol: void 0
        }
        this.defaultSettings = $.extend(defaultOptions, this.options);
        var div = document.createElement("DIV");
        div.id = "nimble-" + this.element.id;
        //inithandleWindowPageSizeControl(this.element);
        //KRG: remove realtime page size due to performance.
        //handlePageResizeInRealTime(this.element);
        this.load(this.options);
    };

    NimbleFrameWork.init = function (element, options) {
        this.settings = options;
        var setting = this.settings;
        this.element = element;
        $rootUrl = setting.url !== null || setting.url !== undefined || setting.url !== "" ? setting.url : "";
        useCheckBoxs = setting.useCheckBox !== null || setting.useCheckBox !== undefined ? setting.useCheckBox : true;
        $mainContainer = setting.mainContainer;
        $pageWraper = setting.pageWraper;
        this.handleSubAjaxRequestFormMethod = function (clear) {
            var settings = $(this.element).data("options");
            $mainContainer = settings.mainContainer;
            $handsonTable = element;
            $rootUrl = settings.url;
            if (settings.paramsData !== undefined) {
                $.extend(this.defaultOptions, settings.paramsData);
            }
            var sortElem = $(element).data("sort");
            var sortOrd = clear === "btnClear" && sortElem !== undefined ? sortElem[1] : "",
                orderCol = clear === "btnClear" && sortElem !== undefined ? sortElem[0] : "";

            const objParam = {
                currentPage: $(".currentPageInput", settings.mainContainer).val(),
                sortOrder: sortOrd,
                orderColumn: orderCol,
                itemsPerPage: $("select.items-per-page.select3 :selected", settings.mainContainer).val(),
                filterExpression: $(this.element).data("filterArray"),//filterExpression,
                postData: postData,
                hrmPostData: postData
            };
            $.extend(objParam, settings.paramsData);
            setImmediate(handleHotJsonDataRequests(setting.url, objParam, this.element, clear));

        };

        if (setting.formType === "Index" || setting.formType === undefined) {
            pagingTemplate.initTemplate($pageWraper);
            this.handleSubAjaxRequestFormMethod();

        } else if (setting.formType === "Child") {
            pagingTemplate.initTemplate($pageWraper);
            this.handleSubAjaxRequestFormMethod();

        } else if (setting.formType === "Selection") {
            handleSearchButtonClick($("#btnSearch"), element);
            pagingTemplate.initTemplate($pageWraper);
            $("#btnSearch").trigger("click");

        } else {
            return;
        }
    };

    NimbleFrameWork.prototype = {
        constructor: NimbleFrameWork,
        load: function (settings) {
            $rootUrl = settings.url !== null || settings.url !== undefined || settings.url !== "" ? settings.url : "";
            useCheckBoxs = settings.useCheckBox !== null || settings.useCheckBox !== undefined ? settings.useCheckBox : true;
            $mainContainer = settings.mainContainer;
            $pageWraper = settings.pageWraper;

            if (settings.formType === "Index" || settings.formType === undefined) {
                pagingTemplate.initTemplate($pageWraper);
                handleSubAjaxRequestFormMethod(this.element);
            } else if (settings.formType === "Child") {
                pagingTemplate.initTemplate($pageWraper);
                handleSubAjaxRequestFormMethod(this.element);
            } else if (settings.formType === "Selection") {
                handleSearchButtonClick($("#btnSearch"), this.element);
                pagingTemplate.initTemplate($pageWraper);
                $("#btnSearch").trigger("click");
            } else {
                return;
            }
        },
        getCheckedItem: function () {
            return checkedData(this.element);
        },
        getAllData: function (row, col, rowEnd, colEnd) {
            const instance = $(this.element).data("handsontable");
            var data;
            if (row === undefined || row === null) {
                data = instance.getData();
                data.unshift($(this.element).data("header"));
                return data;
            }
            data = instance.getData(row, col, rowEnd, colEnd);
            data.unshift($(this.element).data("header"));
            return data;
        },
        getSelected: function () {
            const instance = $(this.element).data("handsontable");
            return instance.getSelected();
        },
        getDataForDataAction: function (rowStart, colStart, rowEnd, colEnd, columnIndex) {

            const instance = $(this.element).data("handsontable");
            const data = instance.getData(rowStart, colStart, rowEnd, colEnd);
            const returnText = data[0][columnIndex];
            return returnText;
        },
        getInstance: function () {
            return getInstance(this.element);
        },
        getDataInstance: function () {
            $.data("nimbleFramework", $(this.element).data("handsontable"));
            return $handsonTable.data("handsontable");
        },
        getHeaderArray: function () {
            var header = [];
            header = $(this.element).data("header");
            return header;
        },
        getData: function () {
            var data = getCheckDataInArray(this.element);
            return data;
        },
        getReloadOnSuccess: function () {
            handleSubAjaxRequestFormMethod(this.element);
        },
        getSelectedRow: function () {
            return getSelectedRow(this);
        },
        getSelectedCell: function (columnName) {
            if (typeof columnName === "undefined")
                return getSelectedRow(this);
            else
                return getSelectedRowWithCol(this, columnName);
        },
        getDataWithHeader: function () {
            const data = this.getData();
            data.unshift(this.getHeaderArray());
            return data;
        },
        getOrderByCol: function () {
            return getOrderByCol(this.element);
        },
        getColumnIndexForPostBack: function (headerColName) {

            if (this.options.onRowClick !== void 0) {
                const header = this.getHeaderArray();
                return header.indexOf(this.options.onRowClick);
            }
            if (headerColName === null || headerColName === undefined) {
                return 1;
            } else {
                const header = this.getHeaderArray();
                return header.indexOf(headerColName);
            }
        },
        reload: function () {
            var options = $(this.element).data("options");
            handleReInitHotInstances(this.element);
            $(this.element).selectionAppModel(options);

        },
        init: function (settings) {
            var options = $.extend({}, $.fn.selectionAppModel.configGetData, settings);
            init(options, this.element);
        },
        reInitAllData: function () {
            var $elem = handleReInitHotInstances($(this.element)[0]);
            this.element = document.getElementById($elem.id);
            inithandleWindowPageSizeControl(this.element);
            return this.element;
        },
        getCheckedboxValue: function () {
            return $(this.element).data("selectedValue");
        },
        handleUpdateSettings: function (configure) {
            var header = $(this.element).data("header");
            var instance = this.getInstance();
            var options = this.options;
            var dataTypes = $(this.element).data("dataTypes");
            var columnName = $(this.element).data("orderByCol");
            var configCells = {
                cells: function (row, col, prop) {
                    var ele = this;
                    var cellProperties = {};
                    if (header[col] === "SN") {
                        if (options.useCheckBox) {
                            //KRG: Avoid reading whole row and took only data of related cell.
                            var index = options.onRowClick === undefined ? 1 : header.indexOf(options.onRowClick);
                            var tsts = ele.instance.getDataAtCell(row, index);

                            //var checkData = ele.instance.getDataAtRow(row);
                            //var index = options.onRowClick === undefined
                            //    ? 1
                            //    : header.indexOf(options.onRowClick);
                            //var tsts = checkData[index];

                            var checkInput = '<input type="checkbox" id="selectSingle" class="htCenter htMiddle selectSingle htCheckboxRendererInput"';
                            checkInput += ' value="' + tsts + '" data-row="' + row + '" data-col="' + col + '" ';
                            return {
                                renderer: function (instance, td, rows, cols, props, value, cellProperties) {
                                    window.Handsontable.renderers.CheckboxRenderer.apply(this, arguments);
                                    checkInput += value === true ? 'checked=checked' : '';
                                    checkInput += ' />';
                                    td.innerHTML = checkInput;
                                    td.style.textAlign = 'center';
                                },
                                type: 'checkbox'
                            };
                        } else {
                            cellProperties.editor = "text";
                            cellProperties.readOnly = true;
                        }
                    }
                    else {
                        if (options.cellsModifyAndRender !== undefined) {
                            options.cellsModifyAndRender(row, col, prop, header, cellProperties, instance, columnName);
                            if (dataTypes[col] === "date") {
                                var colH = dataTypes[col] === "date";
                                return {
                                    renderer: function (instance, td, rows, cols, props, value, iCellProperties) {
                                        window.Handsontable.renderers.TextRenderer.apply(this, arguments);
                                        if (td.innerHTML !== "") {
                                            if (value !== null) {
                                                var dates = value.split("T")[0];
                                                td.innerHTML = dates;
                                            }
                                        }
                                        if (cellProperties.editor === "date") {
                                            if (colH) {
                                                iCellProperties.editor = "date";
                                                td.className += " datepicker";
                                            } else {
                                                iCellProperties.editor = "text";
                                                td.className += " myNepaliDate";
                                            }
                                        }
                                    },
                                    type: cellProperties.editor === "date" ? "date" : "text",
                                    readOnly: cellProperties.editor === "date" ? false : true,
                                    correctFormat: true,
                                    defaultDate: ''
                                };
                            }
                            if (dataTypes[col] === "float" || dataTypes[col] === "decimal") {
                                var dta = ele.instance.getDataAtCell(row, col);
                                return {
                                    renderer: function (instance, td, rows, cols, props, value, iCellProperties) {
                                        //window.Handsontable.NumericCell.renderer.apply(this, arguments);
                                        Handsontable.renderers.NumericRenderer.apply(this, arguments);
                                        if (td.innerHTML !== "") {
                                            if (value !== null) {
                                                td.innerHTML = floorFigure(value);
                                            }
                                            if (options.floatRenderer !== void 0) {
                                                options.floatRenderer(instance, td, rows, cols, props, value, iCellProperties, header);
                                            }
                                            if (typeof configure === "object") {
                                                if (configure.floatRenderer !== undefined)
                                                    configure.floatRenderer(instance, td, rows, cols, props, value, iCellProperties, header);
                                            }
                                        }
                                    },
                                    readOnly: cellProperties.readOnly === true ? true : false,
                                    type: "numeric",
                                    allowInvalid: dta === '' ? true : false
                                };
                            }
                        } else if (configure.cells != undefined) {
                            configure.cells(row, col, prop);
                        }
                        else {
                            cellProperties.editor = "text";
                            cellProperties.readOnly = true;
                        }
                    }
                    if (typeof configure === "object") {
                        if (typeof configure.cells !== "undefined")
                            $.extend(cellProperties, configure.cells(row, col, prop, header, cellProperties));
                    }

                    if (typeof configure === "function") {
                        cellProperties = configure(row, col, prop, header, cellProperties);
                    }

                    return cellProperties;
                }
            };
            if (typeof configure.data !== "undefined") {
                configCells.dataSchema = function () {
                    var schemaObj = {};
                    if (!configure.data.length > 0) {
                        for (var i = 0, len = header.length; i < len; i++) {
                            schemaObj[header[i]] = null;
                        }
                    } else {
                        schemaObj = [];
                    }
                    return schemaObj;
                },
                    configCells.data = configure.data;
            }
            handleHotUpdateSettings(instance, configCells);
        },
        refresh: function () {

            //$(document).off("click");
            NimbleFrameWork.call(this, this.element, this.options);
            if ($) {
                // Bind new instance of slider to the element
                $.data(this.element, 'nimble', this);
            }
            return this;
        },
        getFilterOfGrid: function () {
            var filter = $(this.element).data("filterArray");
            return filter;
        },
        getSortOrder: function () {
            var sort = $(this.element).data("sort");
            return sort;
        },
        getDataWithColumn: function (colNameToGet) {
            return handleGetColumnAccordingToName(this.getAllData(), colNameToGet, this.getHeaderArray());
        },
        getMappedItems: function () {
            return mappedData(this.element);
        },
        getSelectedMappedCell: function () {
            if (this.options.mappedCol)
                return getSelectedRowWithCol(this, this.options.mappedCol);
            else return "";
        },
    };

    var oldCatch = $.fn.selectionAppModel;
    $.fn.selectionAppModel = function (options) {
        $handsonTable = $(this);
        var instance = null;
        var filterArray = [];
        var selectedValue = [];
        var mappedValue = [];
        this.each(function () {
            $.data(this, "nimble", null);
            $.data(this, 'options', options);
            $.data(this, 'filterArray', filterArray);
            $.data(this, "selectedValue", selectedValue);
            $.data(this, "mappedValue", mappedValue);
            $.data(this, "sort", []);
            var nimbleConfig = $.extend({}, this.configGetData, options);
            $.extend(configGetData, options);
            $.data(this, "nimbleConfig", nimbleConfig);
            if (!$.data(this, 'nimble')) {
                instance = new NimbleFrameWork(this, nimbleConfig);
                $.data(this, 'nimble', instance);
            }
        });
        return this;
    };
