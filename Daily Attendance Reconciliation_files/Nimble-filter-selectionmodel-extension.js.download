var setMaximizeGridHeight = function () {

    var divPrint = $("#reload-alls").length;
    if (divPrint >= 1) {
        var profile = 0;

        var nav = $(".navbar-default").length;
        if (nav >= 1) {
            profile = profile + 52;
        } else {
            profile = profile - 0;
        }
        var page = $(".box-footer", $("#reload-alls")).length;
        if (page >= 1) {
            profile = profile + 50;
        } else {
            profile = profile - 10;
        }
        //profile = profile + 166 + 24;
        var heightOfGrid = $(window).height() - profile;
        if (heightOfGrid <= 100) {
            heightOfGrid = 150;
        }
        $('.hands-on-table').height(heightOfGrid);
    }
}


    (function (global, undefined) {
        "use strict";

        if (global.setImmediate) {
            return;
        }

        var nextHandle = 1; // Spec says greater than zero
        var tasksByHandle = {};
        var currentlyRunningATask = false;
        var doc = global.document;
        var registerImmediate;

        function setImmediate(callback) {
            // Callback can either be a function or a string
            if (typeof callback !== "function") {
                callback = new Function("" + callback);
            }
            // Copy function arguments
            var args = new Array(arguments.length - 1);
            for (var i = 0; i < args.length; i++) {
                args[i] = arguments[i + 1];
            }
            // Store and register the task
            var task = { callback: callback, args: args };
            tasksByHandle[nextHandle] = task;
            registerImmediate(nextHandle);
            return nextHandle++;
        }

        function clearImmediate(handle) {
            delete tasksByHandle[handle];
        }

        function run(task) {
            var callback = task.callback;
            var args = task.args;
            switch (args.length) {
                case 0:
                    callback();
                    break;
                case 1:
                    callback(args[0]);
                    break;
                case 2:
                    callback(args[0], args[1]);
                    break;
                case 3:
                    callback(args[0], args[1], args[2]);
                    break;
                default:
                    callback.apply(undefined, args);
                    break;
            }
        }

        function runIfPresent(handle) {
            // From the spec: "Wait until any invocations of this algorithm started before this one have completed."
            // So if we're currently running a task, we'll need to delay this invocation.
            if (currentlyRunningATask) {
                // Delay by doing a setTimeout. setImmediate was tried instead, but in Firefox 7 it generated a
                // "too much recursion" error.
                setTimeout(runIfPresent, 0, handle);
            } else {
                var task = tasksByHandle[handle];
                if (task) {
                    currentlyRunningATask = true;
                    try {
                        run(task);
                    } finally {
                        clearImmediate(handle);
                        currentlyRunningATask = false;
                    }
                }
            }
        }

        function installNextTickImplementation() {
            registerImmediate = function (handle) {
                process.nextTick(function () { runIfPresent(handle); });
            };
        }

        function canUsePostMessage() {
            // The test against `importScripts` prevents this implementation from being installed inside a web worker,
            // where `global.postMessage` means something completely different and can't be used for this purpose.
            if (global.postMessage && !global.importScripts) {
                var postMessageIsAsynchronous = true;
                var oldOnMessage = global.onmessage;
                global.onmessage = function () {
                    postMessageIsAsynchronous = false;
                };
                global.postMessage("", "*");
                global.onmessage = oldOnMessage;
                return postMessageIsAsynchronous;
            }
        }

        function installPostMessageImplementation() {
            // Installs an event handler on `global` for the `message` event: see
            // * https://developer.mozilla.org/en/DOM/window.postMessage
            // * http://www.whatwg.org/specs/web-apps/current-work/multipage/comms.html#crossDocumentMessages

            var messagePrefix = "setImmediate$" + Math.random() + "$";
            var onGlobalMessage = function (event) {
                if (event.source === global &&
                    typeof event.data === "string" &&
                    event.data.indexOf(messagePrefix) === 0) {
                    runIfPresent(+event.data.slice(messagePrefix.length));
                }
            };

            if (global.addEventListener) {
                global.addEventListener("message", onGlobalMessage, false);
            } else {
                global.attachEvent("onmessage", onGlobalMessage);
            }

            registerImmediate = function (handle) {
                global.postMessage(messagePrefix + handle, "*");
            };
        }

        function installMessageChannelImplementation() {
            var channel = new MessageChannel();
            channel.port1.onmessage = function (event) {
                var handle = event.data;
                runIfPresent(handle);
            };

            registerImmediate = function (handle) {
                channel.port2.postMessage(handle);
            };
        }

        function installReadyStateChangeImplementation() {
            var html = doc.documentElement;
            registerImmediate = function (handle) {
                // Create a <script> element; its readystatechange event will be fired asynchronously once it is inserted
                // into the document. Do so, thus queuing up the task. Remember to clean up once it's been called.
                var script = doc.createElement("script");
                script.onreadystatechange = function () {
                    runIfPresent(handle);
                    script.onreadystatechange = null;
                    html.removeChild(script);
                    script = null;
                };
                html.appendChild(script);
            };
        }

        function installSetTimeoutImplementation() {
            registerImmediate = function (handle) {
                setTimeout(runIfPresent, 0, handle);
            };
        }

        // If supported, we should attach to the prototype of global, since that is where setTimeout et al. live.
        var attachTo = Object.getPrototypeOf && Object.getPrototypeOf(global);
        attachTo = attachTo && attachTo.setTimeout ? attachTo : global;

        // Don't get fooled by e.g. browserify environments.
        if ({}.toString.call(global.process) === "[object process]") {
            // For Node.js before 0.9
            installNextTickImplementation();

        } else if (canUsePostMessage()) {
            // For non-IE10 modern browsers
            installPostMessageImplementation();

        } else if (global.MessageChannel) {
            // For web workers, where supported
            installMessageChannelImplementation();

        } else if (doc && "onreadystatechange" in doc.createElement("script")) {
            // For IE 6–8
            installReadyStateChangeImplementation();

        } else {
            // For older browsers
            installSetTimeoutImplementation();
        }

        attachTo.setImmediate = setImmediate;
        attachTo.clearImmediate = clearImmediate;
    }(typeof self === "undefined" ? typeof global === "undefined" ? this : global : self));

(function ($) {
    "use strict";
    var postData = {};
    var $rootUrl = "";
    var $mainContainer;
    var $handsonTable;
    var $pageWraper;
    var useCheckBoxs = false;
    var selectedEmpCode = [];
    var mappedItems = [];
    var hot;
    var filterExpression = [];
    var global = {
        FormData: [],
        //KRG: Unused variables for Global
        //Compartment: [],
        //CompartmentList: [],
        //RackList: [],
        //CategoryList: [],
        //Rack: [],
        //Category: [],
        //OldData: [],
        ColumnName: "",
        SortOrder: "",
        SortIcon: "",
        DataTypes: [],
        header: [],
        lastChange: [],
        orderByCol: ""
    };

    var initGlobalObjectSender = function (element) {
        return {
            Filters: $(element).data("filterArray")
        };
    };

    var filterTemplate = function () {
        var handleSelectOnLoad = function ($select) {
            const $that = $($select);
            var type = $('option:selected', $that).data("type");
            const $thatSelectedVal = $that.val();
            const firstInput = $that.parents("div.popover-content").find("input#first-value");
            const secondInput = $that.parents("div.popover-content").find("input#second-value");
            var btnApply = $that.parents("div.popover-content").find("button.btn-data-apply");

            //show hide input based on data type
            if (type === "bool") {
                $(firstInput).val($thatSelectedVal).hide();
            } else if (type === "date" && $thatSelectedVal === "IsBetween") {
                $(secondInput).removeClass("hidden");
                $(secondInput).on("keyup", handleInputs);
            } else {
                $(secondInput).addClass("hidden");
            }

            //for select change event
            setTimeout(function () {
                $(firstInput).on("keyup", handleInputs);
                if ($thatSelectedVal !== "" && firstInput.val() !== "") {
                    btnApply.prop("disabled", false);
                } else {
                    btnApply.prop("disabled", true);
                }

                //handle inputs when select index change
                if (secondInput.is(":visible") && secondInput.val() === "" && secondInput.val().trim().length <= 0) {
                    btnApply.prop("disabled", true);
                } else {
                    //secondInput.val("");
                }
            }, 200);


            if ($thatSelectedVal === "Empty") {
                $(firstInput).addClass("hidden");
                $(secondInput).addClass("hidden");
                btnApply.prop("disabled", false);
            } else {
                $(firstInput).removeClass("hidden");
            }

            //handle when input keyup
            function handleInputs() {
                if (this.value === "" || this.value.trim().length <= 0 || $thatSelectedVal === "") {
                    btnApply.prop("disabled", true);

                } else if (type === "date" && secondInput.val() === "" || firstInput.val() === "") {
                    //check if the second input is visible
                    if (secondInput.is(":visible")) {
                        btnApply.prop("disabled", true);
                    } else {
                        btnApply.prop("disabled", false);
                    }

                } else {
                    btnApply.prop("disabled", false);
                }
            }
        };

        var handlePrepareArrayInSelect = function (dataType, filter) {
            var optionsArray = [];
            var $select = $("#condition-selector");
            if (dataType === "string") {
                $select.append(`<option data-type="string" value="StartWith" class="hidden">Start With</option>`);
                $select.append(`<option data-type="string" value="EndWith">End With</option>`);
                $select.append(`<option data-type="string" value="Equals">Equals</option>`);
                $select.append(`<option data-type="string" value="Contains" ${dataType === "string" ? "selected='Selected'" : ""}>Contains</option>`);
            }
            if (dataType === "int" || dataType === "float" || dataType === "double" || dataType === "decimal") {
                $select.append(`<option data-type="${dataType}" value="GreaterThan">Greater Then</option>`);
                $select.append(`<option data-type="${dataType}" value="LessThan">Less Then</option>`);
                $select.append(`<option data-type="${dataType}" value="Equals" selected='Selected'>Equals</option>`);
            }
            if (dataType === "bool") {
                $select.append(`<option data-type="bool" value="True" ${dataType === "bool" ? "selected='Selected'" : ""
                    }>Yes</option>`);
                $select.append(`<option data-type="bool" value="False">No</option>`);
            }
            if (dataType === "date") {
                $select.append(` <option data-type="date" value="Before" ${dataType === "date" ? "selected='Selected'" : ""
                    }>Before</option>`);
                $select.append(`<option data-type="date" value="After">After</option>`);
                $select.append(`<option data-type="date" value="IsBetween">Is Between</option>`);
            }
        };
        var handleEnterKeyHit = function (id) {
            $(id).keyup(function (event) {
                if (event.keyCode === 13) {
                    $(".btn-data-apply").click();
                    return false;
                }
                return true;
            });
        };
        var handleToggleConditionValue = function (objId) {
            $(objId).on("change", function (e) {
                e.preventDefault();
                const $that = $(this);
                var type = $('option:selected', $that).data("type");
                const $thatSelectedVal = $that.val();
                $that.attr("data-prev", $thatSelectedVal);
                const firstInput = $that.parents("div.popover-content").find("input#first-value");
                const secondInput = $that.parents("div.popover-content").find("input#second-value");
                var btnApply = $that.parents("div.popover-content").find("button.btn-data-apply");
                var valueFirst = $(firstInput).val();
                $(firstInput).attr("data-prev", valueFirst);
                if (type === "bool") {
                    $(firstInput).val($thatSelectedVal).hide();
                } else if (type === "date" && $thatSelectedVal === "IsBetween") {
                    $(secondInput).removeClass("hidden");
                    $(secondInput).on("keyup", handleInputs);
                } else {
                    $(secondInput).addClass("hidden");
                }
                $(firstInput).on("keyup", handleInputs);
                if ($thatSelectedVal !== "" && firstInput.val() !== "") {
                    btnApply.prop("disabled", false);
                } else {
                    btnApply.prop("disabled", true);
                }
                if (secondInput.is(":visible") && secondInput.val() === "" && secondInput.val().trim().length <= 0) {
                    btnApply.prop("disabled", true);
                } else {
                    //secondInput.val("");
                }
                if ($thatSelectedVal === "Empty") {
                    $(firstInput).addClass("hidden");
                    $(secondInput).addClass("hidden");
                    btnApply.prop("disabled", false);
                } else {
                    $(firstInput).removeClass("hidden");
                }
                function handleInputs() {
                    if (this.value === "" || this.value.trim().length <= 0 || $thatSelectedVal === "") {
                        btnApply.prop("disabled", true);
                    } else if (type === "date" && secondInput.val() === "" || firstInput.val() === "") {
                        if (secondInput.is(":visible")) {
                            btnApply.prop("disabled", true);
                        } else {
                            btnApply.prop("disabled", false);
                        }
                    } else {
                        btnApply.prop("disabled", false);
                    }
                }
            });
        };
        var handleFilterTemplate = function (selector, element) {
            var tableId;
            //create a global tpl for filter
            var template = `
<form action="javascript:;" id="filter-template-form">
    <div id="condition-wrap">
        <div class="form-group" style="margin-bottom:10px !important; ">
            <div>By Condition: </div>
            <select class="form-control select3 input-sm" id="condition-selector" data-placeholder="Conditions..">

            </select>
        </div>

        <div class="form-group " style="margin-bottom:10px !important; ">
            <input id="first-value" type="text" placeholder="value" class ="form-control input-sm" />
        </div>
        <div class="form-group " style="margin-bottom:10px !important; ">
            <input id="second-value" type="text" placeholder="second value" class ="form-control input-sm hidden" />
        </div>
    </div>

    <div class="form-group">
        <button type="button"   class ="btn btn-success btn-xs col-md-5 col-sm-6 btn-data-apply">
            <i class="fa fa-check"></i>
        </button>
        <button type="button" class="btn btn-default btn-xs col-md-5 col-md-offset-2 data-cancel">
            <i class="fa fa-close"></i>
        </button>
        <div class="clearfix"></div>
    </div>
    <div class="form-group no-margin">
        <button type="button" class="btn btn-default btn-xs col-md-6 data-clear-filters" data-filter="clear">
            <i class="fa fa-close"></i> Clear Filters
        </button>
        <button type="button" class="btn btn-default btn-xs col-md-5 data-clear-filters" style="margin-left:12px;" data-filter="clearAll">
            <i class="fa fa-close"></i> Clear All
        </button>
        <div class="clearfix"></div>
    </div>
</form>`;

            function filterClick(selector) {
                $(selector).popover('hide');

                $(selector).on("click", function (e) {
                    e.preventDefault();
                    self = this;

                    $(selector).unbind().bind("click", filterClick($(selector)));
                    return false;
                });
            }


            //init popover for the  selector
            $(selector).popover({
                html: true,
                sanitize: false,
                title: "Filter Options",
                trigger: "click",
                placement: "bottom",
                container: "body",
                template: '<div class="popover" style="margin-left:-70px;"><div class="arrow" style="left:80%"></div><div class="popover-inner"><h3 class="popover-title"></h3><div class="popover-content"><p></p></div></div></div>',
                content: function () {

                    const $this = $(this);

                    const getDataType = $this.offsetParent().offsetParent().find("a").data('type');

                    $(".data-filter").not(this).popover("hide");
                    var filter = $(element).data("filterArray")
                    setTimeout(function () {
                        handlePrepareArrayInSelect(getDataType, filter);
                    }, 200);
                    setTimeout(function () {
                        handleSelectOnLoad($("#condition-selector"));
                        handleEnterKeyHit($("#first-value"));
                        handleEnterKeyHit($("#second-value"));
                    }, 100);
                    return $(template).html();
                }
            });

            //KRG: To check performance
            //$(document).bind("click", function (e) {
            //    if (!$(selector).is(e.target) && $(selector).has(e.target).length === 0 && $(".popover").has(e.target).length === 0) {
            //        $(selector).popover("hide");
            //    }
            //});

            //TODO: Display filter template with events.
            $(selector).bind("click", function (e) {
                e.preventDefault();
                tableId = $(element)
                return false;
            }).on("shown.bs.popover", function (evt) {
                const $this = $(evt.target);
                var filter = $(element).data("filterArray")
                //KRG: unused variable
                //var off = $(this).offset();
                $this.data('bs.popover').$arrow.css({ left: "80%" });

                //KRG: unused variable
                //var left = $this.data('bs.popover').$tip.offset();
                //var leftDec = left.left - 100;

                const getDataType = $this.parents("div.column-filter").find("a").data('type');
                var getDataSort = $this.parents("div.column-filter").find("a").data('sort');
                var getDataSortList = getDataSort.split(':');
                var colName = getDataSortList[0];
                setTimeout(function () {
                    if (filter.length > 0) {
                        for (let j = 0; j < filter.length; j++) {
                            if (colName === filter[j][0]) {
                                $("#condition-selector").val(filter[j][1]);
                                $("#first-value").val(filter[j][2]);
                                $("#second-value").val(filter[j][3]);
                            }
                        }
                    }
                }, 100);

                const options = $this.data('bs.popover').$tip.find('select.select3 option');
                for (let i = 0, iLen = options.length; i < iLen; i++) {
                    const typeValue = options[i].getAttribute('data-type');
                    if (typeValue !== undefined && typeValue !== "default") {
                        if (typeValue !== getDataType) {
                            if ((options[i].value === "Equals" || options[i].value === "Contains" && getDataType === "int") || (options[i].value === "Equals" && getDataType === "date")) { continue; }
                            $(options[i]).remove();
                        }
                    }
                }
                const iconElem = $this.offsetParent().offsetParent().find("a i.fa");
                const columnOptionsValue = $this.parents("div.column-filter").find("a").data("sort").split(":");
                columnOptionsValue.push(iconElem);

                $this.data("bs.popover").$tip.find('input').attr('data-column', columnOptionsValue[0]);
                $(".data-cancel").on("click", function (e) {
                    e.preventDefault();
                    $(evt.currentTarget).popover("hide");
                });

                $(".btn-data-apply")
                    .unbind('click')
                    .bind('click', handleFilterApplyClick($(".btn-data-apply"), columnOptionsValue, tableId));
                $(".data-clear-filters")
                    .unbind('click')
                    .bind('click', filterTemplate.initFiltersClearbutton($(".data-clear-filters"), tableId, getDataSortList));
                handleToggleConditionValue($("#condition-selector"));
                //SetFocus('#first-value');

            }).on("hidden.bs.popover", function () {
                //TODO: after hidden tip
                $('#first-value').unbind("keypress.key13");
                $('#second-value').unbind("keypress.key13");
            });
        };
        var handleFiltersClearButton = function ($selector, element, sortElem) {
            const sender = initGlobalObjectSender(element);
            const divContainer = $selector.parents("div.form-group");
            const prevDivMargin = $(divContainer.parents().children()[1]);
            sender.Filters.length > 0
                ? divContainer.show() && prevDivMargin.removeClass("no-margin")
                : divContainer.hide("fast") && prevDivMargin.addClass("no-margin");

            $selector.on("click", function (e) {
                e.preventDefault();
                const filterArray = [];
                var filter = $(element).data("filterArray");

                var btnIdentifier = $(e.currentTarget).data("filter");
                var type = "ClearAll";
                if (btnIdentifier === "clear") {
                    type = "btnClear";
                } else {
                    filter = filterArray;
                    $(element).data("sort", "");
                }
                for (let i = 0; i < filter.length; i++) {
                    if (filter[i][0] === sortElem[0]) {
                        filter.splice(i, 1);
                    }
                }
                $(element).data("filterArray", filter);

                setImmediate(
                    handleSubAjaxRequestFormMethod(element, type));
                $(e.currentTarget.offsetParent).popover("hide");
            });
        };
        return {
            initFilterTemplate: function (selector, element) {
                //$("body").on("click", function (e) {
                //$("[data-toggle=popover]").each(function () {
                //    if (!$(this).is(e.target) && $(this).has(e.target).length === 0 && $(".popover").has(e.target).length === 0) {
                //        $(this).popover("hide");
                //    }
                //});
                //});
                handleFilterTemplate(selector, element);
            },
            initFiltersClearbutton: function ($selector, element, sortElem) {
                handleFiltersClearButton($selector, element, sortElem);
            }
        };
    }();

    var pagingTemplate = function () {

        var template = `<div id="paging-container">
                    <div class="col-md-2 col-sm-3 col-xs-12">
