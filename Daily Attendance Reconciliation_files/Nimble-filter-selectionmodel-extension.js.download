                    </div>

                  </div>
                </div>`;

        var handleRenderTemplate = function (selector) {
            $(selector).html(template);
        };
        return {
            initTemplate: function (selector) {
                handleRenderTemplate(selector);
            }
        };
    }();

    var handleAjaxRequest = function (config, successCallback, errorCallback, completeCallback) {
        const defaults = {
            cache: false,
            async: false,
            beforesend: function (xhr) { },
            method: 'POST',
            dataType: "json",
            contentType: 'application/json; charset=utf-8',
            success: successCallback,
            error: errorCallback,
            complete: completeCallback
        };

        $.extend(defaults, config);

        return $.ajax(defaults);
    };

    var handlePopOverMove = function () {
        $('[data-toggle="popover"]').popover({
            sanitize: false,
        });
        //Commented: 2018.04.19 by krg: to test performance.
        //$('div').on('scroll', function (e) {
        //    $('.popover').each(function () {
        //        $(this).css('display', 'none');
        //    });
        //});
