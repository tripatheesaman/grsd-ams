    var handledKeys = ['ArrowLeft', 'ArrowRight', 'Tab'];

    var handleHotJsonDataRequestsPreparation = function (data, header, columnName, sortOrder, sortIcon, dataTypes, icon, isCheckBox, originalHeader, widthOfCol, isFrozen, settings, element, status, nimFrame) {
        const config = {
            dataSchema: function () {
                var schemaObj = {};
                if (!data.length > 0) {
                    for (var i = 0, len = header.length; i < len; i++) {
                        schemaObj[header[i]] = null;
                    }
                } else {
                    schemaObj = [];
                }
                return schemaObj;
            },
            data: data,
            fillHandle: false,
            autoColumnSize: false,
            rowHeaders: true,
            manualColumnFreeze: true,
            fixedColumnsLeft: isFrozen === undefined ? 0 : isFrozen,
            manualRowResize: false,
            // currentColClassName: 'currentCol',
            renderAllRows: true,
            manualColumnResize: true,
            disableVisualSelection: true,
            viewportRowRenderingOffset: 30,
            stretchH: header.length < 8 && isCheckBox ? "last" : "all",
            lastClickTime: 0,
            doubleClickThreshold: 300,
            lastClickIndex: 0,
            colWidths: function (cols) {
                if (cols < 0) return;
                if (typeof (handleDataSortingCol) !== "undefined") {
                    const $thatBtnSortingCol = $(".data-sorting-col", $mainContainer);
                    $thatBtnSortingCol.unbind("click").bind("click", handleDataSortingCol($thatBtnSortingCol, settings.element));
                }
                var width = 120;
                var wid;
                width = getValueFromArayOfObject(width, originalHeader, cols, settings);
                if (widthOfCol !== void 0) {
                    if (originalHeader[cols] === "SN") {
                        width = 50;
                    } else {
                        if (typeof widthOfCol !== "undefined") {
                            wid = parseInt(widthOfCol[cols], 10);
                        }
                    }
                    if (wid === 1) {
                        width = 0.1;
                    } else {
                        width = wid;
                    }
                }
                if (settings.excludeColumn !== undefined)
                    if (settings.excludeColumn.indexOf(originalHeader[cols]) > -1) {
                        width = .1;
                    }
                return width;
            },
            modifyColWidth: function (width, col) {

            },
            colHeaders: function (col) {
                var colTxt;//=header[col];
                var wid;
                if (settings.allowFilteringAndPaging === false) {
                    colTxt = getCustomHeaderName(col, header, originalHeader, settings);
                    if (isCheckBox) {
                        if (originalHeader[col] === "SN") {
                            var txt = "<input type='checkbox' class='htCenter checker no-margin select-all' data-check-for='child' id='select-all-rows' style='margin-left: 14px !important;' ";
                            if (settings.isEditAble === true)
                                txt += isCheckedAll(data) ? "checked='checked'" : "";

                            txt += ">";
                            colTxt = txt;
                        }
                    }
                    return colTxt;
                }
                if (settings.excludeColumn === undefined) {
                    settings.excludeColumn = "";
                }
                if (typeof widthOfCol !== "undefined") {
                    wid = parseInt(widthOfCol[col], 10);
                }

                if (originalHeader[col] === columnName && header[col] !== "SN" && settings.excludeColumn.indexOf(originalHeader[col]) === -1 && wid === 1) {
                    colTxt = '<div class="column-filter">';
                    colTxt += '<div class="grid-filter"><button class="data-filter popovers desc" title="Filter this column" data-toggle="popover" data-container="body"></button></div>';
                    colTxt += '<div class="grid-header-title">';
                    colTxt += `<a href='javascript:;'  class='sort-link sort-col data-sorting-col' data-sort='[${originalHeader[col]
                        }]:${sortOrder}:${sortIcon}' data-type='${dataTypes[col]}'>${getCustomHeaderName(col, header, originalHeader, settings)}<i class ='fa ${icon}'></i>`;
                    colTxt += '</div>';
                    colTxt += '</div>';
                } else {
                    if (header[col] === "SN" || settings.excludeColumn.indexOf(originalHeader[col]) > -1 || wid === 1) {
                        colTxt = getCustomHeaderName(col, header, originalHeader, settings);
                    } else {
                        colTxt = '<div class="column-filter">';
                        colTxt += '<div class="grid-filter" ><button class="data-filter popovers desc" title="Filter this column" data-toggle="popover" data-container="body"></button></div>';
                        //colTxt += '<button class="data-filter popovers" title="Filter this column"></button>';
                        colTxt += '<div class="grid-header-title">';
                        colTxt += `<a href='javascript:;'  class='sort-link sort-col data-sorting-col' data-sort='[${originalHeader[col]
                            }]:${sortOrder}:${sortIcon}' data-type='${dataTypes[col]}'>${getCustomHeaderName(col, header, originalHeader, settings)}`;
                        colTxt += '</div>';
                        colTxt += '</div>';
                    }
                }
                if (isCheckBox) {
                    if (originalHeader[col] === "SN") {
                        var txt = "<input type='checkbox' class='htCenter checker no-margin select-all' data-check-for='child' id='select-all-rows' style='margin-left: 14px !important;' ";

                        if (settings.isEditAble === true)
                            txt += isCheckedAll(data) ? "checked='checked'" : "";

                        txt += ">";
                        colTxt = txt;
                    }
                }
                return colTxt;
            },
            cells: function (row, col, prop) {
                var ele = this;
                const cellProperties = {};
                if (header[col] === "SN") {
                    if (isCheckBox) {
                        return {
                            renderer: function (instance, td, rows, cols, props, value, cellProperties) {
                                Handsontable.renderers.TextRenderer.apply(this, arguments);
                                //window.Handsontable.renderers.TextRenderer.apply(this, arguments);
                                //KRG: Avoid reading whole row and took only data of related cell.
                                var index = settings.onRowClick === undefined ? 1 : originalHeader.indexOf(settings.onRowClick);
                                var tsts = ele.instance.getDataAtCell(row, index);

                                //var checkData = ele.instance.getDataAtRow(row);
                                //var index = settings.onRowClick === undefined
                                //    ? 1
                                //    : header.indexOf(settings.onRowClick);
                                //var tsts = checkData[index];

                                var checkInput = '<input type="checkbox" id="selectSingle" class="htCenter htMiddle selectSingle htCheckboxRendererInput"';
                                checkInput += ` value="${tsts}" data-row="${row}" data-col="${col}" `;
                                var tst = $(ele.instance.rootElement).data("selectedValue");
                                if (tst !== void 0 && tst !== null) {
                                    if (tst.length > 0)
                                        nimFrame = tst;
                                }

                                var hello = instance.getCell(rows, cols);
                                var checkBox = hello.querySelectorAll('input[type=checkbox]');
                                var checked = -1;
                                if (tsts !== null && tsts !== undefined) {
                                    tsts = tsts.toString();
                                    checked = nimFrame.indexOf(tsts);
                                    if (checked > -1) {
                                        $(checkBox).attr("checked", "checked");
                                    }
                                }
                                if (settings.isEditAble) {
                                    checkInput += value === true ? 'checked=checked' : '';
                                } else
                                    checkInput += checked > -1 || value === true ? 'checked=checked' : '';
                                checkInput += ' />';

                                td.innerHTML = checkInput;
                                td.style.textAlign = 'center';
                            },
                            readOnly: settings.isEditAble ? false : true,
                            type: settings.isEditAble ? 'checkbox' : 'text'
                        };

                    } else {
                        cellProperties.editor = false;
                        cellProperties.readOnly = true;
                    }
                }
                else {
                    if (settings.cellsModifyAndRender !== undefined) {
                        settings.cellsModifyAndRender(row, col, prop, originalHeader, cellProperties, this, columnName);
                        if (typeof cellProperties.renderers !== "undefined") {
                            $.extend(cellProperties.renderer, cellProperties.renderers);
                        }
                    } else {
                        cellProperties.editor = false;
                        cellProperties.readOnly = true;
                    }

                    if (dataTypes[col] === "date") {
                        return {
                            renderer: function (instance, td, rows, cols, props, value, iCellProperties) {
                                if (cellProperties.readOnly === false) {
                                    //window.Handsontable.AutocompleteCell.renderer.apply(this, arguments);
                                    Handsontable.renderers.AutocompleteRenderer.apply(this, arguments);
                                } else {
                                    Handsontable.renderers.TextRenderer.apply(this, arguments);
                                }
                                var colH = dataTypes[col] === "date";
                                var dates = value;
                                if (td.innerText !== "") {
                                    if (typeof value !== "number")
                                        if (value !== undefined) {
                                            if (value !== null) {
                                                if (value.indexOf("T") > -1)
                                                    dates = value.split("T")[0];
                                            }
                                            td.innerText = dates;
                                        }
                                }
                                if (cellProperties.editor === "date") {
                                    if (colH) {
                                        iCellProperties.editor = "date";
                                        td.className += " datepicker";
                                    } else {
                                        iCellProperties.editor = "text";
                                        td.className += " myNepaliDate";
                                    }
                                }
                                if (cellProperties.readOnly === false) {
                                    td.style.background = '#c5e0b4';
                                }
                                if (typeof settings.dateRenderer !== "undefined")
                                    settings.dateRenderer(instance, td, rows, cols, props, value, iCellProperties);
                            },
                            type: cellProperties.editor === "date" ? "date" : "text",
                            readOnly: cellProperties.editor === "date" ? false : true,
                            correctFormat: true,
                            defaultDate: ''
                        };
                    }
                    else if (dataTypes[col] === "float" || dataTypes[col] === "decimal") {
                        var dta = ele.instance.getDataAtCell(row, col);
                        return {
                            renderer: function (instance, td, rows, cols, props, value, iCellProperties) {
                                //window.Handsontable.NumericCell.renderer.apply(this, arguments);
                                Handsontable.renderers.NumericRenderer.apply(this, arguments);
                                // window.Handsontable.renderers.TextRenderer.apply(this, arguments);

                                if (td.innerHTML !== "") {
                                    if (value !== null) {
                                        td.innerHTML = floorFigure(value);
                                    }
                                }
                                if (typeof settings === "undefined") {
                                    if (typeof settings.floatRenderer === "undefined") {
                                        settings.floatRenderer(instance, td, rows, cols, props, value, iCellProperties, originalHeader);
                                    }
                                }
                            },
                            readOnly: cellProperties.readOnly === true ? true : false,
                            type: "numeric",
                            allowInvalid: dta === '' ? true : false
                        };
                    }
                }

                if (cellProperties.editor === "select") {
                    cellProperties.renderer = customDropdownRenderer;
                }
                if (cellProperties.editor === "dropdown") {
                    cellProperties.type = "dropdown";

                }
                if (cellProperties.editor === "autocomplete") {
                    cellProperties.type = "autocomplete";
                }

                return cellProperties;

            },
            afterRender: function (row, col) {
                displayColumnSum(0, true);
                if (typeof (handleDataSortingCol) !== "undefined") {
                    const $thatBtnSortingCol = $(".data-sorting-col", element);
                    $thatBtnSortingCol.unbind("click").bind("click", handleDataSortingCol($thatBtnSortingCol, this.rootElement));
                }
                $('[data-toggle="popover"]', settings.mainContainer).each(function () { $(this).popover("destroy"); });
                $('[data-toggle="popover"]', element).each(function () { $(this).popover("destroy"); });
                var $thatBtnFilter = $("button.data-filter", element);

                filterTemplate.initFilterTemplate($thatBtnFilter, this.rootElement);
                handleUnbindAndBindPagingButton(this.rootElement);
                if (settings.afterRenderAll !== null && settings.afterRenderAll !== undefined) {
                    settings.afterRenderAll(row, col, this);
                }
            },
            afterRenderer: function (TD, row, col, prop, value, cellProperties) {
                if (header[col] === "SN") {
                    //var ele = this;
                    if (isCheckBox) {
                        //KRG: Avoid reading whole row and took only data of related cell.
                        var index = settings.onRowClick === undefined ? 1 : header.indexOf(settings.onRowClick);
                        var tsts = this.getDataAtCell(row, index);

                        //var checkData = ele.getDataAtRow(row);
                        //var index = settings.onRowClick === undefined
                        //    ? 1
                        //    : header.indexOf(settings.onRowClick);
                        //var tsts = checkData[index];

                        var hello = this.getCell(row, col);
                        var checkBox = hello.querySelectorAll('input[type=checkbox]');
                        if (tsts !== null && tsts !== undefined) {
                            tsts = tsts.toString();
                            var checked = nimFrame.indexOf(tsts);
                            if (checked > -1) {
                                $(checkBox).attr("checked", "checked");
                            }
                        }
                    }
                }
                //KRG: try to set background for editable cell
                if (cellProperties.readOnly === false) {
                    //debugger;
                    TD.style.background = '#c5e0b4';
                }

            },
            beforeOnCellMouseDown: function (event, coords, element) {
                event.stopImmediatePropagation();
            },
            afterOnCellMouseDown: function (event, coords, TD) {
                enableSelectionSum = true;
                if (event.target.type === "checkbox") {
                    //KRG
                    // handleCheckAll($(".select-all"), this.rootElement, this);
                    handleCheck($(".selectSingle"), this, settings, coords);
                }
                //KRG
                else if (event.target.type === 'radio') {
                    var r = coords.row;
                    var c = coords.col;

                    var dataAferOnCellMouseDown = this.getData();
                    for (let j = 0; j < dataAferOnCellMouseDown.length; j++) {
                        //if (dataAferOnCellMouseDown[j][c] === true && !event.target.checked) {
                        //this.setDataAtCell(j, c, false, "radio");                             
                        //}                        
                        dataAferOnCellMouseDown[j][c] = false;
                    }
                    dataAferOnCellMouseDown[r][c] = true;
                    hot.loadData(dataAferOnCellMouseDown);
                    //this.setDataAtCell(r, c, true, "radio");                   
                }
            },
            outsideClickDeselects: false,
            afterSelectionEnd: function (r, c, r2, c2) {
                if (settings.afterSelectionRow !== undefined) {
                    settings.afterSelectionRow(r, c, r2, c2, this);
                }
                var currentTime = new Date().getTime();
                if (currentTime - config.lastClickTime < config.doubleClickThreshold && c > 0 && c == config.lastClickIndex) {

                    if (c > 0) {  // exclude first checkbox column
                        if (firstAjaxTime < 3) {   ///only allow this feature if data fetch time is less than 3 sec.
                            if (gridSumAjaxID) gridSumAjaxID.abort();
                            let cellMeta = hot.getCellMeta(r, c);
                            //sum only when mouse selection event and numeric column
                            if (enableSelectionSum && (cellMeta.dataType == 'numeric' || cellMeta.type == 'numeric')) {
                                var sm = 0;
                                if (cellMeta.readOnly && c == c2 && r == r2) {
                                    //logic to fetch column sum value from backend and display.
                                    fetchAndDisplayColumnSum(header[c], hot);

                                }
                                else {
                                    // sum from selected cells
                                    let data = hot.getData(r, c, r2, c2);
                                    if (data.length > 0) {
                                        for (let i = 0; i < data[0].length; i++) {
                                            sm += data.reduce((pv, cv) => {
                                                return pv + (parseFloat(cv[i]) || 0);
                                            }, 0);
                                        }
                                    }
                                    displayColumnSum(sm);
                                }
                            }
                            else {
                                //remove displayed value
                                displayColumnSum(0, true)
                            }
                        }
                        else {
                            //remove displayed value
                            displayColumnSum(0, true)
                        }
                    }
                }
                config.lastClickTime = currentTime;
                config.lastClickIndex = c;

            },
            afterSelectionEndByProp: function (r, p, r2, p2) {
                if (settings.afterSelectionRowEndByProp !== undefined) {
                    settings.afterSelectionRowEndByProp(r, p, r2, p2, this, header);
                }
            },
            // preventOverflow: 'horizontal',
            afterChange: function (changes, source) {
                if (source !== "loadData") {
                    if (settings.afterChangeData !== undefined) {
                        settings.afterChangeData(changes, source, header, this);
                    }
                    if (settings.changeDataRow !== undefined) {
                        settings.changeDataRow(data, header, this, changes, source);
                    }
                }
            },
            beforeChange: function (datas, source) {
            },
            beforeRenderer: function (instance, td, row, col, prop, value, cellProperties) {
            },
            afterGetColHeader: function (col, TH) {
                var $thatBtnFilter = $("button.data-filter", settings.mainContainer);
                filterTemplate.initFilterTemplate($thatBtnFilter, this.rootElement);
                var widthCol = this.getColWidth(col);
                var colHHtmlElem = $(TH).find(".colHeader").find("div.grid-filter");
                if (widthCol < 28) {
                    colHHtmlElem.remove();
                    //KRG
                    // TH.style.display = 'none';
                }
                if (originalHeader[col] === "SN") {
                    //KRG: Added Check All here, removed from individual check.
                    if (isCheckBox) {
                        handleCheckAll($(".select-all"), this.rootElement, this);
                    }

                    if (settings.isEditAble === true)
                        if (isCheckedAll(this.getData()) === true) {
                            $(TH).find("input#select-all-rows").prop("checked", true);
                        } else
                            $(TH).find("input#select-all-rows").prop("checked", false);
                }
                var filterExp = $(this.rootElement).data("filterArray");

                var sortExp = $(this.rootElement).data("sort");
                var collss = columnName;
                var cols = originalHeader.indexOf(columnName);
                if (status === "btnSort") {
                    $($("TH", $(".ht_clone_top", $(this.rootElement)))[cols + 1]).find(".data-filter").addClass("fitter").css({ "background": "red" });
                    $($("TH", $(".ht_clone_corner", $(this.rootElement)))[cols + 1]).find(".data-filter").addClass("fitter").css({ "background": "red" });
                    $($("TH", $(".ht_clone_left", $(this.rootElement)))[cols + 1]).find(".data-filter").addClass("fitter").css({ "background": "red" });
                    $($("TH", $(".ht_master", $(this.rootElement)))[cols + 1]).find(".data-filter").addClass("fitter").css({ "background": "red" });
                }
                if (filterExp.length > 0) {
                    for (var i = 0; i < filterExp.length; i++) {
                        collss = filterExp[i][0];
                        var colIndex = originalHeader.indexOf(collss);
                        //if (status === "btnSort" || status === "filter") {
                        $($("TH", $(".ht_clone_top", $(this.rootElement)))[colIndex + 1]).find(".data-filter").css({ "background": "blue" });
                        $($("TH", $(".ht_clone_corner", $(this.rootElement)))[colIndex + 1]).find(".data-filter").css({ "background": "blue" });
                        $($("TH", $(".ht_clone_left", $(this.rootElement)))[colIndex + 1]).find(".data-filter").css({ "background": "blue" });
                        $($("TH", $(".ht_master", $(this.rootElement)))[colIndex + 1]).find(".data-filter").css({ "background": "blue" });

                        //}
                    }
                }
                if (sortExp !== undefined && sortExp.length > 0) {
                    var sortCol = sortExp[0];
                    var sortIndex = originalHeader.indexOf(sortCol);
                    $($("TH", $(".ht_clone_top", $(this.rootElement)))[sortIndex + 1]).find(".data-filter").addClass("fitter").css({ "background": "red", "content": '&#x25B2;' });
                    $($("TH", $(".ht_clone_corner", $(this.rootElement)))[sortIndex + 1]).find(".data-filter").addClass("fitter").css({ "background": "red", "content": '&#x25B2;' });
                    $($("TH", $(".ht_clone_left", $(this.rootElement)))[sortIndex + 1]).find(".data-filter").addClass("fitter").css({ "background": "red", "content": '&#x25B2;' });
                    $($("TH", $(".ht_master", $(this.rootElement)))[sortIndex + 1]).find(".data-filter").addClass("fitter").css({ "background": "red", "content": '&#x25B2;' });
                }
            },
            afterCreateRow: function (index, amount) {
                if (settings.afterRowCreate !== void 0) {
                    settings.afterRowCreate(index, amount, data, originalHeader, this);
                }
            },

            //KRG: Try to avoid row enter in hidden cells with left right arrow.
            //REf:Remove hidden columns: http://jsfiddle.net/LkLkd405/4/
            //Ref: https://forum.handsontable.com/t/use-keys-to-skip-empty-cells/3544/2
            beforeKeyDown: function (event) {
                if ((this.getSelected() && handledKeys.includes(event['key'])) ||
                    (this.getSelected() && event['ctrlKey'] && event['key'] === "Delete")) {
                    event.isImmediatePropagationEnabled = false;
                    event.isImmediatePropagationStopped = function () {
                        return !this.isImmediatePropagationEnabled;
                    };
                    event.stopImmediatePropagation();         // prevent EditorManager from processing this event
                    event.preventDefault();                   // prevent browser from scrolling the page up
                }
            },
            afterDocumentKeyDown: function (event) {
                enableSelectionSum = false;
                if (this.getSelected() && !event['shiftKey'] && handledKeys.includes(event['key'])) { //Handle not selection of hidden columns on arrow and tab
                    let row = this.getSelected()[0];
                    let column = this.getSelected()[1];
                    let curCol = column;
                    const totalCols = this.countCols();
                    const right = (event['key'] === 'ArrowRight');
                    const left = (event['key'] === 'ArrowLeft');
                    const tab = (event['key'] === 'Tab');
                    if (right || left || tab) {
                        const incr = (right || tab) ? 1 : -1;
                        var i = 0;
                        do {
                            if (i > 100) break;
                            i++;
                            column = mod(column + incr, totalCols);
                        } while (emptyOrNoWidth(row, column, this));
                        /*If cell is next to last selectable column of currnet row increase or decrease row.*/
                        //if (column < curCol && (right || tab) && row < this.countRows())
                        //    row++;
                        //else if (column > curCol && left && row >= 0)
                        //    row--;

                        /*If cell is next to last selectable column of currnet row stop nevigation.*/
                        if (column < curCol && (right || tab) && row < this.countRows())
                            return;
                        else if (column > curCol && left && row >= 0)
                            return;

                        this.selectCell(row, column);
                    }
                }
                else if (this.getSelected() && event['ctrlKey'] && event['key'] === "Delete") { //delete row on ctrl + delete
                    if (this.getSelected()[3] + 1 == this.countCols() && this.getSelected()[1] == 0)  //checks if a complete row is selected while deleting
                    {
                        var r = this.getSelected()[0];
                        var sr = this.isEmptyRow(r);
                        if (sr == true && r === 0) { }
                        else {
                            this.alter('remove_row', r, 1);
                        }
                    }
                }

            },
            currentRowClassName: 'currentRow'
            //currentColClassName: 'currentCol'
        };


        if (settings.enableSortingAndFiltering == false)
            delete config.afterGetColHeader;
        delete config.afterCreateRow;
        //console.timeEnd("answer time");
        return config;
    };

    function fetchAndDisplayColumnSum(colName, elem) {
        displayColumnSum(0, false, true);
        var element = elem.rootElement;
        var settings = $(element).data("options");
        $mainContainer = settings.mainContainer;
        $handsonTable = element;
        $rootUrl = settings.url;
        if (settings.paramsData !== undefined) {
            $.extend($.fn.selectionAppModel.configGetData.paramsData, settings.paramsData);
        }
        const objParam = {
            currentPage: 1,
            sortOrder: "",
            orderColumn: "",
            itemsPerPage: -1, //$("select.items-per-page.select3 :selected", settings.mainContainer).val(),
            filterExpression: $(element).data("filterArray"),
            postData: postData,
            hrmPostData: postData
        };
        $.extend(objParam, settings.paramsData);

        const config = {
            url: $rootUrl,
            data: JSON.stringify(objParam)
        };
        let sm = 0;
        setTimeout(function () {
            var timeStarts = new Date().getTime();
            gridSumAjaxID = handleAjaxRequest(config,
                function (results) {
                    const objArr = results;
                    if (objArr.StatusType === "error") {
                        // data fetch error.
                        displayColumnSum(0, true)
                    } else {
                        let dataAll = results.Object.shift();
                        let hdr = dataAll.shift();
                        let colIDx = hdr.indexOf(colName);
                        sm = dataAll.reduce((pv, cv) => {
                            return pv + (parseFloat(cv[colIDx]) || 0);
                        }, 0);
                        displayColumnSum(sm);
                        firstAjaxTime = (new Date().getTime() - timeStarts) / 1000;
                    }
                })
        })
    }

    function displayColumnSum(value, isRemoveElementOnly, isLoadingOnly) {
        var ele = $('nav.navbar.navbar-default .container-fluid #l-grid-sum');
        if (isLoadingOnly) {
            if (ele.length == 0) {
                $('nav.navbar.navbar-default .container-fluid').append(`<div class='pull-right' id='l-grid-sum'></div>`);
                ele = $('nav.navbar.navbar-default .container-fluid #l-grid-sum');
            }
            spinnerOn(ele, '1x');
            return;
        }

        if (isRemoveElementOnly) {
            spinnerOff(ele);
            ele.remove();
            return;
        }
        if (ele.length > 0) {
            if (gridSumTimeoutId) clearTimeout(gridSumTimeoutId); //clear previous set timeout
            spinnerOff(ele);
            ele.text(`Sum:${handleFormatNumber(value)}`);
        }
        else {
            $('nav.navbar.navbar-default .container-fluid').append(`<div class='pull-right' id='l-grid-sum'>Sum:${parseFloat(value).toFixed(2)}</div>`);
        }
        gridSumTimeoutId = setTimeout(function () {
            $('nav.navbar.navbar-default .container-fluid #l-grid-sum').remove();
        }, 10000);
    }

    function emptyOrNoWidth(row, col, instance) {
        return instance.getColWidth(col) < 5; // || !instance.getDataAtCell(row, col);
    }

    function mod(n, m) {
        return ((n % m) + m) % m;
    }

    var control;
    //Method For Gridmanager
    var handleGridManagerFromPage = function () {
        $(document).on('mousedown', ".radio", function (event) {
            event.stopPropagation(); //otherwise can confuse cell mousedown handler
        });
        $(document).on('mouseup', ".radio", function (event) {
            event.stopPropagation(); //otherwise can confuse cell dblclick handler
        });

        var handleAddButtonClickOfSelection = function ($sender, config, $elem) {
            $sender.off("click").on("click", function (e) {
                //var controlNameSs = $($elem).data("controlName");
                e.preventDefault();
                var data = $("#hands-on-table-selection").data("nimble");
                var hotInst = data.getInstance();
                var countSourceRows = hotInst.countRows();
                var options = $("#hands-on-table-selection").data("options");
                handleBlockUiForTable(options.mainContainer);
                var colData = hotInst.getData();
                var allData = data.getDataWithHeader();
                for (var i = 0; i < countSourceRows; i++) {
                    var rowData = colData[i][2];
                    if (rowData === config.orderByCol) {
                        if (colData[i][0]) {
                        } else {
                            var test = [true, config.controlName, config.orderByCol, config.orderByCol, null, 100, false, null];
                            allData.push(test);
                        }
                    }
                }
                var $form = $("#common-gridmanager-form");

                setTimeout(function () {
                    const postData = JSON.stringify({
                        Filter: allData
                    });

                    $.post($form.attr("action"), { postData }, function (data, status) {
                        if (status === "success") {
                            var clientMessage = { title: data.Title, type: data.StatusType, content: data.Message };
                            if (clientMessage.type === "success") {
                                handleSubAjaxRequestFormMethod($($elem));
                                window.UIExtendedModals.hide();
                            }

                            window.UIToastr.init(clientMessage);
                            $('.btnSave').button('reset');
                            $(options.mainContainer).unblock();
                        }
                    });
                }, 300);
                $sender.unbind().bind("click", handleAddButtonClickOfSelection($sender, config, $elem));
                return false;
            });
        };
        var handleGridManagerBsModal = function (selector, formName, config, $elem) {
            var $form = $("#" + formName);
            $form.on("submit", function (e) {
                e.preventDefault();
                $('body').modalmanager('loading');
                var dataWidth = $(selector).attr("data-width");
                const dataUrl = selector.attr("data-url");

                var action = selector.attr("data-action");
                var width = dataWidth === null && dataWidth === undefined ? '60%' : dataWidth;
                window.UIExtendedModals.init({
                    width: width,
                    content: dataUrl,
                    contentPlaceHolder: $("#modal-popup"),
                    modal$elem: $("#modal-popup"),
                    fillContent: true,
                    usingAjax: true,
                    data: $form.serialize(),
                    afterPopupOpen: function () {
                        window.handelPickerAfterBsModalPopUpOpen();
                        setTimeout(function () {
