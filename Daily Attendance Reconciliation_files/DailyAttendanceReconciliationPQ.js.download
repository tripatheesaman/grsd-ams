    var handleNewWidowPopup = function ($sender) {
        $sender.on("click", function (e) {
            var id = $sender.attr("id");
            if (!$(gridElement).hasClass('pq-grid')) {
                showClientMsg("Please load grid first.", "warning");
                return;
            }
            upDateLeaveMenuUrls();
            if (["leave", "officialleave", "penaltyleave"].indexOf(id) > -1) {
                const params = new Proxy(new URLSearchParams($sender.attr("data-link")), {
                    get: (searchParams, prop) => searchParams.get(prop),
                });
                let eCode = params.SelectedEmpCode; // "some_value"
                if (!eCode) {
                    showClientMsg("Please select one record to proceed.", "warning", "Attendance Reconciliation");
                    return false;
                }
            }
            var URL = $(this).attr("data-link");
            var padding = 50;
            var screenHeight = screen.height - padding;
            var screenWidth = screen.width - padding;
            var strWindowFeatures = "location=yes,height=" + screenHeight + ",width=" + screenWidth + ",scrollbars=yes,status=yes,top=" + padding / 2 + ",left=" + padding / 2 + "";
            var win = window.open(URL, "_blank", strWindowFeatures);

            var timer = setInterval(function () {
                if (win.closed) {
                    if ($(gridElement).hasClass('pq-grid')) $(gridElement).pqGrid('refreshDataAndView');
                    clearInterval(timer);
                }
            }, 10);
        });
    }

    var handleReloadTableBtnClick = function ($sender) {
        $sender.on("click", function (e) {
            handleReloadTable();
        });
    }

    var handleReloadTable = function () {
        try {
            if ($(gridElement).hasClass('pq-grid')) $(gridElement).pqGrid('refreshDataAndView')
        } catch (e) {
            setTimeout(function () {
                window.location.reload();
            });
        }
    }

    var handleFinalizeUnfinalizeAttendance = function ($sender) {
        $sender.unbind('click').on("click", function (e) {
            var id = $(this).attr("id");
            var dataActionType = $(this).attr('data-action');
            var type = (dataActionType == 'finalizeAttendance' || dataActionType == 'finalizeOvertime') ? 'finalize' : 'unfinalize';

            if (!$(gridElement).hasClass('pq-grid')) {
                showClientMsg("Please load grid first.", "warning");
                return;
            }
            e.preventDefault();
            var gridData = handleGridTransformation(gridElement);
            var jaggedArray = gridData.jagged;
            var dataList = jaggedArray.slice(1);
            var count = dataList.length;


            if (count <= 0) {
                window.handleActionButtonsClick();
                return false;
            }
            var isFinalize = type == 'finalize' ? true : false;
            var finalizeType = (dataActionType == 'unFinalizeOvertime' || dataActionType == 'finalizeOvertime') ? 'Overtime' : 'Attendance';
            $.confirm({
                columnClass: 'col-md-6 col-md-offset-3',
                title: `Are you sure you want to ${isFinalize ? 'Finalize' : 'Unfinalize'} selected records?`,
                content: '' +
                    '<form action="" class="formName">' +
                    '<div class="form-group">' +
                    '<label>Remarks</label>' +
                    '<textarea class="finalizeRemarks form-control" id="finalizeRemarks" name="finalizeRemarks" rows="2" required></textarea></br>' +
                    //'<p><b>Note:</b> Absent employee overtime will automatically be finalized when attendance is finalized.</p>' +
                    '</div>' +
                    '</form>',
                buttons: {
                    formSubmit: {
                        text: (isFinalize ? 'Finalize' : 'Unfinalize') + ' ' + finalizeType,
                        btnClass: 'btn-blue',
                        action: function () {
                            var remarks = this.$content.find('.finalizeRemarks').val();
                            spinnerOn($('body'));
                            $.ajax({
                                method: "POST",
                                url: "/Attendance/DailyAttendanceReconciliation/FinalizeUnfinalize",
                                data: { records: gridData.rowClickItems, isFinalize, remarks, finalizeType },
                                success: function () { },
                                complete: function (result) {
                                    spinnerOff($('body'));
                                    const objArr = JSON.parse(result.responseText);

                                    var isConfirmationRequired = objArr.Object.isConfirmationRequired ? true : false;
                                    var empCodes = objArr.Object.empCodes;

                                    if (isConfirmationRequired) {
                                        $.confirm({
                                            columnClass: 'col-md-6 col-md-offset-3',
                                            title: 'Finalize with the Exception Records',
                                            content: `<div>${empCodes}</div>`,//<div> Some employees are either absent & overtime, or have substitutes </div>
                                            buttons: {
                                                continueWithValidRecords: {
                                                    text: 'Finalize Valid Records',//Continue without Exceptions
                                                    btnClass: 'btn-warning finalizePopUpBtn',
                                                    action: function () {
                                                        spinnerOn($('body'));
                                                        $.ajax({
                                                            method: "POST",
                                                            url: "/Attendance/DailyAttendanceReconciliation/FinalizeUnfinalize",
                                                            data: { records: gridData.rowClickItems, isFinalize, remarks, finalizeType, isConfirm: true, isSkipAndProcessValidRecords: true },
                                                            success: function () { },
                                                            complete: function (result) {
                                                                spinnerOff($('body'));
                                                                const objArr = JSON.parse(result.responseText);

                                                                var clientMessage = { title: "Finalize/Unfinalize Attendance", type: objArr.StatusType, content: objArr.Message };

                                                                window.UIToastr.init(clientMessage);

                                                                if ($(gridElement).hasClass('pq-grid')) $(gridElement).pqGrid('refreshDataAndView')

                                                            },
                                                            error: function (results) {
                                                                spinnerOff($('body'));
                                                            }
                                                        });
                                                    }
                                                },
                                                confirm: {
                                                    text: 'Finalize All Records',//Confirm
                                                    btnClass: 'btn-info',
                                                    action: function () {
                                                        spinnerOn($('body'));
                                                        $.ajax({
                                                            method: "POST",
                                                            url: "/Attendance/DailyAttendanceReconciliation/FinalizeUnfinalize",
                                                            data: { records: gridData.rowClickItems, isFinalize, finalizeType, remarks, isConfirm: true },
                                                            success: function () { },
                                                            complete: function (result) {
                                                                spinnerOff($('body'));
                                                                const objArr = JSON.parse(result.responseText);


                                                                var clientMessage = { title: "Finalize/Unfinalize Attendance", type: objArr.StatusType, content: objArr.Message };

                                                                window.UIToastr.init(clientMessage);
                                                                if ($(gridElement).hasClass('pq-grid')) $(gridElement).pqGrid('refreshDataAndView')

                                                            },
                                                            error: function (results) {
                                                                spinnerOff($('body'));
                                                                console.log(results.responseText);
                                                            }
                                                        });
                                                    }
                                                },
                                                cancel: {
                                                    text: 'Cancel',
                                                    action: function () {
                                                        // User canceled, do something else if needed
                                                    }
                                                }
                                            }
                                        });
                                    } else {

                                        var clientMessage = { title: "Calculate", type: objArr.StatusType, content: objArr.Message };

                                        window.UIToastr.init(clientMessage);
                                        if ($(gridElement).hasClass('pq-grid')) $(gridElement).pqGrid('refreshDataAndView')
                                    }

                                },
                                error: function (results) {
                                    spinnerOff($('body'));
                                    console.log(results.responseText);
                                }
                            });
                        }
                    },
                    cancel: function () {
                        // close
                    },
                },
                onContentReady: function () {
                    // bind to events
                    var jc = this;
                    this.$content.find('form').on('submit', function (e) {
                        // prevent the default form submission
                        e.preventDefault();
                        jc.$$formSubmit.trigger('click'); // reference the button and click it
                    });
                }
            });


            //$.confirm({
            //    title: 'Confirm!',
            //    content: "Do you want to proceed? Click 'Yes' to modify record else 'No'.",
            //    buttons: {
            //        Yes: {
            //            text: 'Yes',
            //            btnClass: 'btn-nimble',
            //            keys: ['enter'],
            //            action: function () {

            //            }
            //        },
            //        No: {
            //            text: 'No',
            //            btnClass: 'btn-nim-sec',
            //            action: function () {

            //            }
            //        },
            //    }
            //});

        })
    }


    var handleEmpAutocompleteFromGrid = function () {
        $(document).on('click', `${gridElement} #btnSetEmployee`, function () {
            var rowCheckIndex = $(gridElement).pqGrid('option', 'onRowClick')
            var gridData = handleGridTransformation(gridElement);
            if (gridData.rowClickItems.length == 1) {
                var selectedData = $.grep($(gridElement).pqGrid('getData'), function (i, v) {
                    return i[rowCheckIndex] == gridData.rowClickItems;
                });
                if (selectedData[0]['EmpCode'] != undefined) {


                    var data = $.grep(finalizeToolbarObject.autocompleteObject, function (i, v) {
                        return i['EmpCode'] == selectedData[0]['EmpCode'];
                    })[0];


                    $(document).find(`#${finalizeToolbarObject.autocompleteObjectIdSelector}`).tokenInput('clear')
                    $(document).find(`#${finalizeToolbarObject.autocompleteObjectIdSelector}`).tokenInput("add", {
                        EmpCode: data.EmpCode,
                        Name: data.EmpName,
                        EmpNameCode: data.EmpNameCode,
                        IsButtonTriggered: true
                    });
                    finalizeToolbarObject.gridEmpCode = data.EmpCode;
                    refreshPayloadAndPqGrid();

                }
            }
        });
    }
    var handleDatabyTabType = function ($sender) {
        $($sender).on("click", function (e) {
            $('#AttendanceStatus').val('-1').change();
            e.preventDefault();
            $('#GlobalFilterDiv').hide();
            const $this = $(e.target);
            const tabType = $this.attr("data-text");
            var menuElement = $("#menutype");
            switch (tabType) {
                case "DOR":
                    $('.titleSpan').text('Daily Overtime Reconciliation')
                    history.pushState(null, null, "/Attendance/DailyAttendanceReconciliation/Index?menutype=overtime&tab=DOR");
                    menuElement.val('overtime')
                    break;
                case "DFR":
                    $('.titleSpan').text('Finalized Attendance')
                    history.pushState(null, null, "/Attendance/DailyAttendanceReconciliation/Index?menutype=finalized&tab=DFR");
                    menuElement.val('finalized')
                    break;
                case "DOFR":
                    $('.titleSpan').text('Finalized Overtime')
                    history.pushState(null, null, "/Attendance/DailyAttendanceReconciliation/Index?menutype=finalizedOvertime&tab=DOFR");
                    menuElement.val('finalizedOvertime')
                    break;
                case "ALL":
                    $('.titleSpan').text('All Data')
                    history.pushState(null, null, "/Attendance/DailyAttendanceReconciliation/Index?menutype=alldata&tab=ALL");
                    menuElement.val('alldata')
                    break;
                case "DAR":
                    $('.titleSpan').text('Daily Attendance Reconciliation')
                    history.pushState(null, null, "/Attendance/DailyAttendanceReconciliation/Index?menutype=attendance&tab=DAR");
                    menuElement.val('attendance')
                    break;
                default:
                    return;
                    break;
            }
            finalizeToolbarObject.gridEmpCode = '';
            finalizeToolbarObject.currentIndex = 0;

            $("#btnSearch").click()
            return;
        });
    }


    return {

        initPageLoad: function () {
            //processFinalizedToolbar(true);
            handlePageLoad();
        },
        inithandleDatabyTabType: function ($sender) {
            handleDatabyTabType($sender);
        },

        initafterPopupOpen(action) {
            afterPopupOpen(action);
        },
        inithandleSearchBtnClick: function ($sender) {
            handleSearchBtnClick($sender)
        },
        inithandleMainGridClick: function () {
            handleMainGridClick();
        },
        initAttendanceCalculate: function (sender, isDate) {
            handleNewRequestBtnClickEvent(sender, isDate)
        },
        initClearShift: function (sender, type) {
            handleClearShift(sender, type);

        },
        inithandleOvertimeAllowance: function (sender) {
            handleOvertimeAllowance(sender)
        },
        inithandleOvertime: function (sender) {
            handleOvertime(sender)
        },
        inithandleForceAttendance: function (sender) {
            handleFroceAttendance(sender);
        },
        inithandleShowPunch: function (sender) {
            handleShowPunch(sender)
        },

        initDeleteOvertime: function (sender, type) {
            handleDeleteOvertime(sender, type);

        },
        initBulkAttendance: function (sender) {
            handleBulkAttendance(sender);
        },
        initRemarks: function (sender) {
            handleRemarks(sender);
        },
        inithandleNewWidowPopup: function (sender) {
            handleNewWidowPopup(sender);
        },
        inithandleReloadTableData: function () {
            handleReloadTable();
        },
        inithandleOTCalcBulk: function ($sender) {
            handleOTCalcBulk($sender);
        },
        inithandleAttendanceCalcBulk: function ($sender) {
            handleAttendanceCalcBulk($sender);
        },
        inithandleOTAllowanceBulk: function ($sender) {
            handleOTAllowanceBulk($sender);
        },
        inithandleFinalizeUnfinalizeAttendance: function (sender) {
            handleFinalizeUnfinalizeAttendance(sender)
        },
        initAjxViewAttendanceDetails(empCode, attdDate) {
            AjxViewAttendanceDetails(empCode, attdDate);
        },
        initHandleEmpAutocompleteFromGrid: function () {
            handleEmpAutocompleteFromGrid();
        }
    }
}();


$(function () {
    $("#id").data("instance", DailyAttendanceModule);
    // $("#leave").attr("target", "_blank");
    DailyAttendanceModule.initPageLoad();
    DailyAttendanceModule.inithandleSearchBtnClick($("#btnSearch"));
    DailyAttendanceModule.inithandleMainGridClick();
    DailyAttendanceModule.initAttendanceCalculate($("#attcalc"), 0);
    DailyAttendanceModule.initAttendanceCalculate($("#attcalc1"), 0);
    DailyAttendanceModule.initAttendanceCalculate($("#addSubs"), 1);
    DailyAttendanceModule.initAttendanceCalculate($("#removeSubs"), 1);
    setTimeout(function () {
        DailyAttendanceModule.initClearShift($("#clearShifts"), "shiftClear")
        DailyAttendanceModule.initClearShift($("#clearForceAttendance"), 'clearforceAttendance')

    }, 500)

    DailyAttendanceModule.inithandleOvertimeAllowance($("#addOTAllowance"));
    DailyAttendanceModule.inithandleOvertime($("#addOverTime"));
    DailyAttendanceModule.inithandleOvertime($(document).find("#saveOT,.lnkSaveOTPQ"));
    DailyAttendanceModule.inithandleOTCalcBulk($("#OTCalcBulk"));
    DailyAttendanceModule.inithandleOTAllowanceBulk($("#OTAllowanceBulk"));
    DailyAttendanceModule.inithandleForceAttendance($("#forceAttendance"));
    DailyAttendanceModule.inithandleShowPunch($("#punchRecord,#punchRecord1,#punchRecord2"));
    DailyAttendanceModule.initBulkAttendance($("#bulkAttendance"));
    DailyAttendanceModule.initRemarks($("#remarks"));
    DailyAttendanceModule.inithandleNewWidowPopup($("#leave,#officialleave,#penaltyleave,#assignShift"));
    DailyAttendanceModule.inithandleDatabyTabType($("#tabMenuItems li:not(._skipped-menu)"));
    DailyAttendanceModule.initHandleEmpAutocompleteFromGrid();
    setTimeout(function () {
        DailyAttendanceModule.initDeleteOvertime($("#deleteOvertime"), 'deleteOvertimes')
        DailyAttendanceModule.initDeleteOvertime($("#deleteOtAllowance"), 'deleteOtAllowances')

    }, 500)

    DailyAttendanceModule.inithandleAttendanceCalcBulk($("#AttendanceCalculationBulk"));

    DailyAttendanceModule.inithandleFinalizeUnfinalizeAttendance($(document).find(".finalizeAttendance"));



})