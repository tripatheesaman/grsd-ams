var uniqueValues = [];
var DailyAttendanceModule = function () {
    var globalData = {};
    var finalizeToolbarObject = {
        autocompleteObject: [],
        autocompleteObjectIdSelector: "employeeAutoCompleteRecon",
        prevButtonIdSelector: 'btnPrevEmpCodeRecon',
        nextButtonIdSelector: 'btnNextEmpCodeRecon',
        empcodeInputIdSelector: 'empcodeDisplayRecon',
        currentIndex: 0,
        gridEmpCode: ""
    };

    var navigateEmployeelist = function (isPrev) {
        var isTokenInitialized = false;
        var currentItem = {};
        if ($(`#token-input-${finalizeToolbarObject.autocompleteObjectIdSelector}`).length > 0) isTokenInitialized = true;

        if (finalizeToolbarObject.currentIndex === 0 && isPrev) {
            var firstItem = finalizeToolbarObject.autocompleteObject[0];
            if (firstItem) {
                $(`#${finalizeToolbarObject.empcodeInputIdSelector}`).val(firstItem.EmpCode);
                currentItem = firstItem;
            }
        } else if (finalizeToolbarObject.currentIndex !== undefined) {
            var newIndex = isPrev ? finalizeToolbarObject.currentIndex - 1 : finalizeToolbarObject.currentIndex + 1;

            if (newIndex >= 0 && newIndex < finalizeToolbarObject.autocompleteObject.length) {
                finalizeToolbarObject.currentIndex = newIndex;

                var selectedItem = finalizeToolbarObject.autocompleteObject[newIndex];
                currentItem = selectedItem;
                $(`#${finalizeToolbarObject.empcodeInputIdSelector}`).val(selectedItem.EmpCode);
            }
        }

        if (isTokenInitialized) {
            $(document).find(`#${finalizeToolbarObject.autocompleteObjectIdSelector}`).tokenInput('clear')
            $(document).find(`#${finalizeToolbarObject.autocompleteObjectIdSelector}`).tokenInput("add", {
                EmpCode: currentItem.EmpCode,
                Name: currentItem.EmpNameCode,
                EmpNameCode: currentItem.EmpNameCode,
                IsButtonTriggered: true
            });
            finalizeToolbarObject.gridEmpCode = currentItem.EmpCode;
            refreshPayloadAndPqGrid();
        }
    }

    var refreshPayloadAndPqGrid = function () {
        if ($(gridElement).hasClass('pq-grid')) {
            $(gridElement).pqGrid("option", "dataModel.postData", function (ui) {
                return getPayload(globalData).payload;
            });
            $(gridElement).pqGrid('refreshDataAndView')
        }
    }
    var preserveFilterData = function () {
        var frm = $(document.forms);
        var data = frm.serializeFormJSON();
        var hrmData = {};
        $.each(data, function (index, value) {
            if ($.isArray(value)) {
                hrmData[index] = value.toString().replace("-1,", "").replace("-1", "");
            } else {
                hrmData[index] = value.replace("-1,", "").replace("-1", "");
            }
        });
        $.extend(data, hrmData);
        globalData = data;
    }
    var gridElement = '#pq-grid-table';

    var prepareEmployeeAutocomplete = function () {
        if ($(`#token-input-${finalizeToolbarObject.autocompleteObjectIdSelector}`).length <= 0) {
            $(document).find(`#${finalizeToolbarObject.autocompleteObjectIdSelector}`).tokenInput(finalizeToolbarObject.autocompleteObject, {
                tokenLimit: 1,
                theme: "facebook",
                preventDuplicates: true,
                minChars: 3,
                propertyToSearch: 'EmpNameCode',
                onAdd: function (item) {

                    $(`#${finalizeToolbarObject.empcodeInputIdSelector}`).val(item.EmpCode);

                    if (item.IsButtonTriggered == false)
                        finalizeToolbarObject.currentIndex = $.inArray(item, finalizeToolbarObject.autocompleteObject);
                    else if (item.IsButtonTriggered == undefined) {
                        finalizeToolbarObject.gridEmpCode = item.EmpCode;
                        refreshPayloadAndPqGrid();
                    }
                    return false;
                },
                onDelete: function (item) {
                    $(`#${finalizeToolbarObject.empcodeInputIdSelector}`).val('');
                    finalizeToolbarObject.gridEmpCode = "";
                    refreshPayloadAndPqGrid();
                }
            });

            $(document).find(`#token-input-${finalizeToolbarObject.autocompleteObjectIdSelector}`).css('border-width', '0')
            $(document).find(`#${finalizeToolbarObject.prevButtonIdSelector}`).unbind('click').on('click', function () {
                navigateEmployeelist(true);
            });

            $(document).find(`#${finalizeToolbarObject.nextButtonIdSelector}`).unbind('click').on('click', function () {
                navigateEmployeelist(false);
            });
        }

    }
    var processFinalizedToolbar = function (isInit = false) {
        if (isInit) {
            spinnerOn($('body'));
            $.ajax({
                method: "POST",
                url: "/Attendance/DailyAttendanceReconciliation/LoadEmployeeData",
                data: JSON.stringify({ postData: handlePreserveFilterData() }),
                dataType: "json",
                contentType: 'application/json; charset=utf-8',
                success: function (result) {
                },
                complete: function (result) {
                    spinnerOff($('body'));
                    finalizeToolbarObject.autocompleteObject = result.responseJSON;
                    prepareEmployeeAutocomplete();

                },
                error: function () {
                    spinnerOff($('body'));
                }
            });


        } else {
            prepareEmployeeAutocomplete();
        }



    }


    var getPayload = function (paramData) {
        var url = "/attendance/DailyAttendanceReconciliation/LoadGridPQ";
        return {
            url: url,
            payload: {
                postData: paramData,
                menutype: $("#menutype").val(),
                gridEmpCode: finalizeToolbarObject.gridEmpCode
            }
        };
    }
    var conditions = {
        'Status': {
            'Travel': 'travel',
            'Suspended': 'ot-suspended',
            'WeeklyOff': 'ot-weekOff',
            'Pending(L)': 'ot-pending-l',
            'Pending Absent': 'ot-pending-absent',
            'Absent': 'ot-absent',
            'Present Holiday': 'ot-present-holiday',
            'Present Pending': 'ot-present-pending',
            'Present': 'ot-present',
            'Holiday': 'holiday',
            'Leave Pending': 'ot-leave-pending',
            'Partial Leave': 'ot-leave-partial',
            'Leave': 'ot-leave',
            'Pending': 'ot-pending',
            'FieldWork': 'ot-fieldwork',
            'MissedPunch': 'ot-missedpunch',
            'ShiftNotBegin': 'ot-shiftnotbegin',
            'Present/Partial Leave': 'ot-halfpresent'
        },
        'MonthStatus': {
            'Travel': 'travel',
            'Suspended': 'ot-suspended',
            'WeeklyOff': 'ot-weekOff',
            'Pending Absent': 'ot-pending-absent',
            'Pending Leave': 'ot-leave',
            'Absent': 'ot-absent',
            'Present Holiday': 'ot-present-holiday',
            'Present Pending': 'ot-present-pending',
            'Present': 'ot-present',
            'Holiday': 'holiday',
            'Leave Pending': 'ot-leave-pending',
            'Partial Leave': 'ot-leave-partial',
            'Leave': 'ot-leave',
            'Pending': 'ot-pending',
            'FieldWork': 'ot-fieldwork',
            'MissedPunch': 'ot-missedpunch',
            'SUB': 'ot-havesubstitute',
            'Half Present/Partial Leave': 'ot-halfpresent'
        }
    };
    var getCellColor = function (value, index) {
        let cls = '';
        let cleanedValue = value.trim().split('(')[0].trim()
        if (cleanedValue.includes('Partial Leave') && !cleanedValue.includes('Half Absent')) {
            cls = 'ot-leave-partial';
            return cls;
        }
        else {
            if (conditions[index]) {
                $.each(conditions[index], function (key, val) {
                    var keywords = key.split(' ');
                    if (keywords.every(function (word) {
                        return value.includes(word);
                    })) {
                        cls = val;
                        return false; // Break the loop when a match is found
                    }
                });
            }
        }
        return cls;
    };

    function getOTTitleWidth(text) {
        const baseText = 'Festival Allowance';
        const baseWidth = 165;
        const scaleFactor = baseWidth / baseText.length;

        const width = text.length * scaleFactor;
        return Math.ceil(width); // Round up to the nearest integer
    }
    var handlePageLoad = function (paramData) {
        //KRG:2022.01.06: Do not load grid if datefrom or date to is null.
        if (!paramData || !paramData.DateFrom || !paramData.DateTo) return;
        finalizeToolbarObject.isGridRefreshed = true;
        finalizeToolbarObject.gridEmpCode = "";
        var preparedPayloads = getPayload(paramData);
        var menuType = $('#menutype').val();
        var isShowFinalizedToolbarItems = (menuType == 'overtime' || menuType == 'attendance') ? true : false;
        var isShowFinalizeUnfinalizeElement = (menuType == 'overtime' || menuType == 'attendance' || menuType == 'finalized' || menuType == 'finalizedOvertime') ? true : false;
        var shouldEnableHwrap = false;
        debugger;
        var config = {
            url: preparedPayloads.url,
            payload: preparedPayloads.payload,
            isPaginationEnable: true,
            useCheckBox: true,

            defaultPageSize: 1000,
            onRowClick: "AttendanceLogId",
            menuType: preparedPayloads.payload.menutype,
            showToolbar: true,
            gridElement: gridElement,
            wrap: false, // Grid data except column wrap
            hwrap: false, // Column Header Wrap       
            atoWidth: true,
            filterSkipColumns: 'WorkDuration,OverTime,ActualOverTime,ApprovedOverTime,ShiftDuration,TotalDuration,LateBy,EarlyBy,TotalLateAndEarlyBy,LateByAfterGrace,EarlyByBeforeGrace,TotalLateAndEarlyByAfterBeforeGrace,WorkDeviation,ShortHours',
            postRenderFunction: function (menuType = preparedPayloads.payload.menutype, element = gridElement) {
                debugger;
                var grid = $(element).pqGrid("getInstance").grid;
                var colModel = grid.colModel;
                if (menuType == 'overtime') {
                    var OTIDIndex = findIndexByPropertyValue(colModel, 'dataIndx', 'OTID');
                    var dataIndexes = [];
                    if ($('#isEditPermissionGiven').val() == 'true') {
                        $.each(colModel, function (i, a) {
                            if (i > OTIDIndex) {
                                debugger;
                                if (a.dataIndx == 'LevelOrder' || a.dataIndx == 'DisplayOrder') return;
                                dataIndexes.push()
                                a['editable'] = true;
                                //a['width'] = getOTTitleWidth(a['title']);
                                a['width'] = 140;
                                a['render'] = function (ui) {
                                    return ui.rowData[a.dataIndx] > 0 ? '1' : ''
                                };
                                shouldEnableHwrap = true;
                                a['cls'] = true ? 'ni-pq-cl-edit ni-wrap-text' : '';
                                a.editModel = { keyUpDown: true };
                                a.validations = [
                                    {
                                        type: function (ui) {
                                            var value = ui.value;
                                            if (isNaN(value) || parseFloat(value) <= 0) {
                                                ui.msg = "Please enter a positive number";
                                                return true;
                                            }
                                        },
                                        icon: 'ui-icon-info'
                                    }
                                ];

                            } else if (a['dataIndx'] == 'ApprovedOverTime' || a['dataIndx'] == 'OTRemarks') {
                                a['editable'] = true;
                                a['cls'] = true ? 'ni-pq-cl-edit' : '';

                            }

                        });

                    }
                    else {
                        $.each(colModel, function (i, a) {
                            if (i > OTIDIndex) {
                                if (a.dataIndx == 'LevelOrder' || a.dataIndx == 'DisplayOrder') return;
                                shouldEnableHwrap = true;
                                return false;
                            }
                        });
                    }



                }
                if (menuType == 'finalizedOvertime') {
                    var OTIDIndex = findIndexByPropertyValue(colModel, 'dataIndx', 'OTID');
                    $.each(colModel, function (i, a) {
                        if (i > OTIDIndex) {
                            if (a.dataIndx == 'LevelOrder' || a.dataIndx == 'DisplayOrder') return;
                            shouldEnableHwrap = true;
                            return false;
                        }
                    });
                }
                $.each(colModel, function (i, a) {
                    if (menuType == 'attendance') {
                        if (a['dataIndx'] == 'OvertimeFinalizedStatus') a['hidden'] = true;
                    }
                    if (a['dataIndx'] == 'IsApplyOT') a['hidden'] = true;
                });
                grid.option('hwrap', shouldEnableHwrap);
                grid.refreshCM(colModel);
                grid.refreshView();
                $(document).find('._r_toolbarItem').show();
                processFinalizedToolbar();
            },
            toolbar: {
                items: [
                    {
                        type: 'button',
                        label: '<i class="fa fa-filter"></i> Filter',
                        listener: function () {
                            this.option('filterModel.header', !this.option('filterModel.header'));
                            this.refresh();
                            if (this.option('filterModel.header')) $(document).find(gridElement).find('.NI_CHECKBOX_HEADER').css({ 'visibility': 'visible' });
                        }
                    },
                    {
                        type: 'button',
                        label: '<i class="fa fa-repeat"></i> Reset filters',
                        listener: function () {
                            $(`#${finalizeToolbarObject.empcodeInputIdSelector}`).val('');
                            this.option('dataModel.postData', getPayload(paramData).payload);
                            this.option('dataModel.url', getPayload(paramData).url);
                            this.reset({ filter: true });
                        }
                    },
                    {
                        type: function () {
                            if ($('#isEditPermissionGiven').val() == 'false') return "";
                            var html = ``
                            if (menuType == 'attendance') {
                                html = ` <a class="lnkFinalizeUnfinalize btn btn-default" href="javascript:;" data-action="finalizeAttendance" data-loading-text="Working on it.."> <i class='fa fa-check-square-o'></i> Finalize Attendance</a>`
                            }
                            else if (menuType == 'overtime') {
                                html += ` <a class="lnkFinalizeUnfinalize btn btn-default" href="javascript:;" data-action="finalizeOvertime" data-loading-text="Working on it.."> <i class='fa fa-check-square-o'></i> Finalize Overtime</a>`
                                html += `&nbsp; <a class="lnkAddOverTime btn btn-default" href="javascript:;" data-action="addOverTime" data-loading-text="Working on it.."> <i class='fa fa-calculator'></i> Calculate OT</a>`
                                html += `&nbsp; <a class="lnkAddOTAllowance btn btn-default" href="javascript:;" data-action="addOTAllowance" data-loading-text="Working on it.."> <i class='fa fa-calculator'></i> Calculate OT Allowance</a>`
                                html += `&nbsp; <a class="lnkSaveOTPQ btn btn-default" href="javascript:;" id="saveOT" data-action="saveOT" data-loading-text="Working on it.."> <i class='fa fa-save'></i> Save OT</a>`
                            }
                            else if (menuType == 'finalized') {

                                html = ` <a class="lnkFinalizeUnfinalize btn btn-default" href="javascript:;" data-action="unFinalizeAttendance" data-loading-text="Working on it.."> <i class='fa fa-undo'></i> Unfinalize Attendance</a>`
                                //html += ` <a class="lnkFinalizeUnfinalize btn btn-default" href="javascript:;" data-action="unFinalizeOvertime" data-loading-text="Working on it.."> <i class='fa fa-undo'></i> Unfinalize Overtime</a>`
                            }
                            else if (menuType == 'finalizedOvertime') {
                                //html = ` <a class="lnkFinalizeUnfinalize btn btn-default" href="javascript:;" data-action="unFinalizeAttendance" data-loading-text="Working on it.."> <i class='fa fa-undo'></i> Unfinalize Attendance</a>`
                                html += ` <a class="lnkFinalizeUnfinalize btn btn-default" href="javascript:;" data-action="unFinalizeOvertime" data-loading-text="Working on it.."> <i class='fa fa-undo'></i> Unfinalize Overtime</a>`

                            }
                            return html;
                        }
                    }
                ]
            },
            columnModifyAndRender: [{
                column: 'Status',
                render: function (ui) {
                    var rowData = ui.rowData,
                        dataIndx = ui.dataIndx;
                    rowData.pq_cellcls = rowData.pq_cellcls || {};
                    rowData.pq_cellcls[dataIndx] = getCellColor(rowData['Status'], 'Status');
                    return `${ui.rowData.Status}`
                }
            },
            {
                column: 'DailyStatus',
                render: function (ui) {
                    var rowData = ui.rowData,
                        dataIndx = ui.dataIndx;
                    rowData.pq_cellcls = rowData.pq_cellcls || {};
                    rowData.pq_cellcls[dataIndx] = getCellColor(rowData['DailyStatus'], 'Status');
                    return `${ui.rowData.Status}`
                }
            },
            {
                column: 'EmpName',
                render: function (ui) {
                    var attdDate = ui.rowData.AttendanceDate;
                    var empCode = ui.rowData.EmpCode;
                    var values2 = `<a class="btn-link no-padding no-margin" id="viewdetails_${empCode}_${attdDate}" ></a>`
                    ui.cellData = values2;
                    return `<a class="btn-link no-padding no-margin" id="viewdetails_${empCode}_${attdDate}" title="Click to view attendance details." style="cursor: pointer;" onclick="DailyAttendanceModule.initAjxViewAttendanceDetails('${empCode}','${attdDate}')">${ui.rowData.EmpName}</a>`
                }
            },
            {
                column: 'MonthStatus',
                render: function (ui) {
                    var rowData = ui.rowData,
                        dataIndx = ui.dataIndx;
                    rowData.pq_cellcls = rowData.pq_cellcls || {};
                    rowData.pq_cellcls[dataIndx] = getCellColor(rowData['MonthStatus'], 'MonthStatus');
                    return `${ui.rowData['MonthStatus']}`
                }
            },
            {
                column: 'AttendanceFinalizedStatus',
                render: function (ui) {
                    return {
                        style: ui.rowData['AttendanceFinalizedStatus'] == true ? 'background:#048705;color:white;' : 'background:yellow',
                        text: ui.rowData['AttendanceFinalizedStatus'] == true ? 'Finalized' : (menuType == 'finalized' ? 'Unfinalized' : 'Pending')
                    };
                }
            },
            {
                column: 'OvertimeFinalizedStatus',
                render: function (ui) {
                    return {
                        style: ui.rowData['IsApplyOT'] == false ? 'background:#544dcd;color:white' : (ui.rowData['OvertimeFinalizedStatus'] == true ? 'background:#048705;color:white;' : 'background:yellow'),
                        text: ui.rowData['IsApplyOT'] == false ? 'Non OT Group: Auto Finalized' : (ui.rowData['OvertimeFinalizedStatus'] == true ? 'Finalized' : ((menuType == 'finalized' || menuType == 'finalizedOvertime') ? 'Unfinalized' : 'Pending'))
                    };
                }
            }],
            cellSave: function (event, ui) {
                if (ui.column.editable && ui.newVal != ui.oldVal) {
                    var checkboxColumnIndex = findIndexByPropertyValue(this.options.colModel, 'dataIndx', 'NI_CHECKBOX');

                    if (checkboxColumnIndex != -1) {
                        ui.rowData['NI_CHECKBOX'] = true
                        this.refreshView()
                    }
                }
            },
            sumTimeColumns: ["OverTime", "ApprovedOverTime"]
        }
        //if ($('#menutype').val() == 'attendance' || $('#menuType').val() == 'overtime') {


        //}

        nimbleRefreshGrid(gridElement, config);

        $.contextMenu('destroy');
        if (["attendance"].indexOf(preparedPayloads.payload.menutype) != -1) {
            setTimeout(function () {
                handleGridContextMenuAttReconc();
            }, 500);

        }

        DailyAttendanceModule.inithandleFinalizeUnfinalizeAttendance($(document).find(".lnkFinalizeUnfinalize"));
        DailyAttendanceModule.inithandleOvertime($(document).find(".lnkSaveOTPQ,.lnkAddOverTime,.lnkAddOTAllowance"));
        DailyAttendanceModule.inithandleOvertimeAllowance($(document).find(".lnkAddOTAllowance"));

    }

    var AjxViewAttendanceDetails = function (empCode, attdDate) {
        var url = '/Attendance/DailyAttendanceReconciliation/ViewAttendanceDetailsOnPopup?EmpCode=' + empCode + '&attdDate=' + attdDate;
        //$('body').modalmanager('loading');
        spinnerOn($('body'));
        $.ajax({
            url: url,
            success: function () { },
            error: function (err) { console.log('Error!'); },
            complete: function (result) {
                $('#modal-popupDetails').html(result.responseText);
                $('#modal-popupDetails').modal('show');
                spinnerOff($('body'));
            }
        });
    }

