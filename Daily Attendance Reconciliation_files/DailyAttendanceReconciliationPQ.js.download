    var handleModalPopUp = function (id, List) {
        let modalHtml = "<div class='modal fade' tabindex='-1' role='dialog' id='modal-popup1'>" +
            '<div class="modal-dialog" role="document" style=" margin-top:0 !important; margin-bottom:0px !important">' +
            '  <div class="modal-content">' +
            "<div class='modal-header'>";
        modalHtml +=
            "<button type='button' class='close' data-dismiss='modal' aria-hidden='true'>×</button><h4 class='modal-title text-warning'><i class='fa fa-warning'></i> Attention!</h4>";
        modalHtml += "</div>" +
            "<div class='modal-body'><h4>Selected row data will be removed from database. If you invoke YES, you'll not be able to undo. Are you sure about this? Click <b>YES</b> to confirm or <b>NO</b> to cancel.</h4></div>" +
            "<div class='modal-footer'>";
        modalHtml +=
            "<a /*data-dismiss='modal'*/ class='btn btn-nim-danger btnSave' id = '" + id + "'><i class='fa fa-trash-o'></i> Yes</a>";
        modalHtml +=
            "<a data-dismiss='modal' class='btn btn-nim-sec' data-dismiss='modal'><i class='fa fa-times'></i> No</a></div></div></div></div>";
        const custDialog = $.parseHTML(modalHtml);
        $(custDialog).modal("show");


        if (id === "shiftClear") {
            handleClearshiftOnclickEvent(List);
        }
        else if (id === "clearforceAttendance") {
            handleClearForceAttendance(List);
        }
        //else if (id === "deleteOvertime") {
        //    handleDeleteOverTime(List);
        //}
        //else if (id === "deleteOtAllowance") {
        //    handleDeleteOtAllowance(List);
        //}
    };
    var handleSendNotification = function ($sender) {
        $sender.off().on("click", function (e) {
            e.preventDefault();
            if (!$(gridElement).hasClass('pq-grid')) {
                showClientMsg("Please load grid first.", "warning");
                return;
            }

            if (!($("#SendtoEmp").is(":checked") || $("#SendtoEmpForAbsent").is(":checked") || $("#SendtoSup").is(":checked") || $("#SendtoSupForAbsent").is(":checked"))) {
                showClientMsg("Please select at least one option.", "warning");
                return;
            }

            var gridData = handleGridTransformation(gridElement, true);

            var jaggedData = gridData.jagged;
            var empcodeIdx = jaggedData[0].indexOf("EmpCode");
            jaggedData = jaggedData.slice(1);
            var empcode = "";

            if (empcodeIdx != -1) {
                empcode = $.map(jaggedData, function (obj) {
                    return obj[empcodeIdx];
                });
                empcode = empcode.filter(function (item, index, self) {
                    return self.indexOf(item) === index;
                });
            }

            const postData = JSON.stringify({
                DateFrom: $("input[name='DateFrom']").val(),
                DateTo: $("input[name='DateTo']").val(),
                IsEmployee: $("#SendtoEmp").prop("checked"),
                IsEmployeeForAbsent: $("#SendtoEmpForAbsent").prop("checked"),
                IsSupervisor: $("#SendtoSup").prop("checked"),
                IsSupervisorForAbsent: $("#SendtoSupForAbsent").prop("checked"),
                EmpCodes: empcode.toString()

            });
            spinnerOn($('body'));
            $('.btnSave').button('loading');
            $.ajax({
                method: "POST",
                url: "/Attendance/DailyAttendanceReconciliation/SendEmail",
                data: postData,
                dataType: "json",
                contentType: 'application/json; charset=utf-8',
                success: function (result) {
                },
                complete: function (result) {
                    spinnerOff($('body'));
                    $('.btnSave').button('reset');
                    var obj = JSON.parse(result.responseText);
                    //default obj
                    const clientMessage = { title: obj.Title, type: obj.StatusType, content: obj.Message };
                    if (obj.StatusType === "success") {
                        window.UIExtendedModals.hide();
                        if ($(gridElement).hasClass('pq-grid')) $(gridElement).pqGrid('refreshDataAndView')
                        handleMainGridClick();
                    }
                    window.UIToastr.init(clientMessage);
                    //window.UIExtendedModals.hide();
                }

            })

        })

    }
    var handleClearshiftOnclickEvent = function (List) {

