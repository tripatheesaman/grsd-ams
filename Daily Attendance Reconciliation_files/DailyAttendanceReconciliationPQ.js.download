    var afterPopupOpen = function (action) {
        console.log('action', action)
        //handleReloadTableBtnClick($('.btnclose'));
        if (action === "shift") {
            handleEmpShiftallocatioGridLoad();
            handleSaveShiftAllocation($("#btShiftFrm"));
