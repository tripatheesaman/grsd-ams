                var URL = '/Attendance/forceattendance/Index?tab=attendancelogs&SelectedEmpCode=' + requestID.toString() + '&Date=' + date + '&TableHeight=' + (screenHeight - 2 * padding - 20) + "";
                window.open(URL, "_blank", strWindowFeatures);
            }

        })
    }

    var handleDeleteOvertime = function ($sender, type) {
        $sender.on("click", function (e) {
            e.preventDefault();
            if (!$(gridElement).hasClass('pq-grid')) {
                showClientMsg("Please load grid first.", "warning");
                return;
            }
            var gridData = handleGridTransformation(gridElement);
            const requestID = gridData.rowClickItems;
            var dataHeader = gridData.jagged[0];
            var dataList = gridData.jagged.slice(1);
            var data = [];
            var clearList = [];
            var headerList = gridData.jagged[0];
            data.push(headerList);
            var count = dataList.length;
            for (var i = 0; i < count; i++) {
                data.push(dataList[i].map(function (val, i) {
                    return val === null ? 0 : val;
                }));
            }

            if (requestID.length <= 0) {
                window.handleActionButtonsClick();
                return false;
            }
            else {
                spinnerOn($('body'));
                $.ajax({
                    method: 'POST',
                    url: '/Attendance/DailyAttendanceReconciliation/CheckOvertimeBlockRule',
                    data: { GridTable: data },
                    success: function (result) {
                    },
                    complete: function (result) {
                        spinnerOff($('body'));
                        var obj = JSON.parse(result.responseText);
                        if (obj == true) {
                            $('.btnSave').button('reset');
                            showClientMsg("Date Deletion is Blocked for selected Data Range.", "error", "Overtime Calculation");
                            if ($(gridElement).hasClass('pq-grid')) $(gridElement).pqGrid('refreshDataAndView')
                            return false;
                        }
                        else {
                            handleModalPopUpForDeleteOvertime(type, data);
                        }

                    },
                    error: function () {

                    }
                })



            }

        })

    }
    var handleModalPopUpForDeleteOvertime = function (id, List) {
        let modalHtml = "<div class='modal fade' tabindex='-1' role='dialog' id='modal-popup2'>" +
            '<div class="modal-dialog" role="document" style=" margin-top:0 !important; margin-bottom:0px !important">' +
            '  <div class="modal-content">' +
            "<div class='modal-header'>";
        modalHtml +=
            "<button type='button' class='close' data-dismiss='modal' aria-hidden='true'>×</button><h4 class='modal-title text-warning'><i class='fa fa-warning'></i> Attention!</h4>";
        modalHtml += "</div>" +
            "<div class='modal-body'>" +
            //"< h4 > Selected row data will be removed from database.If you invoke YES, you'll not be able to undo. Are you sure about this? Click <b>YES</b> to confirm or <b>NO</b> to cancel.</h4>"+
            "<h4>Only manually added overtime will be deleted but not those from overtime requests. Click <b>YES</b> to confirm or <b>NO</b> to cancel.</h4>" +
            "</div > " +
            "<div class='modal-footer'>";
        modalHtml +=
            "<a data-dismiss='modal' class='btn btn-nim-danger btnSave' id = '" + id + "'><i class='fa fa-trash-o'></i> Yes</a>";
        modalHtml +=
            "<a data-dismiss='modal' class='btn btn-nim-sec' data-dismiss='modal'><i class='fa fa-times'></i> No</a></div></div></div></div>";
        const custDialog = $.parseHTML(modalHtml);
        $(custDialog).modal("show");

        if (id === "deleteOvertimes") {
            handleDeleteOverTime(List);
        }
        else if (id === "deleteOtAllowances") {
            handleDeleteOtAllowance(List);
        }
    };

