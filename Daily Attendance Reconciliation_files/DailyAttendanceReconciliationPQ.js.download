            if (dataList.length <= 1) {
                window.handleActionButtonsClick();
                return false;
            }
            else {

                if (handleGridTransformation('#pq-grid-table').jagged[0].indexOf('ShiftCode') == -1 && type == 'shiftClear') {
                    var clientMessage = { title: 'Clear Shift', type: 'error', content: 'Please load grid with ShiftCode to perfrom Clear Shift operation.' };
                    window.UIToastr.init(clientMessage);

                    return;
                }
                /* handleModalPopUp(type, data);*/
                handleModalPopUp(type, dataList);
            }

        })

    }
    var handleForceAttendanceFormValidation = function (sender, action) {
        var form = $('#attendance-manualattendance-forms');
        var error = $('.alert-danger', form);
        var success = $('.alert-success', form);
        form.validate({
            errorElement: 'span', //default input error message container
            errorClass: 'help-block help-block-error', // default input error message class
            focusInvalid: true,
            errorPlacement: function (error, element) {
                return false;
            },
            ignore: "", // validate all fields including form hidden input
            rules: {
                Remarks: {
                    minlength: 3,
                    required: true
                }
            },
            messages: {
            },
            invalidHandler: function (event, validator) { //display error alert on form submit
                success.hide();
                error.show();
            },
            highlight: function (element) {
                $(element).closest('.form-group').removeClass("has-success").addClass('has-error');
            },
            unhighlight: function (element) {
                $(element).closest('.form-group').removeClass('has-error').addClass('has-success');
            },
            success: function (label, element) {
                $(element).closest('.form-group').removeClass('has-error').addClass('has-success');
                $(label).remove();
            },
            submitHandler: function (form) {
                success.show();
                error.hide();
                $('.Create').button('loading');
                $('.btnSave').button('loading');
                const $form = $(form);
                var FromDateValue = $("#FromDate").val();
                var logSource = $("#LogSource").val();
                setTimeout(function () {
                    spinnerOn($('body'));
                    $.ajax({
                        method: $form.attr("method"),
                        url: $form.attr("action"),
                        data: $form.serialize(), DateFrom: FromDateValue, Action: action, LogSource: logSource,
                        success: function () {
                            //show submitting message
                        },
                        complete: function (result) {
                            spinnerOff($('body'));
                            const objArr = JSON.parse(result.responseText);
                            var clientMessage = { title: objArr.Title, type: objArr.StatusType, content: objArr.Message };
                            if (objArr.StatusType === "success") {
                                window.UIExtendedModals.hide();
                                if ($(gridElement).hasClass('pq-grid')) $(gridElement).pqGrid('refreshDataAndView')
                                handleMainGridClick();
                            }
                            window.UIToastr.init(clientMessage);

                            $('.Create').button('reset');
                            $('.btnSave').button('reset');
                        },
                        error: function (results) {
                            console.log(results.responseText);
                        }
                    });
                }, 400);
                return false;
            }
        });
    };
    var handleOvertimeAllowance = function ($sender) {
        $sender.unbind('click').on("click", function (e) {
            e.preventDefault();
            if (!$(gridElement).hasClass('pq-grid')) {
                showClientMsg("Please load grid first.", "warning");
                return;
            }
            var gridData = handleGridTransformation(gridElement);
            var headerList = gridData.jagged[0];
            var dataList = gridData.jagged.slice(1);
            var data = [];
            data.push(headerList);
            var count = dataList.length;
            for (var i = 0; i < count; i++) {
                data.push(dataList[i].map(function (val, i) {
                    return val === null ? 0 : val;
                }));
            }

            if (count <= 0) {
                window.handleActionButtonsClick();
                return false;
            }
            else {
                spinnerOn($('body'));
                $.ajax({
                    method: 'POST',
                    url: '/Attendance/DailyAttendanceReconciliation/CheckOvertimeBlockRule',
                    data: { GridTable: data },
                    success: function (result) {
                    },
                    complete: function (result) {
                        spinnerOff($('body'));
                        var obj = JSON.parse(result.responseText);
                        if (obj.IsBlocked == true) {
                            $('.btnSave').button('reset');
                            showClientMsg("Overtime Calculation is Blocked for selected Data Range.", "error", "Overtime Calculation");
                            showAlertWithTimeoutMessageOnly(obj.Message);
                            if ($(gridElement).hasClass('pq-grid')) $(gridElement).pqGrid('refreshDataAndView');
                            return false;
                        }
                        else {
                            var confirmMessage = confirm("Overtime Allowance will be replaced,Do you want to continue? ");
                            if (confirmMessage == false) {
                                //$('.btnSave').button('reset');
                                return false;
                            }
                            else {
                                const postData = JSON.stringify({
                                    data: data,
                                    loadOTAllowance: $('#LoadOTAllowance').val()
                                });
                                spinnerOn($('body'));
                                $.ajax({
                                    method: "POST",
                                    url: "/Attendance/DailyAttendanceReconciliation/OvertimeAllowanceCalculation",
                                    data: postData,
                                    dataType: "json",
                                    contentType: 'application/json; charset=utf-8',
                                    success: function (result) {
                                    },
                                    complete: function (result) {
                                        spinnerOff($('body'));
                                        //$("#modal-popup").modal("hide");
                                        var obj = JSON.parse(result.responseText);
                                        //default obj
                                        const clientMessage = { title: obj.Title, type: obj.StatusType, content: obj.Message };
                                        if (obj.StatusType === "success") {
                                            //  window.UIExtendedModals.hide();
                                            if ($(gridElement).hasClass('pq-grid')) $(gridElement).pqGrid('refreshDataAndView')
                                            //  handleMainGridClick();
                                            // $("#modal-popup").modal("hide");
                                        }
                                        window.UIToastr.init(clientMessage);
                                        //$("#modal-popup").modal("hide");
                                    }

                                });
                            }
                        }
                    },
                    error: function () {

                    }
                })
            }
        })
    }

    var handlePreserveFilterData = function () {
        var frm = $("form[id='gridFilterForm']");
        var data = frm.serializeFormJSON();
        var hrmData = {};
        $.each(data, function (index, value) {
            if ($.isArray(value)) {
                hrmData[index] = value.toString().replace("-1,", "").replace("-1", "");
            } else {
                hrmData[index] = value.replace("-1,", "").replace("-1", "");
            }
        });
        $.extend(data, hrmData);
        return data;
    }

