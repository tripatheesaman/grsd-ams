    var handleFroceAttendance = function ($sender) {
        $sender.on("click", function (e) {
            e.preventDefault();
            if (!$(gridElement).hasClass('pq-grid')) {
                showClientMsg("Please load grid first.", "warning");
                return;
            }
            var gridData = handleGridTransformation(gridElement);
            var data = gridData.jagged;

            var requestID = gridData.rowClickItems;
            if (requestID == null || requestID.length == 0) {
                showClientMsg("Please select one record to proceed.", "warning", "Attendance Reconciliation");
                return;
            }

            var date = "";
            var dateIdx = data[0].indexOf("AttendanceDate");
            var empcodeIdx = data[0].indexOf("EmpCode");
            var empcode = data[1][empcodeIdx];

            if (data.length == 2) {
                date = data[1][dateIdx];
                //empcode = data[1][empcodeIdx];
            }
            if (data.length > 2) {
                const clientMessage = { title: "Force Attendance", type: "warning", content: "Please select one record to proceed." };
                window.UIToastr.init(clientMessage);
                return false;
            }
            else {
                $('body').modalmanager('loading');
                var sender = $(this);
                var action = sender.attr('data-action');
                var width = '60%';
                var url = "/Attendance/Forceattendance/Create";
                window.UIExtendedModals.init({
                    width: width,
                    content: url,
                    contentPlaceHolder: $("#modal-popup"),//,
                    modalElement: $("#modal-popup"),//$("#modal-popup"),
                    fillContent: true,
                    usingAjax: true,
                    data: { empCode: empcode, logDate: date },
                    afterPopupOpen: function () {
                        handleForceAttendanceFormValidation(sender, action);
                        //$(".timeSet").timepicker();
                        handleReloadTableBtnClick($('.close'));
                        handelPickerAfterBsModalPopUpOpen();
                    },
                    afterPopupClose: function () {

                    }
                });
            }
        })
    }

    var handleShowPunch = function ($sender) {
        $sender.on("click", function (e) {
            e.preventDefault();
            if (!$(gridElement).hasClass('pq-grid')) {
                showClientMsg("Please load grid first.", "warning");
                return;
            }
            var gridData = handleGridTransformation(gridElement);
            var data = gridData.jagged;
            var requestID = gridData.rowClickItems;

            if (requestID == null || requestID.length == 0) {
                showClientMsg("Please select one record to proceed.", "warning", "Attendance Reconciliation");
                return;
            }

            var date = "";
            var dateIdx = data[0].indexOf("AttendanceDate");
            var empcodeIdx = data[0].indexOf("EmpCode");
            console.log(requestID)
            if (data.length == 2) {
                date = data[1][dateIdx];
                requestID = data[1][empcodeIdx];
            }
            if (data.length != 2) {
                const clientMessage = { title: "Show Punch", type: "warning", content: "Please select one record to proceed." };
                window.UIToastr.init(clientMessage);
