    var handleAttendanceCalcBulk = function ($sender) {

        $sender.on("click", function (e) {
            e.preventDefault();
            $.confirm({
                title: 'Confirm!',
                content: "Do you want to proceed? Click 'Yes' to modify record else 'No'.",
                buttons: {
                    Yes: {
                        text: 'Yes',
                        btnClass: 'btn-nimble',
                        keys: ['enter'],
                        action: function () {
                            spinnerOn($('body'));
                            var dateFrom = $("input[name='DateFrom']").val()
                            var dateTo = $("input[name='DateTo']").val()
                            $.ajax({
                                method: "POST",
                                url: "/Attendance/DailyAttendanceReconciliation/CheckBlockRule",
                                data: JSON.stringify({ dateFrom, dateTo }),
                                dataType: "json",
                                contentType: 'application/json; charset=utf-8',
                                success: function (result) {
                                    if (result.IsBlocked == true) {
                                        var errorMessage = (result.OutputMessage != null || result.OutputMessage != "") ? result.OutputMessage : "";
                                        showClientMsg(errorMessage != "" ? errorMessage : "Attendance Calcuation is Blocked for selected Data Range", "error", "Attendance Calculation");
                                        return false;
                                    }
                                    else if (result.IsBlocked == false) {
                                        preserveFilterData();
                                        const data = {
                                            postData: globalData,
                                            dateFrom,
                                            to: dateTo
                                        };
                                        setTimeout(function () {
                                            spinnerOn($('body'));
                                            $.ajax({
                                                method: "POST",
                                                url: "/Attendance/DailyAttendanceReconciliation/BulkCalculateAttendance",
                                                data: data,
                                                success: function () { },
                                                complete: function (result) {
                                                    spinnerOff($('body'));
                                                    const objArr = JSON.parse(result.responseText);
                                                    var clientMessage = { title: "Calculate", type: objArr.StatusType, content: objArr.Message };
                                                    if (objArr.StatusType === "success") {
                                                        if ($(gridElement).hasClass('pq-grid')) $(gridElement).pqGrid('refreshDataAndView');
                                                    }
                                                    $(this).unbind('click').bind('click');
                                                    window.UIToastr.init(clientMessage);
                                                },
                                                error: function (results) {
                                                    spinnerOff($('body'));
                                                    console.log(results.responseText);
                                                }
                                            });
                                        }, 400);
                                    } else {
                                        return false;
                                    }
                                },
                                complete: function (result) {
                                    spinnerOff($('body'));
                                },
                                error: function () {
                                    spinnerOff($('body'));
                                }
                            });
                        }
                    },
                    No: {
                        text: 'No',
                        btnClass: 'btn-nim-sec',
                        action: function () {

                        }
                    },
                }
            });



        })
    }

