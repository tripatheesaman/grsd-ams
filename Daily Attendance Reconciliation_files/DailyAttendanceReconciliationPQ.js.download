    var handleEmpShiftallocatioGridLoad = function () {

        if (!$(gridElement).hasClass('pq-grid')) {
            showClientMsg("Please load grid first.", "warning");
            return;
        }
        var jaggedArray = handleGridTransformation(gridElement).jagged;


        const config1 = {

            url: "/attendance/DailyAttendanceReconciliation/LoadEmpShiftAllocationGrid",
            useCheckBox: false,
            mainContainer: $("#reload-alls1"),
            formType: "Index",
            pageWraper: $(".paging-wrapper"),
            // paramsData: { DateFrom: dateFrom, DateTo: dateTo, EmpCodes: EmpCode },
            paramsData: { data: jaggedArray },
            excludeColumn: ["ShiftID", "UnitID", "EmpGroupID"],
            headerText: [
                { EmpCode: "Emp Code" },
                { EmpName: "Emp Name" },
                { ShiftCode: "Shift Code" },
                { UnitName: "Unit" },
                { EmpGroupName: "Emp Group Name" },
                { ShiftDate: "Shift Date" },
                { ShiftDateNepali: "Shift Date Nepali" },
            ]
        }
        $("#hands-on-table-updateShift").selectionAppModel(config1);
    }


    var handleSaveShiftAllocation = function (sender) {
        sender.on("click", function () {
            if (!$(gridElement).hasClass('pq-grid')) {
                showClientMsg("Please load grid first.", "warning");
                return;
            }
            const handsontable = $("#hands-on-table-updateShift").data('nimble');
            const data = handsontable.getAllData();
            const FromDate = $("#fromDateAllocation").val();
            const ToDate = $("#toDateAllocation").val();
            const SelectShift = $("#SelectShiftId").val();
            const ShiftType = $("#cmbShiftType").val();
            const Remarks = $("#Remarks").val();
            $(".btnSave").button('loading');
            spinnerOn($('body'));
            $.ajax({
                method: 'POST',
                url: '/Attendance/DailyAttendanceReconciliation/CheckShiftBlockRule',
                data: { GridTable: data },
                success: function (result) {
                },
                complete: function (result) {
                    spinnerOff($('body'));
                    var obj = JSON.parse(result.responseText);
                    if (obj == true) {
                        $('#btShiftFrm').button('reset');
                        showClientMsg("Shift Allocation is Blocked for selected Data Range.", "error", "Shift Allocation");
                        return false;
                    }
                    else {
                        spinnerOn($('body'));
                        $.ajax({
                            method: 'POST',
                            url: '/Attendance/DailyAttendanceReconciliation/UpdateEmployeeShiftAllocation',
                            data: { DateFrom: FromDate, ToDate: ToDate, Remarks: Remarks, ShiftId: SelectShift, ShiftTypeId: ShiftType, GridTable: data },
                            success: function (result) {
                            },
                            complete: function (result) {
                                spinnerOff($('body'));
                                $('#btShiftFrm').button('reset');
                                var obj = JSON.parse(result.responseText);
                                //default obj
                                const clientMessage = { title: obj.Title, type: obj.StatusType, content: obj.Message };
                                if (obj.StatusType === "success") {
                                    //hide the UIExtendedModals by caling this method
                                    window.UIExtendedModals.hide();

                                    if ($(gridElement).hasClass('pq-grid')) $(gridElement).pqGrid('refreshDataAndView')
                                    handleMainGridClick();
                                }
                                setTimeout(function () {
                                    window.UIToastr.init(clientMessage);
                                }, 100);
                            },
                            error: function () {
                            }
                        })
                    }

                },
                error: function () {

                }
            })
        })
    }

    function convertDateFormat(dateString) {
        var parts = dateString.split('/');
        if (parts.length !== 3) {
            return null; // Return null for invalid dates
        }

        var day = parts[0];
        var month = parts[1];
        var year = parts[2];

        // Construct the date in 'yyyy/MM/dd' format
        var formattedDate = year + '/' + month + '/' + day;
        return formattedDate;
    }
    var isDateRangeValid = function (dateSys, dateFrom, dateTo) {
        if (dateSys === "nep") {
            if (dateFrom > dateTo)
                return false;
        }
        else {
            var dateFromE = convertDateFormat(dateFrom);
            var dateToE = convertDateFormat(dateTo);

            if (dateFromE > dateToE)
                return false;
        }
        return true;
    }

    var handleSearchBtnClick = function ($sender) {
        $sender.off("click").on("click", function (e) {
            e.preventDefault();
            //$('#GlobalFilterDiv').hide();
            var frm = $("#gridFilterForm");
            var data = frm.serializeFormJSON();

            var hrmData = {};
            $.each(data, function (index, value) {
                if ($.isArray(value)) {
                    hrmData[index] = value.toString().replace("-1,", "").replace("-1", "");
                } else {
                    hrmData[index] = value.replace("-1,", "").replace("-1", "");
                }
            });
            $.extend(data, hrmData);
            globalData = data;
            if (!globalData || !globalData.DateFrom || !globalData.DateTo) {
                const clientMessage = { title: "Data Selection", type: "error", content: "Select date from and date to" };
                window.UIToastr.init(clientMessage);
                return;
            }
            var tabTitle = (new URLSearchParams(window.location.search)).get('tab') == "DAR" ? "Daily Attendance Reconciliation" : "Daily OverTime Reconciliation";
            var dateFromVal = globalData.DateFrom;
            var dateToVal = globalData.DateTo;
            var dateSys = $("#dateSys").val();
            if (dateFromVal != "" && dateFromVal != null && dateToVal != "" && dateToVal != null) {
                if (!isDateRangeValid(dateSys, dateFromVal, dateToVal)) {
                    const clientMessage = { title: tabTitle, type: "warning", content: "DateFrom value cannot be greater than DateTo" };
                    window.UIToastr.init(clientMessage);
                    return;
                }
            }
            handlePageLoad(globalData);
            handleMainGridClick();
            var flag = globalData.EmpCode.toString() !== '' ? true : false;
            $("#Shift").attr('data-url', '/Attendance/DailyAttendanceReconciliation/UpdateShift/?DateFrom=' + $("input[name='DateFrom']").val() + '&DateTo=' + $("input[name='DateTo']").val())
            //$("#bulkAttendance").attr('data-url', '/Attendance/DailyAttendanceReconciliation/BulkAttendance/?LogDateFromNepali=' + $("#DateFrom").val() + '&LogDateToNepali=' + $("#DateTo").val())
            $("#attcalc").attr('data-href', '/Attendance/DailyAttendanceReconciliation/CalculateAttendance/?DateFrom=' + $("input[name='DateFrom']").val() + '&DateTo=' + $("input[name='DateTo']").val())
            $("#attcalc1").attr('data-href', '/Attendance/DailyAttendanceReconciliation/CalculateAttendance1/?DateFrom=' + $("input[name='DateFrom']").val() + '&DateTo=' + $("input[name='DateTo']").val())
            $("#missedpunch").attr('data-url', '/Attendance/DailyAttendanceReconciliation/MissedPunch/?DateFrom=' + $("input[name='DateFrom']").val() + '&DateTo=' + $("input[name='DateTo']").val())
        });
    }

