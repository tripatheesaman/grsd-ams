var IsWindowPopup = function () {
    if ((window.opener !== window && !window.menubar.visible) || window.top != window.self)
        return true;
    else
        return false;
}
var handlePopupButtonVisible = function () {
    if (IsWindowPopup()) {
        $(".form-popup-close").show();
        $(".form-cancel").hide();
        $(".main-header").hide();
        $(".main-sidebar").hide();
        $(".main-footer").hide();
        $(".breadcrumb").hide();
        $(".hide-on-popup-window").hide();
        $(".content-wrapper").addClass("nim-hide-topbar nim-hide-sidebar");
        $(".main-footer").addClass("nim-hide-sidebar");
        $(".nim-rep-sticky").addClass("add-sticky-popup");
    }
    else {
        $(".form-cancel").css("visibility", "visible");
    }
}
var OverlayOn = function () {
    document.getElementById("overlay").style.display = "block";
}
var OverlayOff = function () {
    document.getElementById("overlay").style.display = "none";
}
//Following JS need to placed only after logged in.
var handleIsSessionExist = function () {
    $.ajax({
        url: "/security/account/heartbeat?session=Y",
        async: true,
        cache: true,
        success: function (data) {
            if (data.Object != "1" && window.location.href!="/") {
                window.location.href = "/";
            }
            else {
                OverlayOff();
            }
        },
        error: function (xhr, ajaxOptions, thrownError) {

        }
    });
}