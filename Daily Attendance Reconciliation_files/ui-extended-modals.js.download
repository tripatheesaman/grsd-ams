var UIExtendedModals = function () {

    //options
    var options = {
        title: null,
        isRemote: true,
        content: null, //url if isRemote=true else html 
        afterPopupOpen: null,
        afterPopupClose: null,
        showIframe: false,
        modalElement: $("#modal-popup"),
        titlePlaceHolder: $("#modal-title"),
        contentPlaceHolder: $("#modal-body"),
        width: '',
        height: 'auto',
        fillContent: false,
        usingAjax: false,
        data: null,
        show: false,
        reset: function () {
            this.title = null;
            this.isRemote = true;
            this.content = null; //url if isRemote=true else html 
            this.afterPopupOpen = null;
            this.afterPopupClose = null;
            this.showIframe = false;
            this.modalElement = $("#modal-popup");
            this.titlePlaceHolder = $("#modal-title");
            this.contentPlaceHolder = $("#modal-body");
            this.width = '';
            this.height = 'auto';
            this.fillContent = false;
            this.usingAjax = false;
            this.data = null;
            this.show = false;
        }
    };

    return {
        //main function to initiate the module
        init: function (settings) {

            $.extend(options, settings);
            // general settings

            $.fn.modalmanager.defaults.resize = true;
            // general settings

            var $modal = options.modalElement;
            var $modalHeader = $(".modal-header-iframe");

            if (options.width.toLowerCase() !== "auto")
                $modal.attr('data-width', options.width);
            else
                $modal.removeAttr('data-width');

            if (options.height.toLowerCase() !== "auto")
                $modal.attr('data-height', options.height);
            else
                $modal.removeAttr('data-height');


            var $title = options.titlePlaceHolder;
            var $content = options.contentPlaceHolder;

            //preserver Layout
            var originalLayout = options.modalElement.html();
            if (options.fillContent === true) $content = options.modalElement;

            $title.text(settings.title);

            if (options.content == null && options.showIframe !== true) {
                $modal.modal({ scrollable: false });
            }
            else if (options.showIframe === true) {
                $modal.css({ top: "100px" });
                $content.css({ padding: 0 });

                $modal.on('destroy', function () {
                    $content.empty();
                    $modal.css({ top: "" });
                    $content.css({ padding: "" });
                    options.reset();
                    //$('#holds-the-iframe').css('display', 'block');
                });
                $modal.modal({ scrollable: false });

                $content.html($("<div id='holds-the-iframe'><div class='overlay-content fa fa-refresh fa-3x fa-spin'></div></div><iframe id='ifrContent' class='iframe-embed' frameborder='0' scrolling='no'  src='" + options.content + "' />"));
                $("#ifrContent").on("load", function () {
                    var src = this.contentWindow.location.href;
                    if (src.includes("/SuccessPage?")) {
                        return;
                    }

                    $('#holds-the-iframe').css('display', 'none');
                    resizeIFrameToFitContent("ifrContent");
                    $(".modal-scrollable").scrollTop(0);

                });
            }
            else if (options.isRemote === false) {
                $content.html(options.content);
                $modal.modal({ scrollable: false });
            }
            else if (options.isRemote === true) {
                if (options.usingAjax) {
                    $content.load(options.content, options.data, function () {
                        $modal.modal({ scrollable: false, width: options.width }).on("shown.bs.modal", function () {
                            if (options.afterPopupOpen != null) {
                                options.afterPopupOpen();
                                setTimeout(function () {
                                    window.enableDisableAutoComplete();
                                }, 100);
                            }
                        }).on("hidden.bs.modal", function () {
                            if (options.fillContent === true) { $modal.html(originalLayout); }
                            if (options.afterPopupClose != null) options.afterPopupClose();
                        });
                    });
                } else {
                    $content.load(options.content, '', function () {
                        $modal.modal({ scrollable: false, width: options.width }).on("shown.bs.modal", function () {
                            if (options.afterPopupOpen != null) {
                                options.afterPopupOpen();
                                setTimeout(function () {
                                    window.enableDisableAutoComplete();
                                }, 100);
                            }
                        }).on("hidden.bs.modal", function () {
                            if (options.fillContent === true) { $modal.html(originalLayout); }
                            if (options.afterPopupClose != null) options.afterPopupClose();
                        });
                    });
                }
            }
        },

        hide: function () {
            var $modal = options.modalElement;
            $modal.modal("toggle");
        }
    };

}();