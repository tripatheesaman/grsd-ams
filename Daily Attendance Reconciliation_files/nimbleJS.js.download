function handlePqGirdFreezeAndColWidth(index, element, colModel, postRenderFunction, manualFreezeColumn, excludeColumn, headerText, widthOfColumn, _controlName, _lastSerialNo, groupModel = null, totalFields = null) {
    setTimeout(function () {
        // refreshing column model
        $(element).pqGrid('refreshCM', colModel);

        if (manualFreezeColumn) {
            index = findIndexByPropertyValue(colModel, 'dataIndx', manualFreezeColumn) + 1;
        }

        // updating freeze column index
        if (index != null && index != undefined && index > 0) $(element).pqGrid('option', 'freezeCols', index);

        /* column width code block start*/

        if (totalFields.length > 0) {
            groupModel.showSummary = [true, true];
        }

        // this code block is for setting width, do not modify this block unless sure
        var grid = $(element).pqGrid("instance");
        if (groupModel != {}) {
            $(element).pqGrid("groupOption", groupModel);
        }

        var columnModel = grid.option("colModel");

        var agg = pq.aggregate;
        agg.timeSum = function (arr, col) {
            // Initialize total hours and minutes
            let sumHours = 0;
            let sumMinutes = 0;

            // Regular expression to check for time in HH:mm format
            let timeRegex = /^([01]?\d|2[0-3]):([0-5]\d)$/;

            // Iterate through values in the array
            arr.forEach(value => {
                if (timeRegex.test(value)) {
                    let timeParts = value.split(":");
                    sumHours += parseInt(timeParts[0], 10);
                    sumMinutes += parseInt(timeParts[1], 10);
                }
            });

            // Convert extra minutes to hours
            sumHours += Math.floor(sumMinutes / 60);
            sumMinutes = sumMinutes % 60;

            // Format the result as HH:mm
            return `${sumHours}:${sumMinutes.toString().padStart(2, '0')}`;
        };
        $.each(columnModel, function (i, v) {
            $.each(colModel, function (ii, val) {
                if (v['dataIndx'] == val['dataIndx']) {
                    v.width = val['minWidth']
                }

                if (Array.isArray(totalFields) && totalFields.length > 0) {
                    if (totalFields.includes(v['dataIndx'])) {
                        // Initialize time detection flag
                        let isTimeColumn = false;
                        let timeRegex = /^([01]?\d|2[0-3]):([0-5]\d)$/;

                        // Check the first few values in this column to detect time format
                        let dataModel = grid.option("dataModel").data;
                        for (let i = 0; i < dataModel.length && i < 5; i++) {  // Check up to 5 values for type detection
                            let value = dataModel[i][v['dataIndx']];
                            if (typeof value === "string" && timeRegex.test(value)) {
                                isTimeColumn = true;
                                break;
                            }
                        }

                        // Assign appropriate summary type based on data type
                        v.summary = isTimeColumn
                            ? { type: 'timeSum' }  // Use custom 'all' aggregate for time columns
                            : { type: 'sum' }; // Use normal sum for numeric columns
                    }
                }

                if (excludeColumn && excludeColumn.indexOf(v['dataIndx']) != -1) {
                    v.hidden = true;
                }
                if (headerText && v.hasOwnProperty('dataIndx')) {
                    const dataIndx = v['dataIndx'];
                    const foundItem = headerText.find(item => Object.keys(item)[0] === dataIndx);

                    if (foundItem) {
                        v.title = foundItem[dataIndx];
                    }
                }

                if (widthOfColumn && v.hasOwnProperty('dataIndx')) {
                    const dataIndx = v['dataIndx'];
                    const foundItem = widthOfColumn.find(item => Object.keys(item)[0] === dataIndx);

                    if (foundItem) {
                        v.width = foundItem[dataIndx];
                        v.minWidth = foundItem[dataIndx];
                    }
                }
            });
        });

        if (_lastSerialNo > 0) {
            grid.option('numberCell', { show: true, width: calculateColumnWidthForPQGridSerialNumber(_lastSerialNo) })
        }

        if (totalFields.length > 0) {
            updateGrandSummary(grid, totalFields);
        }

        grid.refresh();
        grid.refreshView();



        /* column width code block end*/

        var gridManagerElm = $(element).next('.btn-pq-grid-grid-manager');
        if (_controlName != null && _controlName != '') {
            if (_controlName) grid.option("ControlName", _controlName);
            $(gridManagerElm).unbind().bind("click", handleConfigGridClick(gridManagerElm, _controlName, $(element)));
            if (gridManagerElm != null) $(gridManagerElm).show();
        }
        else {
            if (gridManagerElm != null) gridManagerElm.hide();
        }

        if (typeof postRenderFunction === 'function') {
            // Call the postRenderFunction
            postRenderFunction();
        }
    }, 0.1)
}
function nimbleRefreshGrid(element, options) {
    var dataModel = {
        location: "remote",
        method: "POST",
        dataType: "JSON",
        postData: options.payload == undefined ? [] : options.payload,
        url: options.url,
        getData: function (_response) {
            if (!isJSONData(_response) || _response == null || (_response.StatusType && (_response.StatusType == "error" || _response.StatusType == "warning"))) {
                const message = _response.Message || "Unable To Load Data!!";
                const statusType = _response.StatusType;
                const title = _response.Title || "Data Load Error";
                const clientMessage = { title: title, type: statusType, content: message };
                //const clientMessage = { title: _response.Title || "Data Load Error", type: _response.StatusType, content: _response.Message || "Unable To Load Data!!" };
                window.UIToastr.init(clientMessage);
                _response = JSON.parse(`
                {
                    "SUCCESS": "success",
                    "ERROR": "error",
                    "WARNING": "warning",
                    "IsWarning": false,
                    "IsError": false,
                    "IsSuccess": false,
                    "GetResponseStatus": 0,
                    "Object": [
                        [["SN","NO_RESULT"], [0,"${message}"]],
                        {
                            "CurrentPage": "1",
                            "NextPage": "0",
                            "TotalItems": "0",
                            "SortOrder": "DESC",
                            "SortIcon": "fa-sort-asc",
                            "ColumnName": "NO_RESULT",
                            "DataTypes": "string",
                            "WidthOfColumn":"1200"
                        }
                    ],
                    "StatusCode": 0,
                    "Message": "${message}",
                    "StatusType": "${statusType}",
                    "Title": "${title}"
                }`);
            }

            let _res = processDataForPQGrid(_response.Object, options.useCheckBox, options.useCheckBox ? 'NI_CHECKBOX' : '', options.columnModifyAndRender, options.filterSkipColumns);
            let colModel = getSetExistingColModel(options.gridElement, _res._col);

            // Process Custom Report data for reporting module 
            _response.Object.forEach(obj => {
                if (obj.CustomReportData != null) {
                    let customData = obj.CustomReportData;
                    for (let key in customData) {
                        if (Object.prototype.hasOwnProperty.call(customData, key)) {
                            let id = decodeURIComponent(key); // Decode URL component
                            let element = document.getElementById(id);
                            if (element) {
                                if ($(element).is('input')) {
                                    $(element).val(customData[key]);
                                } else if ($(element).is('textarea')) {
                                    $(element).val(customData[key]);
                                } else if ($(element).is('span')) {
                                    $(element).append(customData[key]);
                                } else {
                                    console.log(`Element with ID '${id}' is neither an input field nor a textarea nor a span.`);
                                }
                            }
                        }
                    }
                }
            });

            let groupModel = {};
            let totalFields = [];
            var gridSummary = _response.Object[1];
            if (gridSummary) {
                if (gridSummary.TotalFields) {
                    totalFields = gridSummary.TotalFields.split(',');
                }

                if (gridSummary.GroupingColumns) {
                    groupModel = {
                        on: true,
                        dataIndx: gridSummary.GroupingColumns.split(','),
                        collapsed: [true],
                        merge: true,
                        title: [],
                    };
                }

                var customNimbleData = this.option('customNimbleData');

                if (customNimbleData && gridSummary.TotalFields && gridSummary.GroupingColumns.length == 0) {
                    customNimbleData.niSummaryOptions.isEnableTotalFieldsSummary = true;
                    customNimbleData.niSummaryOptions.totalSummaryIndexes = totalFields;
                }

                if (gridSummary.manualFreezeColumn != null) {
                    options.manualFreezeColumn = gridSummary.manualFreezeColumn;
                }
                if (gridSummary.excludeColumn != null && gridSummary.excludeColumn != "") {
                    options.excludeColumn = gridSummary.excludeColumn;
                }
                if (gridSummary.widthOfColumn != undefined) {

                    if (gridSummary.widthOfColumn != null && gridSummary.widthOfColumn.length > 0) {
                        options.widthOfColumn = gridSummary.widthOfColumn;
                    } else {
                        options.widthOfColumn = colModel.map(col => ({ [col.dataIndx]: 100 }));
                        //options.widthOfColumn = colModel.filter(col => col.dataType === "date").map(col => ({ [col.dataIndx]: 100 }));
                    }
                }
                if (gridSummary.headerText != null && gridSummary.headerText.length > 0) {
                    options.headerText = gridSummary.headerText;
                }
            }

            handlePqGirdFreezeAndColWidth(_res._freezeColIndex, options.gridElement, colModel, options.postRenderFunction, options.manualFreezeColumn, options.excludeColumn, options.headerText, options.widthOfColumn, _res._controlName, _res._lastSerialNo, groupModel, totalFields);
            return { freezeColIndex: _res._freezeColIndex, curPage: _res._pager.curPage, totalRecords: _res._pager.totalRecords, data: _res._data };
        },
        error: function (jqXHR, textStatus, errorThrown) {
            if (textStatus !== "abort") { showClientMsg("Error Occured!", "error", "Data Load Error"); }
        }
    };

    var gridObject = {
        dataModel: dataModel,
        sortModel: { type: 'remote', single: true, space: true, multiKey: null },
        numberCell: { show: false },
        flex: { one: true },
        wrap: options.wrap ? options.wrap : false, // Grid data except column wrap
        hwrap: options.hwrap ? options.hwrap : false, // Column Header Wrap
        showTitle: false,
        resizable: true,
        rowBorders: true,
        columnBorders: true,
        onRowClick: options.onRowClick,
        collapsible: { on: false, collapsed: false, toggle: true, css: { zIndex: 1050 } },
        showTop: options.showToolbar, // hide toolbar present avobe column header (maximize, toogle)
        bootstrap: { on: true },
        virtualX: false, virtualY: true,
        filterModel: { on: true, mode: "AND", header: false, type: 'remote' },
        numberCell: { show: true },
        height: SetPqGridHeight(),
        cellClick: function (event, ui) {
            var $container = $(options.gridElement).find('#_pq-grid-summ-container');
            $container.hide();
            var dataIndx = ui.dataIndx;

            var numericDataType = {
                'float': 'float',
                'integer': 'integer',
                'int': 'int'
            };

            var sum = 0;
            var sumOutputString = "";
            var isSumCalculated = false;
            if (numericDataType[ui.column.dataType]) {
                isSumCalculated = true;
                var dataModel = this.options.dataModel.data;

                for (var i = 0; i < dataModel.length; i++) {
                    var value = dataModel[i][dataIndx];
                    if (value && !isNaN(value)) {
                        sum += parseFloat(value);
                    }
                }
                sumOutputString = !isNaN(parseFloat(sum)) ? handleFormatNumber(sum) : "";
                

            } else if (options.sumTimeColumns && options.sumTimeColumns.length > 0) {
                if (options.sumTimeColumns.indexOf(ui.dataIndx) != -1) {
                    isSumCalculated = true;
                    var dataModel = this.options.dataModel.data;
                    var sumHours = 0;
                    var sumMinutes = 0;
                    for (var i = 0; i < dataModel.length; i++) {
                        var value = dataModel[i][dataIndx];
                        var timeRegex = /^([01]\d|2[0-3]):([0-5]\d)$/;
                        if (timeRegex.test(value)) {
                            var timeParts = value.split(":");
                            sumHours += parseInt(timeParts[0]);
                            sumMinutes += parseInt(timeParts[1]);
                        }

                    }
                    sumHours += Math.floor(sumMinutes / 60);
                    sumMinutes = sumMinutes % 60;

                    sumOutputString = `${sumHours}:${sumMinutes}`;
                }
            }
            if (isSumCalculated) {

                $(options.gridElement).find('#_pq-grid-summ-element').text(sumOutputString);
                $container.show();

                if (options.fadeOutTimeout) {
                    clearTimeout(options.fadeOutTimeout);
                }
                options.fadeOutTimeout = setTimeout(function () {
                    $container.fadeOut();
                }, 5000);
            }
        },
        create: function (evt, ui) {
            this.widget().pqTooltip();
        },
        editModel: {
            pressToEdit: true,
            clicksToEdit: 2,
            invalidClass: 'pq-invalid-cell'
        },
        complete: function (event, ui) {
            if (this.options.filterModel.header) $(document).find(options.gridElement).find('.NI_CHECKBOX_HEADER').css({ 'visibility': 'visible' });
            if (typeof options.callbackFunctionAfterComplete === 'function') {
                options.callbackFunctionAfterComplete(options.gridElement);
            }
            if (window.PqGridlastFocusedInputName) {
                setTimeout(() => {
                    const input = $(options.gridElement).find(`.pq-grid-hd-search-field[name="${window.PqGridlastFocusedInputName}"]`);
                    if (input.length) {
                        for (let i = 0; i < input.length; i++) {
                            input[i].focus();
                            const val = input.val();
                            input[i].setSelectionRange(val.length, val.length);
                        }
                    }
                }, 0);
            }
        },
        selectionModel: { all: false },
        colModel: options.useCheckBox ? [{
            dataIndx: 'NI_CHECKBOX',
            align: "center",
            title: "",
            width: 10,
            cb: { header: true, select: true, all: true },
            type: 'checkbox',
            cls: 'ui-state-default',
            dataType: 'bool',
            editor: false,
            sortable: false
        }] : []
    }

    if (options.complete) { gridObject.complete = options.complete }
    if (options.cellSave) { gridObject.cellSave = options.cellSave }
    if (options.isLocalFilter) { gridObject.filterModel.type = "local" }
    if (options.hasOwnProperty('virtualX')) {
        gridObject.virtualX = options.virtualX;
    }
    if (options.hasOwnProperty('virtualY')) {
        gridObject.virtualY = options.virtualY;
    }
    if (typeof options.beforeTableView === 'function') {
        gridObject.beforeTableView = function (event, ui) {
            options.beforeTableView();
        };
    }
    if (options.hasOwnProperty('isSortTypeLocal')) {
        gridObject.sortModel.type = options.isSortTypeLocal ? 'local' : 'remote'
    }
    if (options.groupModel) { gridObject.groupModel = options.groupModel }
    if (options.gridHeight) { gridObject.height = options.gridHeight }
    if (options.showToolbar) {
        gridObject.toolbar = options.toolbar;
        gridObject.toolbar.items.push({
            type: function () {
                return '<span id="_pq-grid-summ-container" style="display:none;position: absolute;right: 0;margin-right: 59px;"><b>Sum: <span id="_pq-grid-summ-element">0.00</span></b></span>'
            }
        })
    };
    if (options.isPaginationEnable) {
        var rPP = options.defaultPageSize ? options.defaultPageSize : 35;
        var rPPOptions = [35, 100, 200, 500, 1000, 5000, 10000];

        // Add rPP to rPPOptions if numeric and not already present, then sort
        if (!isNaN(rPP) && !rPPOptions.includes(rPP)) {
            rPPOptions.push(rPP);
            rPPOptions.sort((a, b) => a - b);
        }

        if ($(element).hasClass('pq-grid')) {
            var prevPageModal = $(element).pqGrid('option', 'pageModel');
            if (prevPageModal && prevPageModal.rPP) rPP = prevPageModal.rPP;
        }

        gridObject.pageModel = { type: options.isLocalPagination ? "local" : "remote", rPPOptions: rPPOptions, rPP: rPP, strRpp: "{0}" };
    }

    gridObject.customNimbleData = {
        niSummaryOptions: {
            isEnableTotalFieldsSummary: false,
            totalSummaryIndexes: []
        }
    }

    gridObject.filter = function (event, ui) {
        var customNimbleData = this.option('customNimbleData');
        if (customNimbleData && customNimbleData.niSummaryOptions.isEnableTotalFieldsSummary) {
            updateGrandSummary(this, customNimbleData.niSummaryOptions.totalSummaryIndexes);
        }
    }
    var grid = $(element).hasClass('pq-grid') ? $(element).pqGrid("destroy").pqGrid(gridObject) : $(element).pqGrid(gridObject);
    return {
        grid: grid
    }
}
function calculateColumnWidthForPQGridSerialNumber(lastSerialNumber, baseWidth = 39, incrementWidth = 1) {

    if (lastSerialNumber <= 100) return 25
    else if (lastSerialNumber > 100 && lastSerialNumber <= 500) return 28
    else if (lastSerialNumber > 500 && lastSerialNumber <= 9999) return 37;
    const digits = lastSerialNumber.toString().length;

    const additionalWidth = (digits > 4) ? (digits - 4) * incrementWidth : 0;

    const totalWidth = baseWidth + additionalWidth;

    return totalWidth;
}

function pqGridGetControlName(gridElement) {
    return $(gridElement).pqGrid("option", 'ControlName');
}
function pqDatePicker(ui) {
    var $this = $(this);

    $this.datepicker({
        //yearRange: "-25:+0", //25 years prior to present.
        changeYear: true,
        dateFormat: 'yyyy/MM/dd',
        changeMonth: true,
        //showButtonPanel: true,
        onClose: function (evt, ui) {
            $(this).focus();
        }
    });
}


