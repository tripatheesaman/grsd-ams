var wordDocumentPreviewer = function (container, fileBase64String) {
    var docxOptions = Object.assign(docx.defaultOptions, {
        className: string = "_preview_document_container", //class name/prefix for default and document style classes
        inWrapper: boolean = true, //enables rendering of wrapper around document content
        ignoreWidth: boolean = false, //disables rendering width of page
        ignoreHeight: boolean = false, //disables rendering height of page
        ignoreFonts: boolean = true, //disables fonts rendering
        breakPages: boolean = true, //enables page breaking on page breaks
        ignoreLastRenderedPageBreak: boolean = true, //disables page breaking on lastRenderedPageBreak elements
        experimental: boolean = true, //enables experimental features (tab stops calculation)
        trimXmlDeclaration: boolean = true, //if true, xml declaration will be removed from xml documents before parsing
        useBase64URL: boolean = false, //if true, images, fonts, etc. will be converted to base 64 URL, otherwise URL.createObjectURL is used
        useMathMLPolyfill: boolean = true, //includes MathML polyfills for chrome, edge, etc.
        showChanges: true, //enables experimental rendering of document changes (inserions/deletions)
        debug: boolean = false, //enables additional logging
    });
    var byteArray = base64ToArrayBuffer(decodeHTMLEntities(fileBase64String));
    if (!byteArray)
        return;
    docx.renderAsync(byteArray, container, null, docxOptions);
}

function base64ToArrayBuffer(base64) {
    var binaryString = window.atob(base64);
    var binaryLen = binaryString.length;
    var bytes = new Uint8Array(binaryLen);
    for (var i = 0; i < binaryLen; i++) {
        var ascii = binaryString.charCodeAt(i);
        bytes[i] = ascii;
    }
    return bytes;
}
function decodeHTMLEntities(text) {
    let textArea = document.createElement('textarea');
    textArea.innerHTML = text;
    return textArea.value;
}

jQuery.validator.addMethod("noSpace", function (value, element) {

    var isValid = value == '' || value.trim().length != 0;
    if (!isValid) {
        $(element).val('');
    } else {
        value = value.replace(/\s+/g, ' ');
        $(element).val(value.trimStart());
    }
    return isValid;
}, "No space please and don't leave it empty");

// PQ Grid Changes
getPqGridEquivalentDataType = function (dataType) {
    if (dataType == null || dataType == undefined) return "string";
    switch (dataType) {
        case 'string':
            return 'string';
        case 'int':
            return 'int';
        case 'float':
            return 'float';
        case 'bool':
            return 'bool';
        case 'date':
            return 'date';
        case 'decimal':
            return 'float';
        default:
            return "string";
    }
}


function getEquivalentCondition(condition, dataType, value1, value2) {
    if (!dataType) return "";
    if (!condition) {
        if (dataType === "date" && value1 && value2) return "IsBetween";
        else if (dataType === "date" && value1 && !value2) return "LessThan";
        else if (dataType === "date" && !value1 && value2) return "GreaterThan";
        else return "";
    }

    switch (condition) {
        case "begin":
            return "StartWith";
        case "contain":
            return "Contains";
        case "notcontain":
        case "notequal":
        case "notempty":
        case "range":
        case "regexp":
        case "notbegin":
        case "notend":
            return "";
        case "equal":
            return "Equals";
        case "empty":
            return "Empty";
        case "end":
            return "EndWIth";
        case "less":
        case "lte":
            return "LessThan";
        case "great":
        case "gte":
            return "GreaterThan";
        case "between":
            if (dataType === "date" && value1 && value2) return "IsBetween";
            else if (dataType === "date" && value1 && !value2) return "LessThan";
            else if (dataType === "date" && !value1 && value2) return "GreaterThan";
            return "IsBetween";
        case "bool":
            return "true";
        case "date":
            if (dataType === "date" && value1 && value2) return "IsBetween";
            else if (dataType === "date" && value1 && !value2) return "LessThan";
            else if (dataType === "date" && !value1 && value2) return "GreaterThan";
            return "Contains";
        default:
            return "";
    }
}


getPqGridFilterObject = function (dataType, condition = null) {
    if (dataType == null || dataType == undefined) return { type: 'string', condition: condition != null ? condition : 'contain', listeners: ['change'] };
    switch (dataType) {
        case 'int':
            return { type: 'textbox', condition: condition != null ? condition : 'equal', listeners: ['change'] }
        case 'float':
            return { type: 'textbox', condition: condition != null ? condition : 'equal', listeners: ['change'] }
        case 'string':
            return { type: 'textbox', condition: condition != null ? condition : 'contain', listeners: ['change'] }
        case 'bool':
            return {
                type: 'select',
                condition: 'equal',
                options: [
                    { '': 'All' },
                    { 'true': 'Yes' },
                    { 'false': 'No' }
                ],
                listeners: ['change']
            }
        case 'date':
            return { type: 'textbox', condition: "between", init: pqDatePicker, listeners: ['change'], format: 'yyyy/MM/dd' }

        default:
            return { type: 'textbox', condition: condition != null ? condition : 'contain', listeners: ['change'] }
    }
}

var _NIPQGRIDS = [];
function processDataForPQGrid(data, isAddCheckBoxSelection, checkBoxIndex, customColumns, filterSkipColumns) {
    let _processGridData = {
        _col: [],
        _data: [],
        _pager: {},
        _freezeColIndex: -1,
        _lastSerialNo: -1
    };
    let _filterSkipColumns = [];
    if (filterSkipColumns) _filterSkipColumns = filterSkipColumns.split(',');

    let _columnNames = data[1]["ColumnsName"] ? data[1]["ColumnsName"].split(',') : data[0][0];
    let _columnDisplayName = data[0][0];
    let _columnDataType = data[1].DataTypes.split(',');
    let _columnWidth = data[1].WidthOfColumn == undefined ? [] : data[1].WidthOfColumn.split(',');
    let _columnFrozenStatus = data[1].IsFrozen == undefined ? [] : data[1].IsFrozen.split(',');
    let _renderColumns = customColumns;

    let _controlName = data[1].ControlName;
    var _type;

    if (data && data.length > 1 && data[1] && typeof data[1].type !== 'undefined') {
        _type = data[1].type;
        if (_type > 2) {
            _controlName = '';
        }
    }

    let _responseData = data[0];
    let snIndex = _columnNames.indexOf('SN');
    if (snIndex != -1 && _responseData.length > 0) {
        _processGridData._lastSerialNo = _responseData[_responseData.length - 1][snIndex];
    }

    _processGridData._pager.curPage = data[1].CurrentPage;
    _processGridData._pager.totalRecords = data[1].TotalItems;

    let _tmpColm = {};
    let _tempColumnsData = [];
    if (isAddCheckBoxSelection) {
        _tempColumnsData.push({
            maxWidth: 50, minWidth: 50,
            title: "<input type='checkbox' class='NI_CHECKBOX_HEADER'  />",
            align: 'center',
            resizable: false,
            dataIndx: checkBoxIndex, type: 'checkbox', cb: { header: true, all: true }, dataType: 'bool', editor: false, sortable: false,
            render: function (ui) {
                return `<input type="checkbox" class='NI_CHECKBOX'  ${ui.rowData[checkBoxIndex] ? 'checked' : ''} />`
            },


        });


    }
    $.each(_columnNames, function (i, v) {
        if (isAddCheckBoxSelection && v == 'SN') return;
        _tmpColm = {};
        _tmpColm.title = _columnDisplayName[i];
        _tmpColm.dataIndx = v;
        _tmpColm.hidden = v == 'SN' ? true : false;
        _tmpColm.minWidth = 130;
        _tmpColm.editable = false;

        $.each(_columnDataType, function (ii, vv) {
            if (ii == i) {
                _tmpColm.dataType = getPqGridEquivalentDataType(vv);
                if (_tmpColm.dataType == 'float') {
                    _tmpColm.format = "####.00";
                    _tmpColm.align = 'right'
                }
                else if (_tmpColm.dataType == 'int') {
                    _tmpColm.align = 'right'
                }
                /* _tmpColm.filter = getPqGridFilterObject(vv, null)*/
                if (_filterSkipColumns.length === 0) {
                    _tmpColm.filter = getPqGridFilterObject(vv, null);
                } else {
                    if (!_filterSkipColumns.includes(v)) {
                        _tmpColm.filter = getPqGridFilterObject(vv, null);
                    }
                }

            }
        });

        $.each(_columnWidth, function (iii, vvv) {
            if (iii + 1 == i) {
                _tmpColm.width = parseFloat(vvv)
                _tmpColm.minWidth = parseFloat(vvv)
                _tmpColm.hidden = parseFloat(vvv) == 1;
            }
        });

        $.each(_renderColumns, function (iv, vvvv) {
            if (vvvv.column == v) {
                if (vvvv.align) _tmpColm.align = vvvv.align
                _tmpColm.render = vvvv.render;
            }
        });
        //console.log(_columnFrozenStatus, _columnNames);
        $.each(_columnFrozenStatus, function (ii, vv) {
            if (ii + 1 == i && vv == '1') {
                _processGridData._freezeColIndex = parseFloat(ii + 1) + 1
            }
        });
        if (_tmpColm.dataType == 'date') {
            _tmpColm.width = _tmpColm.width || 100//_tmpColm.dataType == 'date' ? 200 : _tmpColm.width;
            _tmpColm.minWidth = _tmpColm.width || 100//_tmpColm.dataType == 'date' ? 200 : _tmpColm.width;
            _tmpColm.format = "yy/mm/dd"
        }
        _tempColumnsData.push(_tmpColm);
    });

    _processGridData._col = _tempColumnsData;
    _processGridData._controlName = _controlName;

    let _tmpData = {};
    $.each(_responseData, function (idx, v) {
        _tmpData = {};
        //if (isAddCheckBoxSelection) _tmpColm[checkBoxIndex] = false;
        if (idx == 0) return true;
        $.each(_processGridData._col, function (i, val) {
            if (val.dataIndx == checkBoxIndex) _tmpData[val.title] = v[i]
            else _tmpData[val.dataIndx] = v[i]
        });
        _processGridData._data.push(_tmpData);
    });
    return _processGridData
}

function getSetExistingColModel(girdElement, colData) {
    let $grid = $(girdElement)
    if ($grid.hasClass('pq-grid')) {
        let oldColModel = $grid.pqGrid('getColModel');
        $.each(colData, function (index, item1) {
            let matchingItem = $.grep(oldColModel, function (item2) {
                return item2.dataIndx === item1.dataIndx;
            })[0];
            if (matchingItem && matchingItem.hasOwnProperty('filter')) {
                $.extend(item1, { filter: matchingItem.filter });
            }
        });
        return colData;
    }

    return colData;
}
var handleBlockUiForTable = function (selector) {
    $.blockUI.defaults.css = {};
    return $(selector).block({
        message:
            '<div class="loading-spinner" style="width: 200px; margin-left: -100px;"><div class="progress progress-striped active" style="height:15px;"><div class="progress-bar" style="width: 100%;"></div></div></div>',
        backgroundColor: "#000000",
        opacity: .4,
        theme: false,
        showOverlay: true,
        blockMsgClass: "blockMsg",
        css: {
            padding: 0,
            margin: 0,
            width: '30%',
            top: '40%',
            left: '35%',
            textAlign: 'center',
            color: '#000',
            backgroundColor: '#000000',
            cursor: 'wait'
        }
    });
};
var handleAddButtonClickOfSelection = function ($sender, config, $elem) {
    $sender.off("click").on("click", function (e) {
        //var controlNameSs = $($elem).data("controlName");
        e.preventDefault();
        var data = $("#hands-on-table-selection").data("nimble");
        var hotInst = data.getInstance();
        var countSourceRows = hotInst.countRows();
        var options = $("#hands-on-table-selection").data("options");
        handleBlockUiForTable(options.mainContainer);
        var colData = hotInst.getData();
        var allData = data.getDataWithHeader();
        for (var i = 0; i < countSourceRows; i++) {
            var rowData = colData[i][2];
            if (rowData === config.orderByCol) {
                if (colData[i][0]) {
                } else {
                    var test = [true, config.controlName, config.orderByCol, config.orderByCol, null, 100, false, null];
                    allData.push(test);
                }
            }
        }
        var $form = $("#common-gridmanager-form");

        setTimeout(function () {
            const postData = JSON.stringify({
                Filter: allData
            });

            $.post($form.attr("action"), { postData }, function (data, status) {
                if (status === "success") {
                    var clientMessage = { title: data.Title, type: data.StatusType, content: data.Message };
                    if (clientMessage.type === "success") {
                        $elem.pqGrid('refreshDataAndView')
                        window.UIExtendedModals.hide();
                    }

                    window.UIToastr.init(clientMessage);
                    $('.btnSave').button('reset');
                    $(options.mainContainer).unblock();
                }
            });
        }, 300);
        $sender.unbind().bind("click", handleAddButtonClickOfSelection($sender, config, $elem));
        return false;
    });
};
var handleGridManagerBsModal = function (selector, formName, config, $elem) {
    var $form = $("#" + formName);
    $form.on("submit", function (e) {
        e.preventDefault();
        $('body').modalmanager('loading');
        var dataWidth = $(selector).attr("data-width");
        const dataUrl = selector.attr("data-url");

        var action = selector.attr("data-action");
        var width = dataWidth === null && dataWidth === undefined ? '60%' : dataWidth;
        window.UIExtendedModals.init({
            width: width,
            content: dataUrl,
            contentPlaceHolder: $("#modal-popup"),
            modal$elem: $("#modal-popup"),
            fillContent: true,
            usingAjax: true,
            data: $form.serialize(),
            afterPopupOpen: function () {
                window.handelPickerAfterBsModalPopUpOpen();
                setTimeout(function () {
                    if (action === "configGrid") {
                        const configs = {
                            url: '/CoreExtension/GridManager/LoadSelection',
                            paramsData: { "data": config.data, "controlName": config.controlName, "orderByCol": config.orderByCol },
                            useCheckBox: true,
                            mainContainer: $(".selection"),
                            formType: "Index",
                            pageWraper: $(".paging-wrappersss"),
                            widthOfColumn: [{ IsFrozen: 125 }, { SN: 50 }, { CustomColumnName: 280 }, { ColumnName: 200 }],
                            excludeColumn: ["ControlName", "Ordinal", "Sort"],
                            cellsModifyAndRender: function (row, col, prop, header, cellProperties, hotInstance, columnName) {
                                cellProperties.readOnly = true;
                                if (header[col] === "IsFrozen") {
                                    cellProperties.readOnly = true;
                                    cellProperties.data = "IsFrozen";
                                    var checkInput = '<input type="radio" name="IsFrozen" class="htCenter htMiddle radio"';
                                    checkInput += ` data-rows="${row}" data-cols="${col}"`;
                                    cellProperties.renderer = function (instance, td, rows, cols, props, values, cellPropertiess) {

                                        window.Handsontable.renderers.CheckboxRenderer.apply(this, arguments);
                                        checkInput += values === true ? "checked='checked'" : "";
                                        checkInput += `value="${values}"`;
                                        checkInput += ' />'
                                        td.innerHTML = checkInput;
                                        td.style.textAlign = 'center';
                                    }
                                }
                                if (header[col] === "ColumnWidth") {
                                    cellProperties.readOnly = false;
                                    cellProperties.editor = "text";
                                }
                                if (header[col] === "CustomColumnName") {
                                    cellProperties.readOnly = false;
                                }
                            },
                            afterSelectionEndProp: function (r, p, r2, p2, instance) {

                                const ele = this;
                            },
                            changeDataRow: function (data, header, instance, changes, source) {
                                const ele = this;
                                if (source !== 'loadData') {
                                }
                            },
                            manualRowMove: true,
                            isEditAble: true,
                            autoColumnSize: false,
                            onRowClick: "SN",
                            radionButton: false
                        }
                        $("#hands-on-table-selection").selectionAppModel(configs);
                        handleAddButtonClickOfSelection($(".btnAdd-Sellection"), config, $elem);
                    }
                }, 200);
            },
            afterPopupClose: function () {
                width = "";

            }
        });
        $form.unbind().bind("submit");
    });
    $form.submit();
    return true;
}

var handleConfigGridClick = function ($sender, controlName, $elem) {
    $sender.off("click").on("click", function (e) {
        e.preventDefault();
        var configGrid = {
            url: void 0,
            loadParameter: void 0,
            controlName: controlName,
            GridDataSource: void 0,
            GridParameter: void 0,
            GridTitle: void 0,
            data: void 0,
            orderByCol: void 0
        }
        //var controlNameSs = $($elem).data("controlName");
        var config = {
            url: void 0,
            loadParameter: void 0,
            controlName: controlName,
            GridDataSource: void 0,
            GridParameter: void 0,
            GridTitle: void 0,
            data: void 0,
            orderByCol: void 0
        }
        $.ajax({
            url: '/CoreExtension/GridManager/ManageGrid?controlName=' + controlName,
            success: function (data) {
                config.url = data.GridDataSource;
                config.loadParameter = data.GridParameters;
                var urlWithParam = config.url;
                urlWithParam = urlWithParam.split("/");
                var parameter;
                if (config.loadParameter === undefined || config.loadParameter === null) {
                    parameter = "";
                } else {
                    parameter = config.loadParameter;
                }
                var preparedUrl = "/" + urlWithParam[1] + "/" + urlWithParam[2] + "/Load" + parameter;
                $.ajax({
                    url: preparedUrl,
                    error: function (error) { },
                    success: function (success) {
                        var obj = success;
                        config.data = obj.Object[0];
                        config.orderByCol = obj.Object[1].ColumnName;
                    }, complete: function (complete) { }
                });
                $.extend(configGrid, config);

                handleGridManagerBsModal($sender, 'submit_udsel', config, $elem);
            },
            complete: function (complete) { }
        });

        $sender.unbind().bind("click", handleConfigGridClick($sender, controlName, $elem));
        return false;
    });
};

function updateGrandSummary(grid, totalFields) {
    if (Array.isArray(totalFields) && totalFields.length > 0) {
        const gridData = grid.option("dataModel.data");
        const grandSummary = {};

        // Initialize total structure
        totalFields.forEach(field => {
            grandSummary[field] = {
                isTime: false,  // To identify if the column is a time column
                totalHours: 0,
                totalMinutes: 0,
                numericTotal: 0 // For numeric sums
            };
        });
        // Iterate over each row to calculate totals
        for (let i = 0, len = gridData.length; i < len; i++) {
            const row = gridData[i];

            totalFields.forEach(field => {
                let value = row[field];

                const timeRegex = /^([01]?\d|2[0-3]):([0-5]\d)$/;

                if (typeof value === 'string' && timeRegex.test(value)) {
                    const [hours, minutes] = value.split(":").map(Number);
                    grandSummary[field].isTime = true;
                    grandSummary[field].totalHours += hours;
                    grandSummary[field].totalMinutes += minutes;

                    // Capture first match

                } else if (!isNaN(value)) {
                    grandSummary[field].numericTotal += parseFloat(value);

                }
            });

        }

        // Finalize totals for grand summary
        // Format grandSummary fields
        totalFields.forEach(field => {
            const { isTime, totalHours, totalMinutes, numericTotal } = grandSummary[field];

            if (isTime) {
                const totalHoursFinal = totalHours + Math.floor(totalMinutes / 60);
                const totalMinutesFinal = totalMinutes % 60;
                grandSummary[field] = `${totalHoursFinal}:${totalMinutesFinal.toString().padStart(2, '0')}`;
            } else {
                // Just store plain value here, HTML will be injected via render
                grandSummary[field] = !isNaN(parseFloat(numericTotal)) ? handleFormatNumber(numericTotal) : "";

            }
        });
        //grandSummary['TotalReportings'] = 'Total';
        grandSummary['label'] = "Grand Total";

        // Apply summary
        grid.option("showSummary", true);
        grid.option("summaryData", [grandSummary]);
        grid.option("summaryTitle", '{ avg: "{0}", count: "{0}", max: "{0}", min: "{0}", sum: "{0}"}');

        // Modify column model for bold display
        const columnModel = grid.getColModel();

        let firstColumnIndex = null;
        var firstFieldData = totalFields[0];
        if (firstFieldData) {
            firstColumnIndex = columnModel.findIndex(col => col.dataIndx === firstFieldData);
            firstColumnIndex = firstColumnIndex - 1;
            const column = columnModel.find(col => col.leftPos === firstColumnIndex);
            grandSummary[column.dataIndx] = '<b> Total </b>'
        }

        totalFields.forEach(field => {
            const column = columnModel.find(col => col.dataIndx === field);
            if (column) {
                if (!firstColumnIndex) {
                    firstColumnIndex = column.leftPos - 1;
                }
                column.align = 'right';
                column.render = function (ui) {
                    //console.log(ui.rowData, "roe data")
                    if (ui.rowData?.label === "Grand Total") {
                        return {
                            text: `<b>${ui.cellData}</b>`,
                            cls: 'pq-align-right'
                        };
                    }
                    return ui.cellData;
                };
            }
        });

        // Rebind updated colModel
        grid.option("colModel", columnModel);
        grid.refresh();

    }
}

