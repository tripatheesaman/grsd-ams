    return false;
};

var addTableRow = function (table, url) {
    var ul = $(table).find("tbody tr:first");
    $.ajax({
        url: url,
        success: function (html) {
            $(html).appendTo($(table).find("tbody")); //Pending check binding events. not working now.          
            var form = ul.closest('form');
            form.removeData('validator');
            form.removeData('unobtrusiveValidation');
            $.validator.unobtrusive.parse(form);
        }
    });
    return false;
}

//================================================================================
// Generic Add More Functions End
//================================================================================

var showDialog = function (link, title, isFooter) {
    var url = link.href;
    if (title == null) {
        title = link.text;
    }

    var dialogResult = cmsCoreScript.ajaxRequest(url);
    dialogResult.done(function (data) {
        $(".modal-title").html(title);
        $(".modal-body").html(data);
        if (isFooter == false) {
            $(".modal-footer").css({ "display": "none" });
        }
        $("#myModal").modal("show");
    }).fail(function () {
        return false;
    })
    return false;
}

var QueryString = function (param) {
    const url = window.location.href.slice(window.location.href.indexOf("?") + 1).split("&");
    for (let i = 0; i < url.length; i++) {
        const urlparam = url[i].split("=");
        if (urlparam[0] === param) {
            return urlparam[1];
        }
    }
}

var disableIndivisualAutocompleteByElementId = function (elementId) {
    $("#token-input-" + elementId).parent('li').siblings().find("span.token-input-delete-token-facebook").text("");
    $("#token-input-" + elementId).parent('li').parent("ul.token-input-list-facebook").css({
        "border-color": "#fff",
        "border-width": "1px",
        "border-style": "solid"
    });
}

var enableDisableAutoComplete = function () {
    var fieldSet = $("fieldset").attr("disabled");
    if (fieldSet === "disabled") {
        $("li.token-input-token-facebook").find("span.token-input-delete-token-facebook").text("");
        $("ul.token-input-list-facebook").css({
            "border-color": "#fff",
            "border-width": "1px",
            "border-style": "solid"
        });
    } else {
        $("li.token-input-token-facebook").find("span.token-input-delete-token-facebook").text("×");
        $("ul.token-input-list-facebook").css({
            "border-color": "#8496ba",
            "border-width": "1px",
            "border-style": "solid"
        });
    }
};

var handleActionButtonsClick = function (isCheckBox, isAllowMultiCheck) {
    let modalHtml = "<div class='modal fade'>" +
        "<div class='modal-header'>";
    modalHtml +=
        "<button type='button' class='close' data-dismiss='modal' aria-hidden='true'>×</button><h4 class='modal-title text-warning'><i class='fa fa-warning'></i> Attention!</h4>";
    if (isCheckBox) {
        if (isAllowMultiCheck === undefined) {
            modalHtml += "</div>" +
                "<div class='modal-body'><h4>Please Check at least one Checkbox to proceed this action. Thank you.</h4></div>" +
                "<div class='modal-footer'>";
        }
        else {
            modalHtml += "</div>" +
                "<div class='modal-body'><h4>Please check only one record to proceed this action. Thank you.</h4></div>" +
                "<div class='modal-footer'>";
        }
    } else {
        if (isAllowMultiCheck === undefined) {
            modalHtml += "</div>" +
                "<div class='modal-body'><h4> Please select a row to proceed this action. Thank you.</h4></div>" +
                "<div class='modal-footer'>";
        }
        else {
            modalHtml += "</div>" +
                "<div class='modal-body'><h4>Please select only one record to proceed this action. Thank you.</h4></div>" +
                "<div class='modal-footer'>";
        }
    }

    modalHtml += "<a data-dismiss='modal' class='btn btn-nim-sec'><i class='fa fa-close'></i> Close</a></div></div>";
    const custDialog = $.parseHTML(modalHtml);
    $(custDialog).modal("show");
    return false;
};

var GetSelectedEmpFromDataTable = function () {
    //Collecting checked nodes value and set in a variable with comma seperated
    var SelectedEmps = [];
    $("input:checked").each(function () {
        if ($(this).val() != 'on') {
            if (!SelectedEmps.includes($(this).val())) SelectedEmps.push($(this).val());
        }
    });

    //set checked collected value in a hidden control having id='Sel'
    $("#Sel").val(SelectedEmps.toString());
    if ($("#UDSel").length > 0)
        $("#UDSel").val(SelectedEmps.toString());
    if ($("#UDSelDel").length > 0)
        $("#UDSelDel").val(SelectedEmps.toString());

    return SelectedEmps;
}

var GetSelectedEmpFromHandsontableTable = function (element) {
    var SelectedEmps = $(element).data("nimble").getCheckedItem().toString();
    var mappedvalues = $(element).data("nimble").getMappedItems().toString();
    if ($('#MapSel').length > 0) {
        $("#MapSel").val(mappedvalues);
    }
    else if ($('#submit_udsel').length > 0) {
        input = jQuery("<input type='hidden' name='MapSel' id='MapSel'>");
        jQuery('#submit_udsel').append(input);
        $("#MapSel").val(mappedvalues);
    }

    $("#Sel").val(SelectedEmps);
    if ($("#UDSel").length > 0)
        $("#UDSel").val(SelectedEmps);
    if ($("#UDSelDel").length > 0)
        $("#UDSelDel").val(SelectedEmps);
    return SelectedEmps;
}

var handleBsModal = function (sender, formName, isCheckbox, $multiTableId, columnName, childContent, isPost, isMultipleWithoutCheckbox = false, isCheckboxAndAllowOnlyOneItem = false) {
    var $sender = $(sender);
    if ($sender !== null && $sender !== undefined) {
        var $parentDiv;
        if (!$multiTableId || typeof $multiTableId === "number" || typeof $multiTableId === "undefined") {
            $parentDiv = $($sender).parents().find("div.handsontable");
        } else {
            $parentDiv = $multiTableId; //$($sender).parents().find("div.handsontable");
        }
        $('body').modalmanager('loading');
        var $form = $("#" + formName);
        var className = $(sender).attr("class");
        var dataWidth = $(sender).attr("data-width");
        var dataAction = $($sender).attr("data-action");
        var udSel = $form.find('input#UDSel');
        var udSelDel = $form.find('input#UDSelDel');
        var mapSel;
        if ($form.find('input#MapSel').length > 0) {
            mapSel = $form.find('input#MapSel');
        }
        else {
            $form.append($("<input type='hidden' name='MapSel' id='MapSel'>"));
            mapSel = $form.find('input#MapSel');
        }
        // use string "yes" value to ignore parameter binding to url but checking if checkbox is checked. 
        //pass checked items through post action only. New method for form submit supports this functionality: handleFormSubmitExtended()
        if (typeof isCheckbox === "string") {
            //if (isCheckbox && (isCheckbox.toLowerCase() == "yes")) {
            //    var chkItems = $($parentDiv).data("nimble").getCheckedItem().toString();
            //    if (!chkItems) {
            //        handleActionButtonsClick(isCheckbox);
            //        return false;
            //    }
            //}
        }
        else {
            if (isCheckbox) {
                GetSelectedEmpFromHandsontableTable($parentDiv);
                if (udSel.val() === "" || udSel.val() === "on") {
                    handleActionButtonsClick(isCheckbox);
                    return false;
                }
                if (isCheckboxAndAllowOnlyOneItem) {
                    var selectedItems = $($parentDiv).data("nimble").getCheckedItem();
                    if (selectedItems && selectedItems.length > 1) {
                        handleActionButtonsClick(isCheckbox, isCheckboxAndAllowOnlyOneItem);
                        return false;
                    }
                }
            }
            else {
                if ($parentDiv !== undefined) {
                    const instance = $($parentDiv).data("handsontable");
                    if (instance === null || instance === undefined) {
                        return false;
                    }
                    const selection = instance.getSelected();
                    if (selection === undefined) {
                        handleActionButtonsClick(isCheckbox);
                        return false;
                    }
                    var nimbleInstance = $($parentDiv).data("nimble");
                    var data;
                    if (nimbleInstance.getSelectedCell() === "" || nimbleInstance.getSelectedCell() === undefined) {
                        // added by Ram
                        if (isMultipleWithoutCheckbox) {
                            const row = selection[0];
                            const col = selection[1];
                            const rowEnd = selection[2];
                            const allData = instance.getData(row, 1, rowEnd, 1);
                            data = allData.join();
                        }
                        else {
                            const row = selection[0];
                            data = instance.getDataAtRow(row);
                            data = data[1];

                        }
                    } else {
                        if (!columnName) columnName = undefined;//gives issue if column name  is "" , should keep it undefined 
                        data = nimbleInstance.getSelectedCell(columnName);
                    }
                    $("#Sel").val(data);
                    if (udSel != undefined) udSel.val(data);
                    if (udSelDel != undefined) udSelDel.val(data);

                    var mappeddata = nimbleInstance.getSelectedMappedCell();
                    if (mapSel)
                        mapSel.val(mappeddata);
                }
            }
        }

        $form.on("submit", function (e) {
            e.preventDefault();
            var $form = $(this);
            const dataUrl = $sender.attr("data-url");
            var instance = $("#id").data("instance");
            if (typeof instance === "undefined")
                instance = $("#id1").data("instance");
            var width = "";
            var contentPlaceHolder = $("#modal-popup");
            if (typeof childContent !== "undefined") {
                if (childContent && childContent !== null) {
                    contentPlaceHolder = childContent;
                }

            }
            width = dataWidth === null && dataWidth === undefined ? '60%' : dataWidth;
            window.UIExtendedModals.init({
                width: width,
                content: dataUrl,
                contentPlaceHolder: contentPlaceHolder,
                modalElement: contentPlaceHolder,
                fillContent: true,
                usingAjax: true,
                //data: $form.serialize(),
                data: isPost == true ? $form.serializeArray() : $form.serialize(), // serializeArray() will force POST method instead of GET.
                afterPopupOpen: function () {
                    handelPickerAfterBsModalPopUpOpen();
                    handleBindTabChange();
                    bindSelect2();
                    if (instance !== null && instance !== undefined) {
                        if (typeof instance.initafterPopupOpen !== "undefined") {
                            instance.initafterPopupOpen(dataAction);
                        }
                    }
                },
                afterPopupClose: function () {
                    width = "";
                    if (instance !== null && instance !== undefined) {
                        if (typeof instance.initafterPopUpClose !== "undefined") {
                            instance.initafterPopUpClose(dataAction);
                        }
                    }
                }
            });
            $form.unbind().bind("submit");
        });
        $form.submit();
        return true;
    }
}

var executeFunctionFromData = function (dataAttribut) {
    var d = `${dataAttribut}`; // Save `data-myattr` to d; (Obviously, this is just a hardcoded value as an example)
    window[d](); // Execute the function.
}

var getClickMenuIDFromUrl = function (url) {
    const urlParams = new URLSearchParams(url);
    const ckedmenuid = urlParams.get('ckedmenuid');
    return ckedmenuid;
}

var getPathExcludingIndex = function (pathname) {
    return pathname.replace(/\/index(\/[^/]+)?(\/|$)/, '');
}
var makeSideMenuActive = function () {
    var url = window.location;
    var permMenuUrl = new URL($("#currentMenuUrl").val(), window.location.href);

    $('ul.sidebar-menu a').filter(function () {
        return (this.pathname.toLowerCase() === url.pathname.toLowerCase()
            || getPathExcludingIndex(this.pathname.toLowerCase()) === getPathExcludingIndex(url.pathname.toLowerCase()))
            && (!getClickMenuIDFromUrl(this.search) || !getClickMenuIDFromUrl(url.search)
                || getClickMenuIDFromUrl(this.search).toLowerCase() === getClickMenuIDFromUrl(url.search).toLowerCase());
    }).parent().addClass('active');

    //if (permMenuUrl) {
    //    $('ul.sidebar-menu a').filter(function () {
    //        debugger;
    //        return (this.pathname.toLowerCase() === permMenuUrl.pathname.toLowerCase()
    //            || getPathExcludingIndex(this.pathname.toLowerCase()) === getPathExcludingIndex(permMenuUrl.pathname.toLowerCase()))
    //            && (!getClickMenuIDFromUrl(this.search) || !getClickMenuIDFromUrl(permMenuUrl.search)
    //            || getClickMenuIDFromUrl(this.search).toLowerCase() === getClickMenuIDFromUrl(permMenuUrl.search).toLowerCase());
    //    }).parent().addClass('active');
    //}


    //for treeview
    $('ul.treeview-menu a').filter(function () {
        return (this.pathname.toLowerCase() === url.pathname.toLowerCase()
            || getPathExcludingIndex(this.pathname.toLowerCase()) === getPathExcludingIndex(url.pathname.toLowerCase()))
            && (!getClickMenuIDFromUrl(this.search) || !getClickMenuIDFromUrl(url.search)
                || getClickMenuIDFromUrl(this.search).toLowerCase() === getClickMenuIDFromUrl(url.search).toLowerCase());
    }).parentsUntil(".sidebar-menu > .treeview-menu").addClass('active');

    if (permMenuUrl) {
        $('ul.treeview-menu a').filter(function () {

            return (this.pathname.toLowerCase() === permMenuUrl.pathname.toLowerCase()
                || getPathExcludingIndex(this.pathname.toLowerCase()) === getPathExcludingIndex(permMenuUrl.pathname.toLowerCase()))
                && (!getClickMenuIDFromUrl(this.search) || !getClickMenuIDFromUrl(permMenuUrl.search)
                    || getClickMenuIDFromUrl(this.search).toLowerCase() === getClickMenuIDFromUrl(permMenuUrl.search).toLowerCase());
        }).parentsUntil(".sidebar-menu > .treeview-menu").addClass('active');
    }


    //    activate 
    $('ul.nim-profile-page-menu a').filter(function () {
        return this.pathname.toLowerCase() === url.pathname.toLowerCase();
    }).parent().addClass('active');
};

