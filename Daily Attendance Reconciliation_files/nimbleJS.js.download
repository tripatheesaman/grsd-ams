var handleFormValidationSaveAndContinue = function (formId, sender, callBack, action, handsontableId, isDialoug, customCallBack) {
    var form = $(formId);
    var error = $('.alert-danger', form);
    var success = $('.alert-success', form);
    var btnValue;
    var $elem;
    form.validate({
        focusInvalid: true,
        ignore: "",
        rules: {

        },
        messages: {

        },
        errorPlacement: function (error, element) {

        },
        showErrors: function (errorMap, errorList) {
            this.defaultShowErrors();
        },
        invalidHandler: function (event, validator) {
            success.hide();
            error.show();
        },
        highlight: function (element) {// hightlight error inputs
            $(element).closest('.form-group').removeClass('has-success').addClass('has-error'); // set error class to the control group
        },
        unhighlight: function (element) { // revert the change done by hightlight
            $(element).closest('.form-group').removeClass('has-error').addClass('has-success');
        },
        success: function (label, element) {
            $(element).closest('.form-group').removeClass('has-error').addClass('has-success');
            $(label).remove();
        },
        submitHandler: function (form) {
            success.show();
            error.hide();
            var typeOfButton = this.submitButton.nodeName;
            if (typeOfButton === "TEXT") {
                btnValue = $(this.submitButton.parentElement).attr("data-value");
                $elem = $(this.submitButton.parentElement);
            } else {
                btnValue = $(this.submitButton).attr("data-value");
                $elem = $(this.submitButton);
            }
            $elem.button('loading');
            $elem.attr("disabled", true);
            const $form = $(form);
            var call = false;
            if (typeof callBack === "function") {
                call = callBack($form, $elem, btnValue, action);
                if (typeof call === "boolean")
                    return true;
            }
            else {
                var formData = $form.serialize();
                $.ajax({
                    method: $form.attr("method"),
                    url: $form.attr("action"),
                    data: formData,
                    success: function () {
                    },
                    complete: function (result) {
                        $elem.button('reset');
                        $elem.attr("disabled", false);
                        var obj = JSON.parse(result.responseText);
                        var type = handleTosterMessage(obj);

                        if (type === "success" || type === "info") {
                            if (typeof handsontableId !== "undefined") {
                                if ($(handsontableId).hasClass('pq-grid'))
                                    $(handsontableId).pqGrid('refreshDataAndView')

                                else if ($(handsontableId).hasClass('handsontable'))
                                    $(handsontableId).data("nimble").getReloadOnSuccess();
                            }
                            if (isDialoug === true) {
                                window.UIExtendedModals.hide();
                            }

                        }
                        if (typeof customCallBack !== "undefined") {
                            customCallBack(obj, type, action, $form, $elem, btnValue);
                        }
                    },
                    error: function (results) {
                        console.log(results.responseText);
                    }
                });
                return false;
            }
            return false;
        }
    });
}

/**
 * Method to append Querystring when tab is click if tab child li.a contain data attribute data-text and makes that tab active accordingly
 */
var handleGlobalTabChangeEvent = function () {
    var tabElement = $(".nav-tabs > li > a", $(".nav-tabs-custom"));
    $(".nav-tabs > li > a", $(".nav-tabs-custom")).on("click", function (e) {
        if ($(this).parent('li').hasClass('disabled') || $(this).parent('li').attr("disabled") === "disabled") {
            return false;
        };
        var dataText = $(this).data("text");
        if ('URLSearchParams' in window) {
            var searchParams = new URLSearchParams(window.location.search);
            if (typeof dataText !== "undefined") {
                searchParams.set("tab", dataText);
                window.history.pushState("Index", 'Title', "?" + searchParams.toString());
            }

        }

    });


    var current = QueryString("tab");

    /*Page Loading with tab=tabname not selecting related tab if case not matched, need to make it can insensetive*/
    $(tabElement).filter(function () {
        if (typeof ($(this).attr("data-text")) !== "undefined" && typeof current !== "undefined") {
            return $(this).attr("data-text").toLowerCase() == current.toLowerCase();
        }
    }).addClass('active').tab('show');
}

var handleBindTabChange = function () {
    $(".nav-tabs-custom").on('shown.bs.tab', 'a[data-toggle="tab"]', function (e) {
        bindSelect2();
    })
}

var OnLoginSubmitPw = function (form) {
    var pw = $(form).find('input[id="LoginPassword"]')
    if (pw.val() != "") {
        return md5auth(form);
    }
}

