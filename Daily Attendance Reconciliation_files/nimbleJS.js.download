            gridObject.pageModel = { type: "remote", rPPOptions: [35, 100, 200, 500, 1000, 5000, 10000], rPP: 35, strRpp: "{0}" };
        }

        var grid = this.pqGrid('destroy').pqGrid(gridObject);

        return {
            grid: grid
        }
    };

}(jQuery));

function findIndexByPropertyValue(array, property, value) {
    return array.findIndex(function (object) {
        return object[property] === value;
    });
}

niConvertPqGridData = function (gridElement) {
    var pqGridData = $(gridElement).pqGrid("option", "dataModel.data");

    var headers = Object.keys(pqGridData[0]);
    var nestedArray = [];

    nestedArray.push(headers);

    for (var i = 0; i < pqGridData.length; i++) {
        var valuesArray = [];

        for (var j = 0; j < headers.length; j++) {
            valuesArray.push(pqGridData[i][headers[j]]);
        }

        nestedArray.push(valuesArray);
    }

    return nestedArray;
}

