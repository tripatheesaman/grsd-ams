var parsePqGridFilterDataIntoFilter = function (element, isStringify = false) {
    var colModel = $(element).pqGrid('getColModel');

    var filters = colModel.filter(function (a) {
        return a.filter && a.filter.hasOwnProperty('value');
    });

    var filterArray = filters.map(function (obj) {
        return { dataIndx: obj.dataIndx, dataType: obj.dataType, filter: obj.filter };
    });

    var filter = { "Filter": [] };
    $.each(filterArray, function (index, value) {
        var condition = value.filter.condition.toLowerCase();
        var dataIndx = "[" + value.dataIndx + "]";
        var val1 = value.filter.value || "";
        var val2 = value.filter.value2 || "";
        var dataType = value.dataType;

        filter.Filter.push([dataIndx, getEquivalentCondition(condition, dataType, val1, val2), val1, val2]);
    });

    return isStringify ? JSON.parse(filter) : filter;
}

var parsePqGridSortList = function (element) {
    var sortModel = $(element).pqGrid("option", "sortModel").sorter;
    if (sortModel && sortModel.length > 0) {

        return {
            sort: sortModel[0].dir == 'up' ? 'DESC' : 'ASC',
            orderByCol: sortModel[0].dataIndx
        }
    }
    return {
        sort: "",
        orderByCol: ""
    }
}

var handleExportButtonClickPqGrid = function ($sender, formName, $parentGridRef, tabType) {
    var $pqGrid;
    if ($parentGridRef === '') {
        $pqGrid = void 0;
    }
    if (typeof $parentGridRef === "undefined") {
        //$pqGrid = $($sender).parents("section.content").find('.handsontable');
    } else {
        $pqGrid = $($parentGridRef).pqGrid();
    }
    if (typeof $pqGrid === "undefined" || $pqGrid === null) {
        return;
    }

    var filter = parsePqGridFilterDataIntoFilter($parentGridRef);
    var sortList = parsePqGridSortList($parentGridRef);
    var orderByColData = sortList.orderByCol;
    var sort = sortList.sort;

    var $form = $("#" + formName);
    $form[0].reset();
    var filterInput = $("#filterExpression");
    var sortInput = $("#sortOrder");
    var orderByCol = $("#orderByCol");

    var dataFilter = JSON.stringify(filter);
    var filterExp = $('<input />',
        {
            type: 'hidden',
            name: 'filterExpression',
            id: 'filterExpression',
            value: dataFilter
        });
    var sortElem = $('<input />',
        {
            type: 'hidden',
            name: 'sortOrder',
            id: 'sortOrder',
            value: sort
        });
    var order = $('<input />',
        {
            type: 'hidden',
            name: 'orderByCol',
            id: 'orderByCol',
            value: orderByColData
        });
    if (typeof $(filterInput).get(0) === "undefined") {
        filterExp.appendTo($form);

    }
    if (typeof $(sortInput).get(0) === "undefined") {
        sortElem.appendTo($form);
    }
    if (typeof $(orderByCol).get(0) === "undefined") {
        order.appendTo($form);
    }
    var $filterForm = $("#gridFilterForm");
    if (typeof $filterForm.get(0) !== "undefined") {
        $("#gridFilterForm").find(":input").not("submit").each(function () {
            if ($(this).attr("name") !== undefined && $(this).val() !== null) {
                var input = "#" + $(this).attr("name");
                //if ($form.find(input).length === 0) {
                var inp = $("<input name='" + $(this).attr("name") + "' type='hidden' value='" + $(this).val() + "' id='" + $(this).attr("name") + "'/>");
                $form.append(inp);
                //}
                $(`input[id=${$(this).attr("name")}]`, `#${formName}`).val("" + $(this).val());
            }
        });
    }
    $("#filterExpression").val(dataFilter);
    $("#sortOrder").val(sort);
    $("#orderByCol").val(orderByColData);
    var url = $($sender).attr("data-href");
    if (typeof tabType !== "undefined") {
        if (tabType !== '') {
            var tabName = $($sender).closest('nav').parents().find('div.nav-tabs-custom').find('li.active').find('a');
            var dataText = tabName.attr('data-text');
            if (typeof dataText !== undefined && typeof dataText !== "undefined") {
                var tabType = $('<input />',
                    {
                        type: 'hidden',
                        name: 'tabType',
                        id: 'tabType',
                        value: dataText
                    });
                if (typeof $($("#tabType"), $form).get(0) === "undefined") {
                    tabType.appendTo($form);
                }
                $("#tabType").val(dataText);
            }
        }
    }
    if (url.indexOf('?') > -1) {
        var params = url.split("?")[1];
        var paramList = params.split("&");
        $.each(paramList, function (key, value) {
            if (value.indexOf('=') > 1) {
                var keyValPair = value.split('=');
                if (typeof $($(`#${keyValPair[0]}`), $form).get(0) === "undefined") {
                    $(`<input type='hidden' value='${keyValPair[1]}' />`)
                        .attr(`id`, `${keyValPair[0]}`)
                        .attr(`name`, `${keyValPair[0]}`)
                        .appendTo($form);
                }
                $(`#${keyValPair[0]}`).val(keyValPair[1]);
            }
        });
    }
    $form = removeDuplicateKeysAndGetForm(formName);
    $form.attr("action", url);
    $form.submit();
}

function removeDuplicateKeysAndGetForm(formName) {
    var $form = $("#" + formName);

    // Iterate through form elements
    $form.find(':input').each(function () {
        var key = $(this).attr('name'); // Get the name attribute of the input element
        if ($form.find('[name="' + key + '"]').length > 1) {
            // If there are multiple elements with the same key, remove the duplicates
            $form.find('[name="' + key + '"]:not(:first)').remove();
        }
    });

    return $form;
}

var UDActionHandSonPqGrid = function (id, element, isPopup = 0, mode = "") {
    var $pqGridTable;
    if (typeof element === "undefined") {
        $pqGridTable = $(id).parents("section.content").find('.pq-grid-table');
    } else {
        $pqGridTable = element;
    }
    if ($pqGridTable !== undefined && $pqGridTable !== null) {
        if (mode != "C") { //C: Create
            var url = "";

            var options = $pqGridTable.pqGrid('option');
            var onRowClick = options.onRowClick;


            const instance = $(id).parents("section.content").find('.pq-grid-table');
            if (instance === undefined || instance === null) {

            } else {
                const $ids = $(id).get(0);
                var href = $(id).attr("data-href");
                url = href;// id.href;
                var cellCollections = $.map($pqGridTable.pqGrid('selection', { type: 'cell', method: 'getSelection' }), function (obj) {
                    return obj.rowData[onRowClick];
                });
                var rowCollections = $.map($pqGridTable.pqGrid('selection', { type: 'row', method: 'getSelection' }), function (obj) {
                    return obj.rowData[onRowClick];
                });
                var checkBoxCollection = $.map($pqGridTable.pqGrid('pageData'), function (obj) {
                    if (obj.hasOwnProperty('NI_CHECKBOX')) {
                        return obj.NI_CHECKBOX ? obj[onRowClick] : null;
                    }
                    return null;
                });
                var mergedCollection = $.merge($.merge(cellCollections, rowCollections), checkBoxCollection);


                // Remove duplicates from mergedCollection
                var collection = [];
                $.each(mergedCollection, function (i, el) {
                    if ($.inArray(el, collection) === -1) {
                        collection.push(el);
                    }
                });

                if (!collection || collection.length === 0) {
                    alert("Select (Highlight) record to modify.");
                    return false;
                }

                if (onRowClick !== null && collection.length > 1) {
                    alert('Please select only one record')
                    return false;
                }

                ids = collection[0];

                var d = $pqGridTable.pqGrid('option')

                if (url.indexOf("?") === -1)
                    url = url + "?id=" + ids;
                else
                    url = url + "&id=" + ids;

                $(id).attr("href", url);
            }
        }
        if (isPopup == 1) {
            openFullWindowPopupi(url);
        }
        else {
            window.location = url;
        }
        return false;
    }
    return false;
}

var handleDeleteButtonsClickPqGrid = function ($sender, url, $parentGrid, isCheckBox, formUrl) {
    var data;
    var def = url;
    if (typeof url === "object") {
        [$parentGrid, url] = [url, $parentGrid];
    }

    if (typeof $parentGrid === "undefined" || $parentGrid === null || $parentGrid === '') {
        $parentGrid = $($sender).parents("section.content").find('.pq-grid-table');
    }
    var gridElement = '#' + $($parentGrid).attr('id');
    var options = $parentGrid.pqGrid('option');
    var onRowClick = options.onRowClick;


    var cellCollections = $.map($parentGrid.pqGrid('selection', { type: 'cell', method: 'getSelection' }), function (obj) {
        return obj.rowData[onRowClick];
    });
    var rowCollections = $.map($parentGrid.pqGrid('selection', { type: 'row', method: 'getSelection' }), function (obj) {
        return obj.rowData[onRowClick];
    });
    var checkBoxCollection = $.map($parentGrid.pqGrid('pageData'), function (obj) {
        if (obj.hasOwnProperty('NI_CHECKBOX')) {
            return obj.NI_CHECKBOX ? obj[onRowClick] : null;
        }
        return null;
    });
    var mergedCollection = $.merge($.merge(cellCollections, rowCollections), checkBoxCollection);

    // Remove duplicates from mergedCollection
    var collection = [];
    $.each(mergedCollection, function (i, el) {
        if ($.inArray(el, collection) === -1) {
            collection.push(el);
        }
    });

    if (!collection || collection.length === 0) {
        window.handleActionButtonsClick(false);
        return false;
    }

    data = collection.join(',');
    if (!isCheckBox && collection.length !== 1) {
        showCustomErrorPQ('Please select only one row. Thank You.');
        return;
    }

    $("#modal-popup-delete").modal("show").on("shown.bs.modal", function () {
        if (formUrl !== undefined || formUrl !== '') {
            $("#delete-form-model").attr("action", formUrl);
        }
        $("#delete-form-model").off("submit").on("submit", function (e) {
            e.preventDefault();
            $(this).find('input#UDSelDel').val(data);
            $(this).find('button.btnSave').button('loading');
            const $form = $(this);
            if (url === void 0 || url === '') {
                url = $form.attr("action")
            }
            setTimeout(function () {
                $.post(url, $($form).serialize(), function (data, status) {
                    $($form).find('button.btnSave').button('reset');
                    var clientMessage = { title: data.Title, type: data.StatusType, content: data.Message };
                    if (clientMessage.type === "success") {
                        if ($(gridElement).hasClass('pq-grid')) $(gridElement).pqGrid('refreshDataAndView');
                        $("#modal-popup-delete").modal("hide");
                    }
                    window.UIToastr.init(clientMessage);
                    if (data.Object != null &&
                        data.Object.hasOwnProperty('Total') &&
                        data.Object.hasOwnProperty('Success') &&
                        data.Object.hasOwnProperty('Failed') &&
                        typeof data.Object.Total === 'number' &&
                        typeof data.Object.Success === 'number' &&
                        typeof data.Object.Failed === 'number') {
                        showProcessingResultsConfirmation(data.Title, data.Object);
                    }
                });
            }, 400);

            return false;
        });

    }).on("hidden.bs.modal", function (e) { });
    return false;
}

var showCustomErrorPQ = function (message) {
    let modalHtml = "<div class='modal fade'>" +
        "<div class='modal-header'>";
    modalHtml +=
        "<button type='button' class='close' data-dismiss='modal' aria-hidden='true'>×</button><h4 class='modal-title text-warning'><i class='fa fa-warning'></i> Attention!</h4>";
    modalHtml += "</div>" +
        "<div class='modal-body'><h4>" + message + "</h4></div>" +
        "<div class='modal-footer'>";

    modalHtml += "<a data-dismiss='modal' class='btn btn-nim-sec'><i class='fa fa-close'></i> Close</a></div></div>";
    const custDialog = $.parseHTML(modalHtml);
    $(custDialog).modal("show");
    return false;
}

var handleBsModalPqGrid = function (sender, formName, isCheckbox, $multiTableId, columnName, childContent, isPost, isAllowMultiCheck) {
    var $sender = $(sender);
    if ($sender !== null && $sender !== undefined) {
        var $parentDiv;
        if (!$multiTableId || typeof $multiTableId === "number" || typeof $multiTableId === "undefined") {
            $parentDiv = $($sender).parents("section.content").find('.pq-grid-table');
        } else {
            $parentDiv = $multiTableId; //$($sender).parents().find("div.handsontable");
        }
        $('body').modalmanager('loading');
        var $form = $("#" + formName);
        var className = $(sender).attr("class");
        var dataWidth = $(sender).attr("data-width");
        var dataAction = $($sender).attr("data-action");
        var udSel = $form.find('input#UDSel');
        var udSelDel = $form.find('input#UDSelDel');
        var mapSel;
        if ($form.find('input#MapSel').length > 0) {
            mapSel = $form.find('input#MapSel');
        }
        else {
            $form.append($("<input type='hidden' name='MapSel' id='MapSel'>"));
            mapSel = $form.find('input#MapSel');
        }
        // use string "yes" value to ignore parameter binding to url but checking if checkbox is checked. 
        //pass checked items through post action only. New method for form submit supports this functionality: handleFormSubmitExtended()
        if (typeof isCheckbox === "string") {
            //if (isCheckbox && (isCheckbox.toLowerCase() == "yes")) {
            //    var chkItems = $($parentDiv).data("nimble").getCheckedItem().toString();
            //    if (!chkItems) {
            //        handleActionButtonsClick(isCheckbox);
            //        return false;
            //    }
            //}
        }
        else {
            isCheckbox = false;
            if (isCheckbox) {
                GetSelectedEmpFromTablePqGrid($parentDiv);
                if (udSel.val() === "" || udSel.val() === "on") {
                    handleActionButtonsClick(isCheckbox);
                    return false;
                }
                if ((isAllowMultiCheck == false) && udSel.val() !== "") {
                    var count = udSel.val().split(',').length;
                    if (count > 1) {
                        handleActionButtonsClick(isCheckbox, isAllowMultiCheck);
                        return false;
                    }
                }
            }
            else {
                if ($parentDiv !== undefined) {
                    GetSelectedEmpFromTablePqGrid($parentDiv);
                    if (udSel.val() === "" || udSel.val() === "on") {
                        handleActionButtonsClick(isCheckbox);
                        return false;
                    }

                    if ((isAllowMultiCheck == false) && udSel.val() !== "") {
                        var count = udSel.val().split(',').length;
                        if (count > 1) {
                            handleActionButtonsClick(isCheckbox, isAllowMultiCheck);
                            return false;
                        }
                    }
                    //const instance = $($parentDiv).data("handsontable");
                    //if (instance === null || instance === undefined) {
                    //    return false;
                    //}
                    //const selection = instance.getSelected();
                    //if (selection === undefined) {
                    //    handleActionButtonsClick(isCheckbox);
                    //    return false;
                    //}
                    //var nimbleInstance = $($parentDiv).data("nimble");
                    //var data;
                    //if (nimbleInstance.getSelectedCell() === "" || nimbleInstance.getSelectedCell() === undefined) {
                    //    const row = selection[0];
                    //    data = instance.getDataAtRow(row);
                    //    data = data[1];
                    //} else {
                    //    if (!columnName) columnName = undefined;//gives issue if column name  is "" , should keep it undefined 
                    //    data = nimbleInstance.getSelectedCell(columnName);
                    //}
                    //$("#Sel").val(data);
                    //if (udSel != undefined) udSel.val(data);
                    //if (udSelDel != undefined) udSelDel.val(data);

                    //var mappeddata = nimbleInstance.getSelectedMappedCell();
                    //if (mapSel)
                    //    mapSel.val(mappeddata);
                }
            }
        }

        $form.on("submit", function (e) {
            e.preventDefault();
            var $form = $(this);
            const dataUrl = $sender.attr("data-url");
            var instance = $("#id").data("instance");
            var width = "";
            var contentPlaceHolder = $("#modal-popup");
            if (typeof childContent !== "undefined") {
                if (childContent && childContent !== null) {
                    contentPlaceHolder = childContent;
                }

            }
            width = dataWidth === null && dataWidth === undefined ? '60%' : dataWidth;
            window.UIExtendedModals.init({
                width: width,
                content: dataUrl,
                contentPlaceHolder: contentPlaceHolder,
                modalElement: contentPlaceHolder,
                fillContent: true,
                usingAjax: true,
                //data: $form.serialize(),
                data: isPost == true ? $form.serializeArray() : $form.serialize(), // serializeArray() will force POST method instead of GET.
                afterPopupOpen: function () {
                    handelPickerAfterBsModalPopUpOpen();
                    handleBindTabChange();
                    bindSelect2();
                    if (instance !== null && instance !== undefined) {
                        if (typeof instance.initafterPopupOpen !== "undefined") {
                            instance.initafterPopupOpen(dataAction);
                        }
                    }
                },
                afterPopupClose: function () {
                    width = "";
                    if (instance !== null && instance !== undefined) {
                        if (typeof instance.initafterPopUpClose !== "undefined") {
                            instance.initafterPopUpClose(dataAction);
                        }
                    }
                }
            });
            $form.unbind().bind("submit");
        });
        $form.submit();
        return true;
    }
}

var GetSelectedEmpFromTablePqGrid = function (element) {
    var $parentGrid = $(element)
    if (!$parentGrid.hasClass('pq-grid')) {
        return;
    }

    var options = $(element).pqGrid('option');
    var onRowClick = options.onRowClick;

    var cellCollections = $.map($parentGrid.pqGrid('selection', { type: 'cell', method: 'getSelection' }), function (obj) {
        return obj.rowData[onRowClick];
    });
    var rowCollections = $.map($parentGrid.pqGrid('selection', { type: 'row', method: 'getSelection' }), function (obj) {
        return obj.rowData[onRowClick];
    });
    var checkBoxCollection = $.map($parentGrid.pqGrid('pageData'), function (obj) {
        if (obj.hasOwnProperty('NI_CHECKBOX')) {
            return obj.NI_CHECKBOX ? obj[onRowClick] : null;
        }
        return null;
    });
    var mergedCollection = $.merge($.merge(cellCollections, rowCollections), checkBoxCollection);

    // Remove duplicates from mergedCollection
    var collection = [];
    $.each(mergedCollection, function (i, el) {
        if ($.inArray(el, collection) === -1) {
            collection.push(el);
        }
    });

    //if (!collection || collection.length === 0) {
    //    window.handleActionButtonsClick(false);
    //    return false;
    //}

    var SelectedEmps = collection.join(',');
    var mappedvalues = collection.join(',');;
    if ($('#MapSel').length > 0) {
        $("#MapSel").val(mappedvalues);
    }
    else if ($('#submit_udsel').length > 0) {
        input = jQuery("<input type='hidden' name='MapSel' id='MapSel'>");
        jQuery('#submit_udsel').append(input);
        $("#MapSel").val(mappedvalues);
    }

    $("#Sel").val(SelectedEmps);
    if ($("#UDSel").length > 0)
        $("#UDSel").val(SelectedEmps);
    if ($("#UDSelDel").length > 0)
        $("#UDSelDel").val(SelectedEmps);
    return SelectedEmps;
}

function SetPqGridHeight() {
    var pageHeaderHeight = $(".main-header").outerHeight() || 0;
    var profileHeight = $("#profileheader").outerHeight() || 0;
    var headerContHeight = $('.content-header').outerHeight() || 0;
    var tabHeight = $(".nav-tabs-custom>.nav.nav-tabs").outerHeight() || 0;
    var navHeight = $(".navbar-default:visible").outerHeight() || 0;
    var gridPagerHeight = $(".grid-pager").outerHeight() || 0;
    var gridFooterHeight = $(".grid-footer").outerHeight() || 0;
    var pageFooterHeight = $(".main-footer").outerHeight() || 0;
    var isPopup = IsWindowPopup();

    var profile = profileHeight + headerContHeight + tabHeight + navHeight + gridPagerHeight + gridFooterHeight;
    if (!isPopup)
        profile += pageHeaderHeight + pageFooterHeight;
    var gridHeight = $(window).height() - profile - 1;

    return gridHeight <= 250 ? 250 : gridHeight;
}



var handleGridTransformation = function (element, isCheckBoxonly = false, isGetAllGridData = false) {
    var $parentGrid = $(element)
    var colModel = $parentGrid.pqGrid('option', 'colModel');

    var options = $parentGrid.pqGrid('option');
    var onRowClick = options.onRowClick;

    var cellCollections = !isCheckBoxonly ? $.map($parentGrid.pqGrid('selection', { type: 'cell', method: 'getSelection' }), function (obj) {
        return obj.rowData[onRowClick];
    }) : [];
    var rowCollections = !isCheckBoxonly ? $.map($parentGrid.pqGrid('selection', { type: 'row', method: 'getSelection' }), function (obj) {
        return obj.rowData[onRowClick];
    }) : [];
    var checkBoxCollection = $.map($parentGrid.pqGrid('pageData'), function (obj) {
        if (obj.hasOwnProperty('NI_CHECKBOX')) {
            return obj.NI_CHECKBOX ? obj[onRowClick] : null;
        }
        return null;
    });
    var mergedCollection = $.merge($.merge(cellCollections, rowCollections), checkBoxCollection);
    mergedCollection = removeDuplicates(mergedCollection);
    var dataModel = $(element).pqGrid('getData');

    if (!isGetAllGridData) {
        dataModel = $.grep(dataModel, function (data) {
            return mergedCollection.indexOf(data[onRowClick]) !== -1;
        });
    }

    //dataModel = $.grep(dataModel, function (data) {
    //    return mergedCollection.indexOf(data[onRowClick]) !== -1;
    //});
    var headers = $.map(colModel, function (col) {
        return col['dataIndx'] == "NI_CHECKBOX" ? "SN" : col['dataIndx'];
    });

    // Creating the jagged array with column headers as the first row
    var jagged = [headers];

    // Iterating over each data object in dataModel
    $.each(dataModel, function (index, data) {
        var row = [];

        // Iterating over each column in colModel and fetching the corresponding value from data
        $.each(colModel, function (colIndex, col) {
            var value = col.dataIndx == "SN" ? true : data[col.dataIndx];
            row.push(value);
        });

        jagged.push(row);
    });

    return {
        jagged: jagged,
        rowClickItems: mergedCollection
    };
}

var handleGridTransformationFocus = function (element, isCheckBoxonly = false, isGetAllGridData = false) {
    var $parentGrid = $(element)
    var colModel = $parentGrid.pqGrid('option', 'colModel');

    var options = $parentGrid.pqGrid('option');
    var onRowClick = options.onRowClick;

    var cellCollections = !isCheckBoxonly ? $.map($parentGrid.pqGrid('selection', { type: 'cell', method: 'getSelection' }), function (obj) {
        return obj.rowData[onRowClick];
    }) : [];
    var rowCollections = !isCheckBoxonly ? $.map($parentGrid.pqGrid('selection', { type: 'row', method: 'getSelection' }), function (obj) {
        return obj.rowData[onRowClick];
    }) : [];

    var mergedCollection = $.merge(cellCollections, rowCollections);
    mergedCollection = removeDuplicates(mergedCollection);
    var dataModel = $(element).pqGrid('getData');

    if (!isGetAllGridData) {
        dataModel = $.grep(dataModel, function (data) {
            return mergedCollection.indexOf(data[onRowClick]) !== -1;
        });
    }

    //dataModel = $.grep(dataModel, function (data) {
    //    return mergedCollection.indexOf(data[onRowClick]) !== -1;
    //});
    var headers = $.map(colModel, function (col) {
        return col['dataIndx'] == "NI_CHECKBOX" ? "SN" : col['dataIndx'];
    });

    // Creating the jagged array with column headers as the first row
    var jagged = [headers];

    // Iterating over each data object in dataModel
    $.each(dataModel, function (index, data) {
        var row = [];

        // Iterating over each column in colModel and fetching the corresponding value from data
        $.each(colModel, function (colIndex, col) {
            var value = col.dataIndx == "SN" ? true : data[col.dataIndx];
            row.push(value);
        });

        jagged.push(row);
    });

    return {
        jagged: jagged,
        rowClickItems: mergedCollection
    };
}

var handleGridTransformationChecked = function (element, isCheckBoxonly = false, isGetAllGridData = false) {
    var $parentGrid = $(element)
    var colModel = $parentGrid.pqGrid('option', 'colModel');

    var options = $parentGrid.pqGrid('option');
    var onRowClick = options.onRowClick;

    var rowCollections = !isCheckBoxonly ? $.map($parentGrid.pqGrid('selection', { type: 'row', method: 'getSelection' }), function (obj) {
        return obj.rowData[onRowClick];
    }) : [];
    var checkBoxCollection = $.map($parentGrid.pqGrid('pageData'), function (obj) {
        if (obj.hasOwnProperty('NI_CHECKBOX')) {
            return obj.NI_CHECKBOX ? obj[onRowClick] : null;
        }
        return null;
    });
    var mergedCollection = $.merge(checkBoxCollection, rowCollections);
    mergedCollection = removeDuplicates(mergedCollection);
    var dataModel = $(element).pqGrid('getData');

    if (!isGetAllGridData) {
        dataModel = $.grep(dataModel, function (data) {
            return mergedCollection.indexOf(data[onRowClick]) !== -1;
        });
    }

    //dataModel = $.grep(dataModel, function (data) {
    //    return mergedCollection.indexOf(data[onRowClick]) !== -1;
    //});
    var headers = $.map(colModel, function (col) {
        return col['dataIndx'] == "NI_CHECKBOX" ? "SN" : col['dataIndx'];
    });

    // Creating the jagged array with column headers as the first row
    var jagged = [headers];

    // Iterating over each data object in dataModel
    $.each(dataModel, function (index, data) {
        var row = [];

        // Iterating over each column in colModel and fetching the corresponding value from data
        $.each(colModel, function (colIndex, col) {
            var value = col.dataIndx == "SN" ? true : data[col.dataIndx];
            row.push(value);
        });

        jagged.push(row);
    });

    return {
        jagged: jagged,
        rowClickItems: mergedCollection
    };
}

var getPqGridSelectedOrAllData = function (element) {
    var $parentGrid = $(element);
    var colModel = $parentGrid.pqGrid('option', 'colModel');
    var onRowClick = $parentGrid.pqGrid('option', 'onRowClick');

    // Get all data from the grid
    var allData = $parentGrid.pqGrid('getData');

    // Check if any checkboxes are checked (i.e., rows with NI_CHECKBOX === true)
    var hasCheckedRows = allData.some(function (row) {
        return row.NI_CHECKBOX === true; // Check if the row's checkbox is selected
    });

    // Filter data to include only checked rows if any checkbox is checked; otherwise, include all rows
    var filteredData = hasCheckedRows
        ? $.grep(allData, function (row) {
            return row.NI_CHECKBOX === true;
        })
        : allData;

    // Create headers for the jagged array
    var headers = $.map(colModel, function (col) {
        return col.dataIndx == "NI_CHECKBOX" ? "SN" : col.dataIndx;
    });

    // Create jagged array with headers
    var jagged = [headers];

    // Add rows to the jagged array
    $.each(filteredData, function (index, data) {
        var row = [];

        // Iterate over the columns in the colModel
        $.each(colModel, function (colIndex, col) {
            var value = col.dataIndx == "NI_CHECKBOX"
                ? index + 1  // Assign serial number (SN) starting from 1
                : data[col.dataIndx];
            row.push(value);
        });

        jagged.push(row);
    });

    // Get only the "onRowClick" column data for the filtered rows
    var filteredRowData = $.map(filteredData, function (row) {
        return row[onRowClick]; // Extract the "onRowClick" column data for each filtered row
    });

    // Return the jagged array with the selected data and the filtered rows with only the onRowClick column data
    return {
        jagged: jagged,         // Jagged array with selected or all data
        filteredRows: filteredRowData // Only the "onRowClick" data from filtered rows
    };
};


function handleKeyPressTimeFormat(event) {
    // Get the key that was pressed
    const key = event.key;

    // Get the current input value
    const inputValue = event.target.value;

    // Check if the pressed key is a digit (0-9)
    const isDigit = /^\d$/.test(key);

    // Check if the pressed key is a colon (:) and there is no existing colon in the input value
    const isColon = key === ':' && inputValue.indexOf(':') === -1;

    // Check if the pressed key is the Backspace key
    const isBackspace = key === 'Backspace';

    // Check if the pressed key is the Tab key
    const isTab = key === 'Tab';

    // Check if the pressed key is the Enter key
    const isEnter = key === 'Enter';

    // Check if the pressed key is a valid input based on the allowed characters
    const isValidInput = isDigit || isColon || isBackspace || isTab || isEnter;

    // If the pressed key is not a valid input, prevent its default behavior (e.g., prevent typing)
    if (!isValidInput) {
        event.preventDefault();
        return false;
    }

    // If the pressed key is a digit or a colon, handle the input formatting
    if (isDigit || isColon) {
        // Get the caret position in the input value
        const caretPosition = event.target.selectionStart;

        // Insert the pressed key at the current caret position in the input value
        const updatedValue =
            inputValue.slice(0, caretPosition) +
            key +
            inputValue.slice(caretPosition);

        // Check if the updated value matches the desired time format (e.g., "HH:mm")
        const isValidTimeFormat = /^([01]?[0-9]|2[0-3]):[0-5][0-9]$/.test(updatedValue);

        // If the updated value is not a valid time format, prevent updating the input value
        if (!isValidTimeFormat) {
            event.preventDefault();
            return false;
        }
    }

    // Allow the input if it satisfies the conditions
    return true;
}

function isJSONData(something) {
    if (typeof something != 'string')
        something = JSON.stringify(something);

    try {
        JSON.parse(something);
        return true;
    } catch (e) {
        return false;
    }
}

var SubmitFormPqGrid = function (formName, actionName, target, element, isUDSel, confirmMsg) {
    if (isUDSel == null || isUDSel == true) {
        GetSelectedEmpFromDataTablePqGrid(element);
        if ($("#UDSel").val() == "") {
            alert("Select (Check box) record to modify.");
            return false;
        }
    }

    if (confirmMsg != null && confirmMsg != "") {
        if (!confirm(confirmMsg)) {
            return false;
        }
    }

    var form = $("#" + formName);

    if (actionName != null && actionName != '') {
        $(form).attr("action", actionName);
    }
    if (target != null && target != '') {
        $(form).attr("target", "_blank");
    }

    form.submit();
    return true;
}

var GetSelectedEmpFromDataTablePqGrid = function (element) {
    //Collecting checked nodes value and set in a variable with comma seperated
    var SelectedEmps = [];
    var grid = handleGridTransformation(element);
    SelectedEmps = grid.rowClickItems.join(',');

    //$("input:checked").each(function () {
    //    if ($(this).val() != 'on') {
    //        if (!SelectedEmps.includes($(this).val())) SelectedEmps.push($(this).val());
    //    }
    //});

    //set checked collected value in a hidden control having id='Sel'
    $("#Sel").val(SelectedEmps.toString());
    if ($("#UDSel").length > 0)
        $("#UDSel").val(SelectedEmps.toString());
    if ($("#UDSelDel").length > 0)
        $("#UDSelDel").val(SelectedEmps.toString());

    return SelectedEmps;
}

// PQ Grid Changes End

function isNumberKeyAmount(evt, isNonNegativeNumber = false) {
    var charCode = (evt.which) ? evt.which : event.keyCode;

    if (isNonNegativeNumber) {
        // Allow digits (0-9) and one minus sign (-), and prevent other characters
        if (charCode == 45) {
            return true;
        } else if (charCode == 46 || (charCode >= 48 && charCode <= 57)) {
            return true;
        } else {
            return false;
        }
    } else {
        // Allow digits (0-9) and one decimal point (.) and prevent other characters
        if (charCode == 46 || (charCode >= 48 && charCode <= 57)) {
            return true;
        } else {
            return false;
        }
    }
}

function isNumberKeyQuantity(evt, isNonNegativeNumber = false) {
    var charCode = (evt.which) ? evt.which : event.keyCode;

    if (isNonNegativeNumber) {
        // Allow digits (0-9) and one minus sign (-), and prevent other characters
        if (charCode == 45) {
            return true;
        } else if (charCode >= 48 && charCode <= 57) {
            return true;
        } else {
            return false;
        }
    } else {
        // Allow digits (0-9) and prevent other characters
        if (charCode >= 48 && charCode <= 57) {
            return true;
        } else {
            return false;
        }
    }
}


function isNumberKeyWithDecimal(txt, evt) {
    var charCode = (evt.which) ? evt.which : evt.keyCode;
    if (charCode == 46) {
        //Check if the text already contains the . character
        if (txt.value.indexOf('.') === -1) {
            return true;
        } else {
            return false;
        }
    } else {
        if (charCode > 31
            && (charCode < 48 || charCode > 57))
            return false;
    }
}

function removeDuplicates(arr) {
    var uniqueArray = [];
    for (var i = 0; i < arr.length; i++) {
        if (uniqueArray.indexOf(arr[i]) === -1) {
            uniqueArray.push(arr[i]);
        }
    }
    return uniqueArray;
}

function showAlertWithTimeoutMessageOnly(responseMessage) {
    if (responseMessage === undefined || responseMessage === '' || responseMessage === null) return;
    try {
        var html = `
                <div class="alert alert-message alert-danger alert-dismissable bulk-validation">
                    <button type="button" class="close" data-dismiss="alert" aria-hidden="true">&times;</button>`
        html += "<ul>";
        html += `<li>${responseMessage}</li>`
        html += '</ul></div>';
        var alertClass = '.bulk-validation';
        var timeoutDuration = 5000; // 5 seconds

        var oldDynamicAlert = $(document).find(alertClass);
        oldDynamicAlert.off('mouseenter').off('mouseleave');
        clearTimeout(oldDynamicAlert.data('removeTimeout'));

        if (oldDynamicAlert.length > 0) {
            oldDynamicAlert.remove();
        }

        $('.content-header:last').after(html);

        var dynamicAlert = $(document).find(alertClass);
        // Set a timeout to remove the alert after the specified duration
        var removeTimeout = setTimeout(function () {
            dynamicAlert.remove();
        }, timeoutDuration);

        // Prevent alert from closing when hovered and remove after the specified duration of inactivity
        var delayBeforeRemove = timeoutDuration; // delay matches the specified timeout duration

        dynamicAlert.on('mouseenter', function () {
            // Clear the timeout to prevent immediate removal
            clearTimeout(removeTimeout);
        }).on('mouseleave', function () {
            // Reset the timeout to remove the alert after the specified delay
            removeTimeout = setTimeout(function () {
                dynamicAlert.remove();
            }, delayBeforeRemove);
        });

        // Store the timeout ID as data for the dynamicAlert element
        dynamicAlert.data('removeTimeout', removeTimeout);
        isResponseValidationTriggered = true;
    } catch (e) {

    }

}
function copyToClipboard(text) {
    var $temp = $("<input>");
    $("body").append($temp);
    $temp.val(text).select();
    document.execCommand("copy");
    $temp.remove();
}

function reportingChartClick(event, chart, chartId, chartOnField, subReportID, label) {
    if (!label) {
        var elements = chart.getElementsAtEventForMode(event, 'nearest', { intersect: true }, true);
        if (elements.length > 0) {
            var el = elements[0];
            var index = el._index;
            var chartData = chart.data;
            label = chartData.labels[index];
        }
    }
    const filterValue = label === "summary-table" ? chart.getAttribute('data-params') : "";

    var customreport = $("#ReportCustomizationID").val();
    if (label) {
        if (subReportID) {
            var form = document.createElement('form');
            form.method = 'POST';
            form.action = '/Reporting/ReportViewer/PopUpReport';

            var customReportInput = document.createElement('input');
            customReportInput.type = 'hidden';
            customReportInput.name = 'customreport';
            customReportInput.value = customreport;
            form.appendChild(customReportInput);

            var labelInput = document.createElement('input');
            labelInput.type = 'hidden';
            labelInput.name = 'label';
            labelInput.value = label;
            form.appendChild(labelInput);

            var chartIdInput = document.createElement('input');
            chartIdInput.type = 'hidden';
            chartIdInput.name = 'chartId';
            chartIdInput.value = chartId;
            form.appendChild(chartIdInput);

            var chartOnFieldInput = document.createElement('input');
            chartOnFieldInput.type = 'hidden';
            chartOnFieldInput.name = 'chartOnField';
            chartOnFieldInput.value = label == "summary-table" ? filterValue : chartOnField;
            form.appendChild(chartOnFieldInput);

            var subReportIDInput = document.createElement('input');
            subReportIDInput.type = 'hidden';
            subReportIDInput.name = 'subReportID';
            subReportIDInput.value = subReportID;
            form.appendChild(subReportIDInput);

            var parameterList = [];
            var parameter = $('#parameters').length ? $('#parameters') : $('#parameterArea');
            $.each(parameter.find('.param'), function (i, val) {
                var idName = $(this).attr('id');
                var inputType = $(this).data("type");
                var model = {
                    CustomReportParameterName: idName,
                    CustomReportParameterValue: $(this).val() ? $(this).val().toString() : "",
                    SpParameterName: $(this).data("spparam"),
                    DisplayTextColumnName: $(this).data("displayname"),
                    IDColumnName: idName,
                    CustomReportParameterType: $(this).data("CustomReportParameterType"),
                    CustomReportParameterType: inputType,

                };
                parameterList.push(model);
            });
            var parameterListInput = document.createElement('input');
            parameterListInput.type = 'hidden';
            parameterListInput.name = 'parameterList';
            parameterListInput.value = JSON.stringify(parameterList);
            form.appendChild(parameterListInput);

            var globalData = {};
            var ReportDataSourceType = $("#CustomDS").val();
            if (ReportDataSourceType === "U") {
                // Serialize form data
                var frm = $("form[id='gridFilterForm']");
                var data = frm.serializeFormJSON();

                // Clean up data by removing '-1' values
                var hrmData = {};
                $.each(data, function (index, value) {
                    if ($.isArray(value)) {
                        hrmData[index] = value.toString().replace("-1,", "").replace("-1", "");
                    } else {
                        hrmData[index] = value.replace("-1,", "").replace("-1", "");
                    }
                });

                // Merge cleaned data into original data
                $.extend(data, hrmData);

                // Map the data to the NimbleGlobalFilterModel
                var nimbleGlobalFilterModel = {
                    DateType: data.DateType ? parseInt(data.DateType) : null,
                    LayoutCols: data.LayoutCols ? parseInt(data.LayoutCols) : 3,
                    LayoutColClass: data.LayoutColClass || "",
                    IsSubmit: data.IsSubmit === "true",
                    IsActionButton: data.IsActionButton === "true",
                    IsFilterAppend: data.IsFilterAppend === "true",
                    IsChild: data.IsChild === "true",
                    IsAutoComplete: data.IsAutoComplete === "true",
                    ActionName: data.ActionName || "",
                    ControllerName: data.ControllerName || "",
                    AreaName: data.AreaName || "",
                    FilterPageCode: data.FilterPageCode || "",
                    GridParameter: data.GridParameter ? JSON.parse(data.GridParameter) : null,
                    GlobalFilters: [],  // Populate this based on your specific filter data
                    SelectedGlobalFilter: data.SelectedGlobalFilter ? JSON.parse(data.SelectedGlobalFilter) : null,
                    InputSubmittedValues: {}
                };

                // Populate InputSubmittedValues with any additional data
                $.each(data, function (key, value) {
                    if (!nimbleGlobalFilterModel.hasOwnProperty(key)) {
                        nimbleGlobalFilterModel.InputSubmittedValues[key] = value;
                    }
                });

                // Convert the nimbleGlobalFilterModel to JSON and assign it to globalData
                globalData = nimbleGlobalFilterModel;

                // Create a hidden input field for globalData
                var globalDataInput = document.createElement('input');
                globalDataInput.type = 'hidden';
                globalDataInput.name = 'reportPostData';
                globalDataInput.value = JSON.stringify(globalData);

                // Append the hidden input to the form
                form.append(globalDataInput);
            }

            document.body.appendChild(form);


            openFullWindowPopupWithForm(form);

            return false;
        }
    }
};

function showImportPreviewErrorMessage(
    selector,
    msg,
    noOfErrorMessagesToDisplay = 10,
    rowPrefix = 'Record'
) {
    var errorHtml;
    if (isNaN(noOfErrorMessagesToDisplay)) noOfErrorMessagesToDisplay = 10;

    try {
        if (isJSONData(msg) && msg.includes('key') && msg.includes('value')) {
            var errors = $.parseJSON(msg);
            var shown = errors.slice(0, noOfErrorMessagesToDisplay);

            errorHtml = '<ul>' +
                shown.map(function (a) {
                    return '<li><strong><i>' +
                        rowPrefix + ' ' + (a.key + 2) +
                        ':</i></strong>' + a.value.join(', ') +
                        '</li>';
                }).join('') +
                (errors.length > noOfErrorMessagesToDisplay
                    ? '<li><em>...and ' +
                    (errors.length - noOfErrorMessagesToDisplay) +
                    ' more errors.</em></li>'
                    : ''
                ) +
                '</ul>';
        }
        else {
            errorHtml = '<p>' + msg + '</p>';
        }
    }
    catch (e) {
        console.error('Error parsing JSON:', e);
        errorHtml = '<p>There was an error processing validation messages.</p>';
    }

    $(selector).html(errorHtml);
}

function applyDynamicValidation(formId, appPageCode, validationApiUrl = "/coreextension/apppage/getmandatorycolumns", options = {}) {
    // Simple options object structure
    // options = {
    //     includeFields: ['field1', 'field2'], // Only validate these fields
    //     excludeFields: ['field3', 'field4'], // Skip these fields
    // }

    $.ajax({
        url: validationApiUrl,
        method: 'GET',
        data: { appPageCode: appPageCode },
        success: function (response) {
            _isFormValidationApiLoadCompleted = true;
            if (!response.success || !response.data) {
                console.warn("Validation rules not loaded:", response.message || "No data.");
                return;
            }

            var $form = $(`#${formId}`);

            // Add custom validator for dd/mm/yyyy format (if not already present)
            if (!$.validator.methods.datepickereng) {
                $.validator.addMethod("datepickereng", function (value, element) {
                    if (!value) return true; // Allow empty, required handled separately
                    var re = /^([0-2][0-9]|3[01])\/(0[1-9]|1[0-2])\/([0-9]{4})$/;
                    if (!re.test(value)) return false;
                    var parts = value.split('/');
                    var day = parseInt(parts[0], 10),
                        month = parseInt(parts[1], 10) - 1, // 0-based month
                        year = parseInt(parts[2], 10);
                    var date = new Date(year, month, day);
                    return (
                        date &&
                        date.getFullYear() === year &&
                        date.getMonth() === month &&
                        date.getDate() === day
                    );
                }, "Please enter a valid date in dd/mm/yyyy format.");
            }

            // Helper function to check if field should be validated
            function shouldValidateField(fieldName) {
                // If includeFields is specified, only validate those fields
                if (options.includeFields && options.includeFields.length > 0) {
                    return options.includeFields.includes(fieldName);
                }

                // If excludeFields is specified, skip those fields
                if (options.excludeFields && options.excludeFields.length > 0) {
                    return !options.excludeFields.includes(fieldName);
                }

                // No filtering specified, validate all fields
                return true;
            }

            response.data.forEach(function (rule) {
                // Skip field if not in validation scope
                if (!shouldValidateField(rule.FieldName)) {
                    return;
                }

                var $input = $(`#${formId} [name="${rule.FieldName}"]`);

                // Remove validation attributes
                var validationAttrs = [
                    'data-val', 'data-val-required', 'data-val-length',
                    'data-val-length-max', 'data-val-length-min',
                    'data-val-minlength', 'data-val-maxlength',
                    'data-val-number', 'data-val-min', 'data-val-max',
                    'data-val-range', 'data-val-range-min', 'data-val-range-max',
                    'data-val-regex', 'data-val-regex-pattern'
                ];
                validationAttrs.forEach(function (attr) {
                    $input.removeAttr(attr);
                });

                // Remove existing jQuery validation rules
                $input.rules("remove");

                // Clear validation state and error messages
                $input.removeClass('input-validation-error valid error');
                $input.next('.field-validation-error').remove();
                $input.siblings('.field-validation-error').remove();

                // Remove from unobtrusive validation cache
                var unobtrusiveValidation = $form.data('unobtrusiveValidation');
                if (unobtrusiveValidation && unobtrusiveValidation.options) {
                    if (unobtrusiveValidation.options.rules && unobtrusiveValidation.options.rules[rule.FieldName]) {
                        delete unobtrusiveValidation.options.rules[rule.FieldName];
                    }
                    if (unobtrusiveValidation.options.messages && unobtrusiveValidation.options.messages[rule.FieldName]) {
                        delete unobtrusiveValidation.options.messages[rule.FieldName];
                    }
                }

                // Remove from jQuery validator's internal cache
                var validator = $form.data('validator');
                if (validator && validator.settings) {
                    if (validator.settings.rules && validator.settings.rules[rule.FieldName]) {
                        delete validator.settings.rules[rule.FieldName];
                    }
                    if (validator.settings.messages && validator.settings.messages[rule.FieldName]) {
                        delete validator.settings.messages[rule.FieldName];
                    }
                }

                // Handle Select2 initialization if FormType is select-2-dropdown
                if (rule.FormType === 'select-2-dropdown') {
                    if (!$input.hasClass('select2-hidden-accessible')) {
                        $input.addClass('web-select2').select2();
                    }
                    $input.off('select2:close.dynamicValidation').on('select2:close.dynamicValidation', function (e) {
                        $(this).valid();
                    });
                }

                var validationRules = {};
                var validationMessages = {};

                // Required validation
                if (!rule.IsAllowNullOrEmpty) {
                    validationRules.required = true;
                    validationMessages.required = `${rule.DisplayName} is required.`;
                    $input.attr('data-val-required', validationMessages.required);
                }

                // Numeric validation
                if (rule.IsNumeric) {
                    validationRules.number = true;
                    validationMessages.number = `${rule.DisplayName} must be numeric.`;
                    $input.attr('data-val-number', validationMessages.number);

                    if (!rule.IsAllowZeroValue) {
                        validationRules.min = 1;
                        validationMessages.min = `${rule.DisplayName} cannot be blank(-) or empty.`;
                        $input.attr('data-val-min', validationMessages.min);
                    }
                }

                // Min/Max length validation
                if (rule.MinLength > 0) {
                    validationRules.minlength = rule.MinLength;
                    validationMessages.minlength = `${rule.DisplayName} must be at least ${rule.MinLength} characters.`;
                    $input.attr('data-val-minlength', validationMessages.minlength);
                }
                if (rule.MaxLength > 0) {
                    validationRules.maxlength = rule.MaxLength;
                    validationMessages.maxlength = `${rule.DisplayName} must be at most ${rule.MaxLength} characters.`;
                    $input.attr('data-val-maxlength', validationMessages.maxlength);
                    $input.attr('data-val-length', validationMessages.maxlength);
                    $input.attr('data-val-length-max', rule.MaxLength);
                }

                // DatePickerEng date validation
                if (rule.FieldType === 'DatePickerEng') {
                    validationRules.datepickereng = true;
                    validationMessages.datepickereng = `${rule.DisplayName} must be a valid date in dd/mm/yyyy format.`;
                    $input.attr('data-val-datepickereng', validationMessages.datepickereng);
                }

                // Enable validation for this field
                if (Object.keys(validationRules).length > 0) {
                    $input.attr('data-val', 'true');
                }

                // Apply new rules using jQuery validate
                $input.rules("add", validationRules);

                // Add messages to ensure they're applied
                if (Object.keys(validationMessages).length > 0) {
                    $input.rules("add", { messages: validationMessages });
                }
                // populate validation span if not exits
                if ($input.next('.field-validation-valid').length === 0 &&
                    $input.siblings('.field-validation-valid').length === 0) {

                    var fieldName = $input.attr('name');
                    var $validationSpan = $('<span></span>')
                        .addClass('field-validation-valid')
                        .attr('data-valmsg-for', fieldName)
                        .attr('data-valmsg-replace', 'true');

                    if ($input.hasClass('web-select2') && $input.next('.select2-container').length > 0) {
                        $validationSpan.insertAfter($input.next('.select2-container'));
                    } else {
                        $validationSpan.insertAfter($input);
                    }
                }
            });

            // Initialize/Reinitialize form validation with Select2 support
            var existingValidator = $form.data('validator');
            if (existingValidator) {
                existingValidator.resetForm();
                if (existingValidator.elements) {
                    existingValidator.elements();
                }
            } else {
                $form.validate({
                    errorPlacement: function (label, element) {
                        if (element.hasClass('web-select2')) {
                            label.insertAfter(element.next('.select2-container')).addClass('mt-2 text-danger');
                        } else {
                            label.addClass('mt-2 text-danger');
                            label.insertAfter(element);
                        }
                    },
                    highlight: function (element) {
                        $(element).parent().addClass('is-invalid');
                        $(element).addClass('form-control-danger');
                    },
                    success: function (label, element) {
                        $(element).parent().removeClass('is-invalid');
                        $(element).removeClass('form-control-danger');
                        label.remove();
                    }
                });
            }

            // Reinitialize unobtrusive validation to pick up new attributes
            $form.removeData('unobtrusiveValidation');
            $.validator.unobtrusive.parse($form);

        },
        error: function (xhr) {
            console.error("Validation rule load failed:", xhr.responseText);
        }
    });
}


handlePqGridFilterFocus = function () {
    window.PqGridlastFocusedInputName = null;
    $(document).on('keydown', '.pq-grid-hd-search-field', function (event) {
        if (event && event.target && event.target.name) {
            window.PqGridlastFocusedInputName = event.target.name;
        }
    });
}


function showProcessingResultsConfirmation(title, data, options = {}) {
    const obj = data;

    // Only proceed if there are failures to show
    if (obj.Total == obj.Success) return;

    // Default options
    const defaults = {
        title: title,
        compact: true,
        showRetryButton: true,
        onRetry: function () { }
    };
    const opts = Object.assign(defaults, options);

    // Build message content
    let message = `<div style="font-family: monospace; font-size: 12px; text-align: left;">`;
    message += `<strong>Summary: ${obj.Total} total | ${obj.Success} success | ${obj.Failed} failed</strong><br><br>`;

    if (obj.Failed > 0 && obj.Errors) {
        // Handle both array and object formats for errors
        if (Array.isArray(obj.Errors)) {
            obj.Errors.forEach(error => {
                if (error.Key && error.Value) {
                    message += `<span style="color: #dc3545;">${error.Key}</span>: ${error.Value}<br>`;
                }
            });
        } else {
            Object.entries(obj.Errors).forEach(([code, description]) => {
                message += `<span style="color: #dc3545;">${code}</span>: ${description}<br>`;
            });
        }
    }
    message += `</div>`;

    // Build buttons
    const buttons = {
        close: {
            text: 'Close',
            btnClass: 'btn-orange'
        }
    };

    var confirmModalType = {
        type: '750px',
        useBootstrap: false,
    };

    // Show popup
    $.confirm({
        title: opts.title,
        content: message,
        type: obj.Failed > 0 ? 'red' : 'green',
        typeAnimated: true,
        boxWidth: confirmModalType.type,
        useBootstrap: confirmModalType.useBootstrap,
        buttons: buttons
    });
}

window.applyCustomFont = function (columnList, fontFamily) {
    if (!columnList || !fontFamily) return;
    var sanitized = fontFamily.replace(/[^a-zA-Z0-9_-]/g, '');
    if (!sanitized || document.querySelector('style[data-font="' + sanitized + '"]')) return;
    var dir = '/Content/Font/';
    var exts = ['ttf', 'otf', 'woff', 'woff2'];
    var formats = { ttf: 'truetype', otf: 'opentype', woff: 'woff', woff2: 'woff2' };
    var found = false;
    var columns = columnList.split(',').map(function (c) { return c.trim(); }).filter(Boolean);
    var fontPath = '';
    var fontFormat = '';

    var applyFont = function () {
        columns.forEach(function (name) {
            var escaped = name.replace(/[!"#$%&'()*+,.\/:;<=>?@[\\\]^`{|}~]/g, '\\$&');
            $("[name='" + escaped + "']").css('font-family', sanitized);
        });
    };

    var applyCKEditor = function (editor) {
        if (!editor.document) return;

        var doc = editor.document.$;
        var head = doc.getElementsByTagName('head')[0];

        // Inject font into iframe if not already present
        if (!head.querySelector('style[data-font="' + sanitized + '"]')) {
            var style = doc.createElement('style');
            style.setAttribute('data-font', sanitized);
            style.textContent = '@font-face{font-family:"' + sanitized + '";src:url("' + fontPath + '")format("' + fontFormat + '")}';
            head.appendChild(style);
        }
    };

    exts.forEach(function (ext) {
        if (found) return;
        fetch(dir + sanitized + '.' + ext, { method: 'HEAD' })
            .then(function (r) {
                if (r.ok && !found) {
                    found = true;
                    fontPath = dir + sanitized + '.' + ext;
                    fontFormat = formats[ext];

                    // Inject font CSS
                    var style = document.createElement('style');
                    style.setAttribute('data-font', sanitized);
                    style.textContent = '@font-face{font-family:"' + sanitized + '";src:url("' + fontPath + '")format("' + fontFormat + '")}' +
                        '[style*="font-family:' + sanitized + '"]{font-family:"' + sanitized + '"!important}';
                    document.head.appendChild(style);

                    // Apply to existing fields
                    applyFont();

                    // Watch for dynamic content
                    if (window.MutationObserver) {
                        new MutationObserver(function (mutations) {
                            if (mutations.some(function (m) { return m.addedNodes.length; })) applyFont();
                        }).observe(document.body, { childList: true, subtree: true });
                    }

                    // Handle CKEditor
                    if (typeof CKEDITOR !== 'undefined') {
                        for (var name in CKEDITOR.instances) {
                            if (CKEDITOR.instances.hasOwnProperty(name)) {
                                var ed = CKEDITOR.instances[name];
                                if (ed && ed.status === 'ready') {
                                    applyCKEditor(ed);
                                } else if (ed) {
                                    ed.on('instanceReady', function () { applyCKEditor(this); });
                                }
                            }
                        }
                        CKEDITOR.on('instanceReady', function (evt) {
                            applyCKEditor(evt.editor);
                            var fonts = evt.editor.config.font_names || '';
                            if (fonts.indexOf(sanitized) === -1) {
                                evt.editor.config.font_names = fonts + sanitized + '/' + sanitized + ';';
                            }
                        });
                    }
                }
            })
            .catch(function () { });
    });
};