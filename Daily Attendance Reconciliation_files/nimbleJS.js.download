var pad = function (num) {
    return ("0" + num).slice(-2);
}

var hhmmss = function (secs) {
    var minutes = Math.floor(secs / 60);
    secs = secs % 60;
    var hours = Math.floor(minutes / 60)
    minutes = minutes % 60;
    return `${pad(hours)}:${pad(minutes)}:${pad(secs)}`;
    // return pad(hours)+":"+pad(minutes)+":"+pad(secs); for old browsers
}

var CheckToggle = function (classname, checkboxID) {
    $("." + classname).prop("checked", $("#" + checkboxID).prop("checked"))
}

var Confirm = function (msg) {
    if (msg == '' || msg == undefined) msg == "Sure to Delete ?";
    var status = confirm(msg);
    return status;
}

//Created for: Perform Update Delete operation for highlighted row in grid mvc table.  It can be used for any operation for selected/highlighted row for grid mvc table.
var UDAction = function (id, isPopup = 0, mode = "") {
    var url = id.href;
    if (mode != "C") { //C: Create
        if ($("#id").val() != undefined && $("#id").val() != "") {

            if (url.indexOf("?") == -1)
                url = url + "?id=" + $("#id").val();
            else
                url = url + "&id=" + $("#id").val();
        }
        else {
            alert("Select (Highlight) record to modify.");
            return false;
        }
    }
    if (isPopup == 1) {
        openFullWindowPopupi(url);
    }
    else {
        window.location = url;
    }
    return false;
}

var UDActionHandSon = function (id, element, isPopup = 0, mode = "") {
    var $handsontable;
    if (typeof element === "undefined") {
        $handsontable = $(id).parents("div.content-wrapper").find("div.handsontable");
    } else {
        $handsontable = element;
    }
    if ($handsontable !== undefined && $handsontable !== null) {
        if (mode != "C") { //C: Create
            const instance = $handsontable.handsontable("getInstance");
            var url = "";
            if (instance === undefined || instance === null) {

            } else {
                const $ids = $(id).get(0);
                var href = $(id).attr("data-href");
                url = href;// id.href;
                if (instance.getSelected() !== undefined) {
                    const rowStart = instance.getSelected()[0];
                    const rowEnd = instance.getSelected()[2];
                    const datas = instance.getData(rowStart, 0, rowEnd, instance.countCols());
                    const nimbleInstance = $handsontable.data("options");
                    var rowClick = null;
                    var index;
                    if (nimbleInstance) {
                        if (nimbleInstance.onRowClick !== undefined)
                            rowClick = nimbleInstance.onRowClick;
                    }
                    if (rowClick !== null) {
                        index = $handsontable.data("header").indexOf(rowClick);
                    } else {
                        index = 0;
                    }
                    const ids = datas[0][index];
                    if (url.indexOf("?") === -1)
                        url = url + "?id=" + ids;
                    else
                        url = url + "&id=" + ids;
                }
                else {
                    alert("Select (Highlight) record to modify.");
                    return false;
                }
                $(id).attr("href", url);
            }
        }

        if (isPopup == 1) {
            openFullWindowPopupi(url);
        }
        else {
            window.location = url;
        }
        return false;
    }
    return false;
}

var SubmitForm = function (formName, actionName, target, isUDSel, confirmMsg) {
    if (isUDSel == null || isUDSel == true) {
        GetSelectedEmpFromDataTable();
        if ($("#UDSel").val() == "") {
            alert("Select (Check box) record to modify.");
            return false;
        }
    }

    if (confirmMsg != null && confirmMsg != "") {
        if (!confirm(confirmMsg)) {
            return false;
        }
    }

    var form = $("#" + formName);

    if (actionName != null && actionName != '') {
        $(form).attr("action", actionName);
    }
    if (target != null && target != '') {
        $(form).attr("target", "_blank");
    }

    form.submit();
    return true;
}

var SubmitFilterForm = function (formName) {
    var form = $("#" + formName);
    const $form = $(form);
    var data = $form.serializeFormJSON();
    var testDate = {};
    $.each(data, function (index, value) {
        if ($.isArray(value)) {
            //testDate[index] = value.toString().replace("-1,", "").replace("-1", "");
        } else {
            //testDate[index] = value.replace("-1,", "").replace("-1", "");
        }
    });
    $.extend(data, testDate);
    $form.empty();
    $.each(data, function (key, value) {
        $(`<input type='hidden' value='${value}' />`)
            .attr(`id`, `${key}`)
            .attr(`name`, `${key}`)
            .appendTo($form);
    });
    $form.submit();
    return true;
}

var openFullWindowPopup = function (url, windowName) {
    params = 'width=' + screen.width;
    params += ', height=' + screen.height;
    params += ', top=0, left=0'
    params += ', fullscreen=yes';
    params += ', directories=no';
    params += ', location=no';
    params += ', menubar=no';
    params += ', resizable=no';
    params += ', scrollbars=no';
    params += ', status=no';
    params += ', toolbar=no';
    var url = url + (url.includes("?") ? "&" : "?") + "windowtarget=popup";
    var newwin = window.open(url, windowName ? windowName : 'FullWindowAll', params);
    newwin.moveTo(0, 0);
    newwin.resizeTo(screen.availWidth - 100, screen.availHeight - 100);
    if (window.focus) { newwin.focus() }
    return false;
}

var closeFullWindowPopupi = function (pageReload = false) {
    window.parent.closeFullWindowPopupiModal();
    if (pageReload) {
        window.parent.location.reload();
    }
}

var openFullWindowPopupWithForm = function (form) {
    var windowName = 'FullWindowAll' + new Date().getTime();
    form.target = windowName;
    var width = screen.width - 100;
    var height = screen.height - 100;
    var left = (screen.width - width) / 2;
    var top = (screen.height - height) / 2;
    var params = `width=${width}, height=${height}, top=${top}, left=${left}, fullscreen=no, directories=no, location=no, menubar=no, resizable=no, scrollbars=no, status=no, toolbar=no`;

    var newwin = window.open('', windowName, params);
    newwin.resizeTo(screen.availWidth - 100, screen.availHeight - 50);

    form.submit();

    if (window.focus) {
        newwin.focus();
    }

    return false;
}


var handleBindPopupiCancel = function () {
    if (IsWindowPopup()) {
        var $selector = $(".modal-footer>*>.btn.btn-nim-sec,.modal-footer>*>*>.btn.btn-nim-sec");
        $selector.on("click", function () {
            if ($selector.html() == "Cancel") {
                closeFullWindowPopupi();
            }
        })
    }
}

window.closeFullWindowPopupiModal = function () {
    $('#modal-popup').modal('hide');
};

var resizeIFrameToFitContent = function (iFrame = 'ifrContent') {
    var iframe = window.parent.document.getElementById(iFrame);
    if (iframe != null && iframe != undefined) {
        var height = iframe.contentWindow.document.body.scrollHeight < document.body.scrollHeight ? document.body.scrollHeight - 30 - 25 : iframe.contentWindow.document.body.scrollHeight;
        iframe.style.height = height + 'px';
    }
}

//window.addEventListener('unload', function (event) {
//    if (IsWindowPopup) {
//        closeFullWindowPopupi();
//    }
//});

var IsWindowPopup = function () {
    if ((window.opener !== window && !window.menubar.visible) || window.top != window.self)
        return true;
    else
        return false;
}


var openFullWindowPopupi = function (url, title, width, afterPopupOpen, afterPopupClose) {
    var dataUrl = url + (url.includes("?") ? "&" : "?") + "windowtarget=popup";
    width = width === null || width === undefined ? '100%' : width;
    window.UIExtendedModals.init({
        title: title,
        isRemote: false,
        content: dataUrl, //url if isRemote=true else html
        showIframe: true,
        modalElement: $("#modal-popup"),
        titlePlaceHolder: $("#modal-title"),
        contentPlaceHolder: $("#modal-popup > #modal-body"),
        width: width,
        height: 'auto',
        fillContent: false,
        usingAjax: false,
        data: null,
        afterPopupOpen: function () {
            //afterPopupOpen;
        },
        afterPopupClose: function () {
            //afterPopupClose;
        }
    });

    return false;
}

var SetFocus = function (controlID) {
    if (document.getElementById(controlID) != null) document.getElementById(controlID).focus();
}

var AddThead = function (controlIDorClass) {
    var $table = $('table.nim-report-table,table.grid-table' + (controlIDorClass !== undefined ? ',' + controlIDorClass : ''));
    $table.floatThead({
        scrollContainer: function ($table) {
            return $table.closest('.scroll,.scrollRep');
        },
        useAbsolutePositioning: true
    });
    $table.floatThead('reflow');
}

var RemoveThead = function (controlIDorClass) {
    var $table = $('table.nim-report-table,table.grid-table' + (controlIDorClass !== undefined ? ',' + controlIDorClass : ''));
    $table.floatThead('destroy');
}

var ToogleHead = function () {
    if ($("#AddHead").is(':unchecked'))
        RemoveThead();
    else
        AddThead();
}


function setExtGridHeight(panelName = "GridPanel1") {
    if (Ext.getCmp(panelName)) {
        if (window.innerHeight != undefined) {
            var height = window.innerHeight;
        }
        else {
            //for ie
            var B = document.body,
                D = document.documentElement;
            var height = Math.min(D.clientHeight, B.clientHeight);
        }
        Ext.getCmp(panelName).setHeight(height - 136);
    } else {
        setTimeout(setExtGridHeight, 100, panelName);
    }
}

function SetMvcGridHeight() {
    var div_reload = $("#reload-all").length;
    var div_print = $("#div_print").length;
    var div_scroll = $(".scroll").length;
    if ((div_reload >= 1 || div_print >= 1) && div_scroll >= 1) {
        var pageHeaderHeight = $(".main-header").outerHeight() || 0;
        var profileHeight = $(".profileheader").outerHeight() || 0;
        var profileLeftMenuHeight = 0;
        if (profileHeight > 0) {
            profileHeight += 25;
        }
        var headerContHeight = $('.content-header').outerHeight() || 0;
        var tabHeight = $(".nav-tabs-custom>.nav.nav-tabs").outerHeight() || 0;
        var navHeight = $(".navbar-default:visible").outerHeight() || 0;
        var gridPagerHeight = $(".grid-pager").outerHeight() || 0;
        var gridFooterHeight = $(".grid-footer").outerHeight() || 0;
        var pageFooterHeight = $(".main-footer").outerHeight() || 0;
        var gridPageTitleHeight = $(".grid-page-title").outerHeight() || 0;

        var isPopup = IsWindowPopup();

        var profile = profileHeight + headerContHeight + tabHeight + navHeight + gridPagerHeight + gridFooterHeight + gridPageTitleHeight;
        if (!isPopup)
            profile += pageHeaderHeight + pageFooterHeight;
        var windowHeight = $(window).height();
        var gridHeight = windowHeight - profile - 3;

        if (gridHeight < profileLeftMenuHeight && profileHeight > 0)
            gridHeight = profileLeftMenuHeight - navHeight - tabHeight - gridFooterHeight;

        if (gridHeight > (windowHeight - pageHeaderHeight - pageFooterHeight))
            gridHeight = (windowHeight - pageHeaderHeight - pageFooterHeight);

        if (gridHeight <= 250) {
            gridHeight = 250;
        }


        $(".scroll").height(gridHeight);
    }
}


//Add items inside class "toolbar_item" into .btn-toolbar. utilized in index page to add buttons into common toolbar. 
//In index page keep buttons inside a span with class "toolbar_item", it will add these buttons in toolbar.
var handleAddMenuItemsToFormToolbar = function () {
    $(".toolbar_item").appendTo(".btn-toolbar");
    // $(".toolbar_item_out").appendTo(".btn-toolbar-out");
    $(".toolbar_item_out").insertBefore(".more-option");
    if (!$(".more-option").length) {
        $(".toolbar_item_out").appendTo(".btn-toolbar-out");
    }

    $(".toolbar_item").removeClass("toolbar_item");
    $(".toolbar_item_out").removeClass("toolbar_item_out");

    if ($(".btn-toolbar").length) {
        var val = $(".btn-toolbar").html().trim();
        if (val == "") {
            $(".btn-toolbar").parent().attr("style", "display:none");
        }
    }
};

var handleAjaxRequest = function (config, successCallback, errorCallback, completeCallback) {
    const defaults = {
        cache: false,
        beforesend: function (xhr) { },
        method: 'POST',
        dataType: "json",
        contentType: 'application/json; charset=utf-8',
        success: successCallback,
        error: errorCallback,
        complete: completeCallback
    };
    $.extend(defaults, config);
    $.ajax(defaults);
};

// ajax request
var ajaxRequest = function (url, data) {
    return $.ajax({
        url: url,
        type: 'POST',
        data: data
    });
}

var cmsCoreScript = (function () {
    ajaxRequest = function (url, data) {
        return $.ajax({
            url: url,
            type: 'POST',
            data: data
        });
    }

    tooltip = $(".content").on("hover", ".tt", function () {
        console.log("hovered");
    })

    return {
        ajaxRequest: ajaxRequest,
        tooltip: tooltip
    }
}(cmsCoreScript || {}));

