//  Left section on click panel module open   
var handleSidebarModuleSection = function () {
    $('a.sidebar-module-icon').on("click", function (e) {
        e.preventDefault();
        if ($('.module-listing-wrap' && '.sidebar-module-icon').hasClass("active")) {
            $('.module-listing-wrap').animate({
                left: "-550px"
            }, 300).removeClass("active");

            $('.sidebar-module-icon').removeClass("active");

        } else {
            $('.module-listing-wrap').animate({
                left: "0px"
            }, 300).addClass("active");
            $('.sidebar-module-icon').addClass("active");
        }

    });

    //When Outer body click left pannel hide
    $('body').on('click', function (event) {
        if ($(event.target).closest(".sidebar-module-icon").length === 1 || $(event.target).closest(".module-listing-wrap").length === 1) {
            return;
        } else {
            if ($('.module-listing-wrap' && '.sidebar-module-icon').hasClass("active")) {
                $('.module-listing-wrap').animate({
                    left: "-550px"
                }, 300).removeClass("active");

                $('.sidebar-module-icon').removeClass("active");
            };
        }

    });

    bindSlimScroll('.nim-slim-module-wrap');
}


var bindSlimScroll = function (container) {
    $(container).slimScroll({
        height: '85vh',
        width: 'auto',
        size: '13px',
        touchScrollStep: 50
    });
}
var printdiv = function (printpage) {
    var headstr = "<html><head><title></title>";
    headstr += ('<link rel="stylesheet" href="/Content/Theme/bootstrap/css/bootstrap.min.css" type="text/css" media="print" />');
    headstr += ('<link rel="stylesheet" href="/Content/Theme/dist/css/AdminLTENimble.css" type="text/css" media="print" />');
    headstr += "</head><body>";
    var footstr = "</body>";
    var newstr = document.all.item(printpage).innerHTML;
    var oldstr = document.body.innerHTML;
    document.body.innerHTML = headstr + newstr + footstr;
    //setTimeout(function () { oldstr.print(); }, 1000);
    window.print();
    setTimeout(function () { document.body.innerHTML = oldstr; }, 1000);
    return false;
};

//New method to resolve js disabled after print button click
var printdivtonewtab = function (printpage) {   
    var headstr = "<html><head><title></title>";
    var bodystr = "</head><body>";
    var footstr = "</body>";
    var newstr = document.all.item(printpage).innerHTML;
    var oldheadstr = document.head.innerHTML;
    newWin = window.open("");
    newWin.document.write(headstr + oldheadstr + bodystr + newstr + footstr);
    newWin.document.close();
    newWin.focus();
    setTimeout(function () { newWin.print(); newWin.close(); }, 2000);
    return false;
};

var tableToExcelSkipNoPrint = (function () {
    var uri = 'data:application/vnd.ms-excel;base64,'
        , template = '<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel"  xmlns="http://www.w3.org/TR/REC-html40"><head> <!--[if gte mso 9]><xml><x:ExcelWorkbook><x:ExcelWorksheets> <x:ExcelWorksheet><x:Name>{worksheet}</x:Name> <x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions>  </x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook> </xml><![endif]--></head><body> <table>{table}</table></body></html>'
        , base64 = function (s) { return window.btoa(unescape(encodeURIComponent(s))) }
        , format = function (s, c) { return s.replace(/{(\w+)}/g, function (m, p) { return c[p]; }) }
    return function (table, name, filename) {
        if (!table.nodeType) table = document.getElementById(table)

        // Clone the table to preserve the original
        var tableClone = table.cloneNode(true);

        // Remove elements with the class 'no-print'
        var noPrintElements = tableClone.querySelectorAll('.no-print');
        noPrintElements.forEach(function (el) {
            el.parentNode.removeChild(el);
        });

        var ctx = { worksheet: name || 'Worksheet', table: tableClone.innerHTML }
        if (filename == null)
            filename = "Report";

        var blob = new Blob(['\ufeff', tableClone.innerHTML], {
            type: "application/vnd.ms-excel"
        });

        var expUrl = URL.createObjectURL(blob);
        document.getElementById("dlink").href = expUrl;

        //document.getElementById("dlink").href = uri + base64(format(template, ctx));
        document.getElementById("dlink").download = filename + ".xls";
        document.getElementById("dlink").click();

        //window.location.href = uri + base64(format(template, ctx))
    }
})();

var tableToExcel = (function () {
    var uri = 'data:application/vnd.ms-excel;base64,'
        , template = '<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel"  xmlns="http://www.w3.org/TR/REC-html40"><head> <!--[if gte mso 9]><xml><x:ExcelWorkbook><x:ExcelWorksheets> <x:ExcelWorksheet><x:Name>{worksheet}</x:Name> <x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions>  </x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook> </xml><![endif]--></head><body> <table>{table}</table></body></html>'
        , base64 = function (s) { return window.btoa(unescape(encodeURIComponent(s))) }
        , format = function (s, c) { return s.replace(/{(\w+)}/g, function (m, p) { return c[p]; }) }
    return function (table, name, filename) {
        if (!table.nodeType) table = document.getElementById(table)

        var ctx = { worksheet: name || 'Worksheet', table: table.innerHTML }
        if (filename == null)
            filename = "Report";

        var blob = new Blob(['\ufeff', table.innerHTML], {
            type: "application/vnd.ms-excel"
        });

        var expUrl = URL.createObjectURL(blob);
        document.getElementById("dlink").href = expUrl;

        //document.getElementById("dlink").href = uri + base64(format(template, ctx));
        document.getElementById("dlink").download = filename + ".xls";
        document.getElementById("dlink").click();

        //window.location.href = uri + base64(format(template, ctx))
    }
})();

//Time Picker, EnglishDatePicker and NepaliDatePicker for Modal Pop-up

//Call this function after ( afterPopupOpen ) BSModalPopUp open ;
var handelPickerAfterBsModalPopUpOpen = function () {
    $(".datepicker").datepicker(
        {
            format: "dd/mm/yyyy",
            autoclose: true,
            calendarWeeks: true,
            todayBtn: true,
            todayHighlight: true,
            forceParse: false
        }).on("show", function (ev) {
            var $instance = $(this).data("datepicker");
            $instance.update();
            $instance._allow_update = false;
            $instance._attachSecondaryEvents();
        }).inputmask("dd/mm/yyyy", { "placeholder": "dd/mm/yyyy" });

    ///Start Nepali Date Picker
    $(".nepali-calendar").nepaliDatePicker({
        npdMonth: true,
        npdYear: true,
        npdYearCount: 100
    });

    handleBindTimePicker();
};

var DateDiff = {
    inDays: function (d1, d2) {
        var t2 = d2.getTime();
        var t1 = d1.getTime();

        return parseInt((t2 - t1) / (24 * 3600 * 1000));
    },

    inWeeks: function (d1, d2) {
        var t2 = d2.getTime();
        var t1 = d1.getTime();

        return parseInt((t2 - t1) / (24 * 3600 * 1000 * 7));
    },

    inMonths: function (d1, d2) {
        var d1Y = d1.getFullYear();
        var d2Y = d2.getFullYear();
        var d1M = d1.getMonth();
        var d2M = d2.getMonth();

        return (d2M + 12 * d2Y) - (d1M + 12 * d1Y);
    },

    inYears: function (d1, d2) {
        return d2.getFullYear() - d1.getFullYear();
    }
}

var handleBindTimePicker = function (step = 10) {
    //Start TimePicker 
    $(".timepicker, .timeSet").timepicker({
        timeFormat: "H:i",
        showSecond: false,
        ampm: false,
        step: step
    });
}

//Convert yyyy/mm/dd to js valid date
var toDateYYMMDD = function (dateStr) {
    var parts = dateStr.split("/");
    return new Date(parts[0], parts[1] - 1, parts[2]);
}

function toDateLong(dateStr) {
    var parts = dateStr.split("/");
    return new Date(parts[2], parts[1] - 1, parts[0]);
}

var handleDataPickerValidatorIssue = function () {
    //Fixes for Bootstarp datepicker error on chrome.
    jQuery.validator.methods["date"] = function (value, element) { return true; }

}

/*Date Picker Conversion from DateOfBirth AD and vicecersa*/
var handleDateConversion = function (nepaliDate, engDate, callbackFunction = undefined) {
    var $engDateInput = $(engDate);
    var $nepaliDateInput = $(nepaliDate);


    $($engDateInput).on("focusout", function (ev) {
        // var previousDate = $(this).val();
        var $date = $(this).data("datepicker");
        $date.update();
        $date._allow_update = false;
        $date._attachSecondaryEvents();
        const from = $(ev.target).val().split("/");
        if ($(ev.target).val().length === 0) { $nepaliDateInput.val(""); return; }

        const date = new Date(from[2], from[1] - 1, from[0]);
        const format = date.getFullYear() + "/" + ("0" + (date.getMonth() + 1)).slice(-2) + "/" + ("0" + date.getDate()).slice(-2);

        const getNpDate = window.AD2BS(format);
        $nepaliDateInput.val(getNpDate);
    })

    $($engDateInput).on("changeDate", function (ev) {
        const from = $(ev.target).val().split("/");
        if ($(ev.target).val().length === 0) { $nepaliDateInput.val(""); return; }
        //convert date
        const date = new Date(from[2], from[1] - 1, from[0]);
        //Date formatted with 2 digits
        const format = date.getFullYear() + "/" + ("0" + (date.getMonth() + 1)).slice(-2) + "/" + ("0" + date.getDate()).slice(-2);
        //Get nepali date by English date
        const getNpDate = window.AD2BS(format);
        //fill the value
        $nepaliDateInput.val(getNpDate);
    });

    /*Datepicker Selection Bs to AD*/
    $($nepaliDateInput).on("focusout", function (ev) {
        $(nepaliDate).nepaliDatePicker({
            npdMonth: true,
            npdYear: true,
            npdYearCount: 100,
            ndpEnglishInput: "date-helper",

            onChange: function () {
                var DOBNepali = $(nepaliDate).val();
                if (DOBNepali.length === 0) { $($engDateInput).val(""); return; }

                var npDate = window.BS2AD(DOBNepali);
                const date = new Date(npDate);
                $($engDateInput).val(("0" + date.getDate()).slice(-2) + "/" + ("0" + (date.getMonth() + 1)).slice(-2) + "/" + date.getFullYear());
                $engDateInput.change();
                if (callbackFunction != null && callbackFunction != undefined) {
                    callbackFunction($engDateInput);
                }
            }
        });
    });

    /* Bi-dictionary Type BS to AD BirthDate Conversion*/
    $($nepaliDateInput).change(function (ev) {

        var previousDate = $(this).val();

        if (previousDate.length === 0) { $($engDateInput).val(""); return; }
        var $date = $(this).data("datepicker");
        const getEng = window.BS2AD(previousDate);
        const date = new Date(getEng);
        $($engDateInput).val(("0" + date.getDate()).slice(-2) + "/" + ("0" + (date.getMonth() + 1)).slice(-2) + "/" + date.getFullYear());
        $engDateInput.change();
    });
}

var BSDate = []; //global variable
//acceptable date format "yyyy/mm/dd","yyyy-dd-mm","yyyy.mm.dd"
var IsValidNepaliDate = function (nDate) {
    try {
        let nYear = 0, nMonth = 0, nDay = 0;
        if (!nDate)
            return false;

        var ND = [];
        if (nDate.indexOf("/") > 0)
            ND = nDate.split('/');
        else if (nDate.indexOf("-") > 0)
            ND = nDate.split('-');
        else if (nDate.indexOf(".") > 0)
            ND = nDate.split('.');
        else
            return false;

        if (ND.length != 3)
            return false;

        if (ND[0].length != 4 || ND[1].length > 2 || ND[2].length > 2)
            return false;

        nYear = parseInt(ND[0]);
        nMonth = parseInt(ND[1]);
        nDay = parseInt(ND[2]);


        if (isNaN(nYear) || isNaN(nMonth) || isNaN(nDay))
            return false;

        if (nMonth <= 12 & nMonth >= 1 & nDay <= 32 & nDay >= 1)
            if (nDay <= GetMonthEnd(nYear, nMonth))
                return true;

        return false;
    }
    catch
    {
        return false;
    }
}

