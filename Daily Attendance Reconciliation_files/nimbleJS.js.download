var viewPage = function (path) {
    if (path != null) {
        var win = window.open(path, '_blank');
        win.focus();
    }
    else
        return false;
}

var handleHideAlertMessage = function () {
    //Auto Hide Error/Success Message
    setTimeout(function () {
        $(".alert-message").hide(1000)
    }, 60000);
}

var handleShowNotification = function (type, msg) {
    if (type == "success") {
        $(".alert-success").alert(500);
        $("#top-message-success").html(msg);
    }
    else if (type == "warning") {
        $(".alert-warning").show(500);
        $("#top-message-warning").html(msg);
    }
    else if (type == "error") {
        //$(".alert-danger").removeClass("hidden");
        $(".alert-danger").hide(0);
        $(".alert-danger").show(500);
        $("#top-message-danger").html(msg);
    }
}

var handleHeartBeat = function (interval) {
    var isHeartbeatInProgress = false;

    window.setInterval(function () {
        if (isHeartbeatInProgress) return;
        isHeartbeatInProgress = true;

        $.post("/security/account/heartbeat")
            .done(function (data) {
            })
            .always(function () {
                isHeartbeatInProgress = false;
            });
    }, interval);
}

var handleInputChange = function () {
    /*Form Input Change track*/
    $('form input,select,textarea').on("change", function (e) {
        var formId = $(this).closest('form').attr('id') == undefined ? $(this).closest('form').attr('action') : $(this).closest('form').attr('action');
        IsDirty.FormName = formId;
        IsDirty.IsDirty = true;
    });
}

var handleFormCloseConfirm = function (element, modal) {
    var formId = $(element).closest('form').attr('id') == undefined ? $(element).closest('form').attr('action') : $(element).closest('form').attr('action');
    if (IsDirty.FormName == formId && IsDirty.IsDirty) {
        if (Confirm("Closing the form? Your entered data may be lost.")) {
            IsDirty.FormName = '';
            IsDirty.IsDirty = false;
            if (modal == 'modal') {
                $(element).closest('.modal').modal('hide');
            }
            return true;
        } else {
            return false;
        }
    } else if (modal == 'modal') {
        $(element).closest('.modal').modal('hide');
    }
}

// Employee search for _NevbarTopRight panel
var handleEmployeeAutoComplete = function () {
    var url = "/Hrm/Employee/EmployeeSearch";
    $("#SearchEmpCode").tokenInput(url, {
        theme: "facebook",
        preventDuplicates: true,
        method: "POST",
        tokenLimit: 1,
        onAdd: function (item) {
            handleEmployeeSearch($("#SearchEmpCode"));
            return false;
        },
        onReady: function () {
            $("#token-input-SearchEmpCode").attr("placeholder", "Type EmpName or EmpCode");
        },
        onDelete: function () {
            $("#token-input-SearchEmpCode").attr("placeholder", "Type EmpName or EmpCode");
        }
    });
}

var handleEmployeeSearch = function ($sender) {
    var empCode = $("#SearchEmpCode").val();
    if (empCode == "" || empCode == null || empCode == undefined) {
        return false;
    }
    $sender.on('change', function () {
        //window.location.href = "/Hrm/Employee/EmployeeQuickProfilePage?empCode=" + empCode;
        window.location.href = `/hrm/employeereport/employeedetails?empCode=${empCode}`;
    })
}

// Menu search for _NevbarTopRight panel
var handleSearchMenuAutoComplete = function () {
    var url = "/Security/Update/MenuSearch";
    $("#SearchMenu,#SearchMenu1").tokenInput(url, {
        theme: "facebook",
        preventDuplicates: true,
        method: "POST",
        tokenLimit: 1,
        propertyToSearch: "MenuName",
        resultsFormatter: function (item) {
            return `<li>
                        <b><i class ='fa ${item.MenuIcon}'/></i> ${item.MenuName}<br></b>
                        <div class='pl-3'>${item.MenuPath}</div>
                    </li>`
        },
        //tokenFormatter: function (item) { return `<li>${item.MenuName}</li>` },
        onAdd: function (item) {
            //console.log(item)
            var $rootUrl = "";
            if (item.MenuUrl.indexOf("?") > -1) {
                $rootUrl = `${item.MenuUrl}&ckedmenuid=${item.MenuID}`;
            }
            else {
                $rootUrl = `${item.MenuUrl}?ckedmenuid=${item.MenuID}`;
            }
            handleMenuSearch(item.MenuID, $rootUrl);
            //$("#token-input-SearchMenu").attr("placeholder", "Search Menu");
            return false;
        },
        onReady: function () {
            $("#token-input-SearchMenu").attr("placeholder", "Search Menu");
            $("<style>")
                .prop("type", "text/css")
                .html(".token-input-dropdown-facebook { max-height: 500px !important; overflow-y: auto !important; }")
                .appendTo("head");
        },
        onDelete: function () {
            $("#token-input-SearchMenu").attr("placeholder", "Search Menu");
        }
    });
}

