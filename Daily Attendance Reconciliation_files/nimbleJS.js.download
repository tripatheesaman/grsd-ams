    if ($("#" + textBox).length == 0) return false;
    if (type == null || type.toLowerCase() === "b") {
        CKEDITOR.replace(textBox, {
            height: editorHeight,
            allowedContent: true,
            /* disallowedContent: 'table{*}; td{*}; tr{*}; th{*}; div{*}',*/
            toolbarGroups:
                [
                    { name: 'basicstyles', groups: ['basicstyles', 'cleanup'] },
                    { name: 'clipboard', groups: ['clipboard', 'undo'] },
                    { name: 'paragraph', groups: ['list', 'blocks', 'align', 'bidi', 'paragraph'] },
                    { name: 'links', groups: ['links'] },
                    { name: 'insert', groups: ['insert'] },
                    { name: 'colors', groups: ['colors'] },
                    { name: 'editing', groups: ['find', 'selection', 'spellchecker', 'editing'] },
                    { name: 'styles', groups: ['styles'] },
                    { name: 'tools', groups: ['tools'] },
                    { name: 'others', groups: ['others'] },
                    { name: 'document', groups: ['document', 'doctools', 'mode', 'checkicon'] }
                ],
            removeButtons: 'Save,NewPage,Preview,Print,Templates,Cut,Copy,Paste,PasteText,PasteFromWord,Undo,Redo,SelectAll,Form,Checkbox,Radio,TextField,Textarea,Select,Button,ImageButton,HiddenField,CreateDiv,BidiLtr,BidiRtl,Language,Flash,Smiley,Iframe,Styles,ShowBlocks,About,Subscript,Superscript,RemoveFormat,CopyFormatting,SpecialChar,Find,Replace,Scayt,Anchor,BGColor,Font,Format',
            extraPlugins: 'codesnippet,pastetext,pagebreak,justify'//'checkicon'
        });
    }
    else {
        CKEDITOR.replace(textBox, {
            height: editorHeight,
            allowedContent: true,
            /*disallowedContent: 'table{*}; td{*}; tr{*}; th{*}; div{*}',*/
            toolbarGroups:
                [
                    { name: 'basicstyles', groups: ['basicstyles', 'cleanup'] },
                    { name: 'clipboard', groups: ['clipboard', 'undo'] },
                    { name: 'paragraph', groups: ['list', 'indent', 'blocks', 'align', 'bidi', 'paragraph'] },
                    { name: 'links', groups: ['links'] },
                    { name: 'insert', groups: ['insert'] },
                    { name: 'editing', groups: ['find', 'selection', 'editing'] },
                    { name: 'colors', groups: ['colors'] },
                    { name: 'tools', groups: ['tools'] },
                    { name: 'others', groups: ['others'] },
                    { name: 'styles', groups: ['styles'] },
                    { name: 'document', groups: ['document', 'doctools', 'mode', 'checkicon'], }
                ],
            removeButtons: 'Save,NewPage,Preview,Templates,Cut,Copy,Paste,PasteText,PasteFromWord,Undo,Redo,SelectAll,Form,Checkbox,Radio,TextField,Textarea,Select,Button,ImageButton,HiddenField,CreateDiv,BidiLtr,BidiRtl,Language,Flash,Smiley,Iframe,ShowBlocks,About,Anchor',
            extraPlugins: 'codesnippet,font,youtube,pagebreak,find,colorbutton,colordialog,justify,dialogadvtab,liststyle,wordcount,lineheight,checkicon,tableresize,tableselection,tabletools'//''
        });
    }
}

var handleExportButtonClick = function ($sender, formName, $parentGrid, tabType) {
    var $handsontable;
    if ($parentGrid === '') {
        $parentGrid = void 0;
    }
    if (typeof $parentGrid === "undefined") {
        $handsontable = $($sender).parents("section.content").find('.handsontable');
    } else {
        $handsontable = $parentGrid;
    }
    if (typeof $handsontable === "undefined" || $handsontable === null) {
        return;
    }
    var nimbleInstance = $handsontable.data("nimble");
    var filter = nimbleInstance.getFilterOfGrid();
    var sortList = nimbleInstance.getSortOrder();
    var orderByColData = nimbleInstance.getOrderByCol();
    var sort = "";
    if (sortList.length > 0) {
        sort = sortList[1];
        orderByColData = sortList[0];
    }
    var $form = $("#" + formName);
    var filterInput = $("#filterExpression");
    var sortInput = $("#sortOrder");
    var orderByCol = $("#orderByCol");
    var dataFilter = JSON.stringify({ Filter: filter });
    var filterExp = $('<input />',
        {
            type: 'hidden',
            name: 'filterExpression',
            id: 'filterExpression',
            value: dataFilter
        });
    var sortElem = $('<input />',
        {
            type: 'hidden',
            name: 'sortOrder',
            id: 'sortOrder',
            value: sort
        });
    var order = $('<input />',
        {
            type: 'hidden',
            name: 'orderByCol',
            id: 'orderByCol',
            value: orderByColData
        });
    if (typeof $(filterInput).get(0) === "undefined") {
        filterExp.appendTo($form);

    }
    if (typeof $(sortInput).get(0) === "undefined") {
        sortElem.appendTo($form);
    }
    if (typeof $(orderByCol).get(0) === "undefined") {
        order.appendTo($form);
    }
    var $filterForm = $("#gridFilterForm");
    if (typeof $filterForm.get(0) !== "undefined") {
        $("#gridFilterForm").find(":input").not("submit").each(function () {
            if ($(this).attr("name") !== undefined && $(this).val() !== null) {
                var input = "#" + $(this).attr("name");
                if ($form.find(input).length === 0) {
                    var inp = $("<input name='" + $(this).attr("name") + "' type='hidden' value='" + $(this).val() + "' id='" + $(this).attr("name") + "'/>");
                    $form.append(inp);
                }
                $(`input[id=${$(this).attr("name")}]`, `#${formName}`).val("" + $(this).val());
            }
        });
    }
    $("#filterExpression").val(dataFilter);
    $("#sortOrder").val(sort);
    $("#orderByCol").val(orderByColData);
    var url = $($sender).attr("data-href");
    if (typeof tabType !== "undefined") {
        if (tabType !== '') {
            var tabName = $($sender).closest('nav').parents().find('div.nav-tabs-custom').find('li.active').find('a');
            var dataText = tabName.attr('data-text');
            if (typeof dataText !== undefined && typeof dataText !== "undefined") {
                var tabType = $('<input />',
                    {
                        type: 'hidden',
                        name: 'tabType',
                        id: 'tabType',
                        value: dataText
                    });
                if (typeof $($("#tabType"), $form).get(0) === "undefined") {
                    tabType.appendTo($form);
                }
                $("#tabType").val(dataText);
            }
        }
    }
    if (url.indexOf('?') > -1) {
        var params = url.split("?")[1];
        var paramList = params.split("&");
        $.each(paramList, function (key, value) {
            if (value.indexOf('=') > 1) {
                var keyValPair = value.split('=');
                if (typeof $($(`#${keyValPair[0]}`), $form).get(0) === "undefined") {
                    $(`<input type='hidden' value='${keyValPair[1]}' />`)
                        .attr(`id`, `${keyValPair[0]}`)
                        .attr(`name`, `${keyValPair[0]}`)
                        .appendTo($form);
                }
                $(`#${keyValPair[0]}`).val(keyValPair[1]);
            }
        });
    }
    $form.attr("action", url);
    $form.submit();
}

var clickCreate = function (sender) {
    var href = $(sender).attr("data-href");
    location.href = href;
};

var handleDeleteButtonsClick = function ($sender, url, $parentGrid, isCheckBox, formUrl) {
    var data;
    var def = url;
    if (typeof url === "object") {
        [$parentGrid, url] = [url, $parentGrid];
    }
    console.log(formUrl)
    if (typeof $parentGrid === "undefined" || $parentGrid === null || $parentGrid === '') {
        $parentGrid = $($sender).parents("section.content").find('.handsontable');
    }
    if ($parentGrid === null || $parentGrid === undefined || $parentGrid === '') {
        return false;
    }
    const instance = $parentGrid.handsontable("getInstance");
    const selection = instance.getSelected();
    if (selection === null || selection === undefined) {
        window.handleActionButtonsClick(false);
        return false;
    }
    var nimbleInstance = $parentGrid.data("nimble");
    if (nimbleInstance === undefined || nimbleInstance === null) {
        return false;
    }

    if (isCheckBox === true) {
        data = GetSelectedEmpFromHandsontableTable($parentGrid);
        if (data === "" || data === "on") {
            handleActionButtonsClick(isCheckBox);
            return false;
        }
    } else {
        if (nimbleInstance.getSelectedCell() === "" || nimbleInstance.getSelectedCell() === undefined) {
            const row = selection[0];
            data = instance.getDataAtRow(row);
            data = data[1];
        } else {
            data = nimbleInstance.getSelectedCell();
        }
    }

    $("#modal-popup-delete").modal("show").on("shown.bs.modal", function () {
        if (formUrl !== undefined || formUrl !== '') {
            $("#delete-form-model").attr("action", formUrl);
        }
        $("#delete-form-model").off("submit").on("submit", function (e) {
            e.preventDefault();
            $(this).find('input#UDSelDel').val(data);
            $(this).find('button.btnSave').button('loading');
            const $form = $(this);
            if (url === void 0 || url === '') {
                url = $form.attr("action")
            }
            setTimeout(function () {
                $.post(url, $($form).serialize(), function (data, status) {
                    $($form).find('button.btnSave').button('reset');
                    var clientMessage = { title: data.Title, type: data.StatusType, content: data.Message };
                    if (clientMessage.type === "success") {
                        $parentGrid.data("nimble").getReloadOnSuccess();
                        $("#modal-popup-delete").modal("hide");
                    }
                    window.UIToastr.init(clientMessage);
                });
            },
                400);

            return false;
        });

    }).on("hidden.bs.modal", function (e) {

    });;
    return false;
};

var handleDeleteButtonsClickMvcGrid = function ($sender, url) {
    var data = GetSelectedEmpFromDataTable();
    if (data === "") {
        handleActionButtonsClick(false);
        return false;
    }
    $("#modal-popup-delete").modal("show").on("shown.bs.modal", function () {

        $("#delete-form-model").off("submit").on("submit", function (e) {
            //$("#delete-form-model").submit(function (e) {
            e.preventDefault();
            $(this).find('input#UDSelDel').val(data);
            $(this).find('button.btnSave').button('loading');
            const $form = $(this);
            if (url === void 0 || url === '') {
                url = $form.attr("action")
            }
            setTimeout(function () {
                $.post(url, $($form).serialize(), function (data, status) {
                    $($form).find('button.btnSave').button('reset');
                    var clientMessage = { title: "Delete", type: status, content: "Error Deleting Data!!" };
                    if (status === "success") {
                        clientMessage.content = "Data Has been Deleted Successfully";

                        var row = $('.grid-mvc').find("tbody>tr.grid-row-selected");

                        row.fadeOut(800, function () {
                            row.remove();
                        });
                        $("#div_print").load(location.href + " #div_print", function (response, status, xhr) {
                            $(".grid-mvc").each(function () { $(".grid-mvc").gridmvc(); });
                        });

                        $("#modal-popup-delete").modal("hide");
                    }
                    window.UIToastr.init(clientMessage);
                    //$form.unbind("submit").bind("submit");
                });
            },
                400);
            //$("#delete-form-model").unbind("submit");
            return false;
        });

    }).on("hidden.bs.modal", function (e) {

    });;
    return false;
};

var handleTosterMessage = function (obj) {
    const clientMessage = { title: obj.Title, type: obj.StatusType, content: obj.Message };
    window.UIToastr.init(clientMessage);
    return clientMessage.type;
}

var showClientMsg = function (msg, msgType, title) {
    var clientMessage = { title: title, type: msgType, content: msg };
    window.UIToastr.init(clientMessage);
}

var showClientMsgForTime = function (msg, msgType, title, seconds) {
    var clientMessage = { title: title, type: msgType, content: msg, time: parseInt(seconds) * 1000 };
    window.UIToastr.init(clientMessage);
}

