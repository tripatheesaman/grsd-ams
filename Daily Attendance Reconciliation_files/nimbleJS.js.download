var handleMapJsonToSelect2Data = function (intemArray, valueField, textField) {
    const data = $.map(intemArray,
        function (obj) {
            obj.id = obj[valueField];
            obj.text = obj[textField];
            return obj;
        });

    return data;
};

var select2LoadWithData = (function (window, $) {
    function select2LoadWithData(parent, dataArray, select2Options) {
        var dataMap = handleMapJsonToSelect2Data(dataArray, "id", "Value");
        var newOptions = [];
        for (var i = 0; i < dataMap.length; i++) {
            var opt = dataMap[i];
            var options =
                `<option value='${opt.id}'>${opt.Value}</option>`;
            newOptions.push(options);
        }
        var optionsSelect = select2Options || {};
        $(parent).select2(optionsSelect);
        $(parent).select2('destroy').html(newOptions).prop("disabled", false).select2();
    }

    return select2LoadWithData;

})(window, $);

var select2Cascade = (function (window, $) {
    function select2Cascade(parent, child, url, autoLoad, select2Options) {
        var afterActions = [];
        var options = select2Options || {};
        $(parent).select2();
        $(child).select2();
        // Register functions to be called after cascading data loading done
        this.then = function (callback) {
            afterActions.push(callback);
            return this;
        };
        var loadFunction = function (params) {
            $.post(url.replace(':parentId:', $(parent).val()), function (items) {
                var dataToLoad = JSON.parse(items);
                var newOptions = '';
                for (var i = 0; i < dataToLoad.length; i++) {
                    var itm = dataToLoad[i];
                    var selected = itm.SelectedValue === "true" ? "selected='selected'" : "";
                    newOptions += '<option value="' + itm.id + '" ' + selected + '>' + itm.Value + '</option>';
                }

                child.select2('destroy').html(newOptions).prop("disabled", false)
                    .select2(options);

                afterActions.forEach(function (callback) {
                    callback(parent, child, items);
                });
            });
        };
        var $that = this;
        parent.select2(select2Options).on("change", function (e) {
            child.prop("disabled", true);
            loadFunction(this);
        });
        if (typeof autoLoad !== "undefined") {
            if (autoLoad === true)
                loadFunction(parent);
        }
    }

    return select2Cascade;

})(window, $);

(function (window, $) {
    $.fn.select2Cascade = function (options) {
        this.default = {
            url: '',
            childId: void 0,
            autoLoad: true,
            select2Options: void 0
        };
        var settings = $.extend(this.default, options);
        return select2Cascade($(this), $(settings.childId), settings.url, settings.autoLoad, settings.select2Options);
    };
}(window, jQuery));

(function ($) {
    $.fn.serializeFormJSON = function () {

        var o = {};
        var a = this.serializeArray();
        $.each(a, function () {
            if (o[this.name]) {
                if (!o[this.name].push) {
                    o[this.name] = [o[this.name]];
                }
                o[this.name].push(this.value || '');
            } else {
                o[this.name] = this.value || '';
            }
        });
        return o;
    };
})(jQuery);

var colors = ["#1575cd", "#a0d471", "#c25454", "#b7a62f", "#9d4b81", "#937f84", "#86b8c6", "#54c354", "#aeacad", "#d6ccaa", "#a845dc", "#77f2d8"];

var getColorForData = function (length) {
    var bgColors = [];
    for (var i = 0; i < length; i++) {
        bgColors.push(colors[i % colors.length]);
    }
    return bgColors;
}

var bindTree = function () {

    var DataKey = 'lte.tree';

    var Default = {
        animationSpeed: 500,
        accordion: true,
        followLink: false,
        trigger: '.treeview a'
    };

    var Selector = {
        tree: '.tree',
        treeview: '.treeview',
        treeviewMenu: '.treeview-menu',
        open: '.menu-open, .active',
        li: 'li',
        data: '[data-widget="tree"]',
        active: '.active'
    };

    var ClassName = {
        open: 'menu-open',
        tree: 'tree'
    };

    var Event = {
        collapsed: 'collapsed.tree',
        expanded: 'expanded.tree'
    };

    // Tree Class Definition
    // =====================
    var Tree = function (element, options) {
        this.element = element;
        this.options = options;

        $(this.element).addClass(ClassName.tree);

        $(Selector.treeview + Selector.active, this.element).addClass(ClassName.open);

        this._setUpListeners();
    };

    Tree.prototype.toggle = function (link, event) {
        var treeviewMenu = link.next(Selector.treeviewMenu);
        var parentLi = link.parent();
        var isOpen = parentLi.hasClass(ClassName.open);

        if (!parentLi.is(Selector.treeview)) {
            return;
        }

        if (!this.options.followLink || link.attr('href') === '#') {
            event.preventDefault();
        }

        if (isOpen) {
            this.collapse(treeviewMenu, parentLi);
        } else {
            this.expand(treeviewMenu, parentLi);
        }
    };

    Tree.prototype.expand = function (tree, parent) {
        var expandedEvent = $.Event(Event.expanded);

        if (this.options.accordion) {
            var openMenuLi = parent.siblings(Selector.open);
            var openTree = openMenuLi.children(Selector.treeviewMenu);
            this.collapse(openTree, openMenuLi);
        }

        parent.addClass(ClassName.open);
        tree.slideDown(this.options.animationSpeed, function () {
            $(this.element).trigger(expandedEvent);
        }.bind(this));
    };

    Tree.prototype.collapse = function (tree, parentLi) {
        var collapsedEvent = $.Event(Event.collapsed);

        tree.find(Selector.open).removeClass(ClassName.open);
        parentLi.removeClass(ClassName.open);
        tree.slideUp(this.options.animationSpeed, function () {
            tree.find(Selector.open + ' > ' + Selector.treeview).slideUp();
            $(this.element).trigger(collapsedEvent);
        }.bind(this));
    };

    // Private

    Tree.prototype._setUpListeners = function () {
        var that = this;

        $(this.element).off().on('click', this.options.trigger, function (event) {
            that.toggle($(this), event);
        });
    };

    // Plugin Definition
    // =================
    function Plugin(option) {
        return this.each(function () {
            var $this = $(this);
            var data = $this.data(DataKey);

            if (!data) {
                var options = $.extend({}, Default, $this.data(), typeof option == 'object' && option);
                $this.data(DataKey, new Tree($this, options));
            }
        });
    }

    var old = $.fn.tree;

    $.fn.tree = Plugin;
    $.fn.tree.Constructor = Tree;

    // No Conflict Mode
    // ================
    $.fn.tree.noConflict = function () {
        $.fn.tree = old;
        return this;
    };

    // Tree Data API
    // =============
    //$(window).off().on('load', function () {
    $(Selector.data).each(function () {
        Plugin.call($(this));
    });
    //});
}

var replaceLast = function (fullText, replaceText, replacedByText) {
    var lastIndex = fullText.lastIndexOf(replaceText);
    if (lastIndex === -1) {
        return fullText;
    }

    fullText = fullText.slice(0, lastIndex) + fullText.slice(lastIndex).replace(replaceText, replacedByText);
    return fullText;
}

var handleAppendClickedMenuIdInLink = function () {
    var ckedmenuid = QueryString("ckedmenuid");
    if (ckedmenuid != null) {
        $("a").attr('href', function (index, item) {
            return item == null || item == "" || item.indexOf("#") !== -1 || item.indexOf("javascript:") !== -1 || item.indexOf("ckedmenuid") !== -1
                ? item
                : (item + (item.indexOf('?') != -1 ? "&" : "?") + "ckedmenuid=" + ckedmenuid);
        });

        $("form").attr('action', function (index, item) {
            return item == "#" || item == "" || item == null || item.indexOf("javascript:") !== -1 || item.indexOf("ckedmenuid") !== -1
                ? item
                : (item + (item.indexOf('?') != -1 ? "&" : "?") + "ckedmenuid=" + ckedmenuid);
        });
    }
}

var spinnerOn = function ($selector, fasizeas1xto4x) {
    switch (fasizeas1xto4x) {
        case '1x':
            fasizeas1xto4x = 'fa-1x';
            break;
        case '2x':
            fasizeas1xto4x = 'fa-2x';
            break;
        case '3x':
            fasizeas1xto4x = 'fa-3x';
            break;
        case '4x':
            fasizeas1xto4x = 'fa-4x';
            break;
        default:
            fasizeas1xto4x = 'fa-4x';
            break;
    }

    $.blockUI.defaults.css = {};
    $selector.block({
        message: `<div class="fa fa-spinner fa-pulse ${fasizeas1xto4x} fa-spin"></div>`,
        css: {
            textAlign: 'center',
            color: '#3c8dbc',
            cursor: 'wait'
        },
        overlayCSS: {
            backgroundColor: '#000',
            opacity: 0.6,
            cursor: 'wait'
        },

    })
    // if div height zero do not center display msg. 
    if ($selector.height() > 10) {
        $('.blockUI.blockMsg').setScreenCenter($selector);
    }
}
var spinnerOff = function ($selector) {
    $selector.unblock();
}
$.fn.setScreenCenter = function ($selector) {
    this.css("position", "absolute");
    var heightDiff = $selector.height() - $(window).height();
    var widthDiff = $selector.width() - $(window).width();
    if (heightDiff < 0) {
        this.css("top", ($selector.height() - this.height()) / 2 + $selector.scrollTop() + "px");
    }
    else {
        this.css("top", ($(window).height() - this.height()) / 2 + $(window).scrollTop() + "px");
    }
    if (widthDiff < 0) {
        this.css("left", ($selector.width() - this.width()) / 2 + $selector.scrollLeft() + "px");
    }
    else {
        this.css("left", ($(window).width() - this.width()) / 2 + $(window).scrollLeft() + "px");
    }
    return this;
}

var handleChartLabelPaddingGlobal = function () {
    Chart.Legend.prototype.afterFit = function () {
        this.height = this.height + 20;
    };
}

var handleFormatNumber = function (number) {
    var formatter = new Intl.NumberFormat('en-US', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
    });
    return formatter.format(number);
};

var handleFormatDate = function (date) {
    if (!date) return date;

    const options = { year: 'numeric', month: 'short', day: '2-digit' };
    const formattedDate = date.toLocaleDateString('en-US', options);
    return formattedDate;
};


// CSRF (XSRF) security
//ctx should be context of forgery token which encloses it. eg: $('#formID') or $('#divID')
function addAntiForgeryToken(data, ctx) {
    //if the object is undefined, create a new one.
    if (!data) {
        data = {};
    }
    var tokenInput = $('input[name=__RequestVerificationToken]');
    if (ctx) {
        tokenInput = $('input[name=__RequestVerificationToken]', ctx);
    }
    //add token
    if (tokenInput.length) {
        data.__RequestVerificationToken = tokenInput.val();
    }
    return data;
};

//================================================================================
// More Menu Start
//================================================================================

var handleSidebarMoremenu = function () {
    /*Auto close more menu when use clicked outside of moremenu container*/
    $(document).mouseup(function (e) {
        var container = $(".moremenu-container");
        var isVisible = container.is(':visible');
        //container.css('height', window.innerHeight - 50 + 'px');
        if (isVisible) {
            var data = document.activeElement.attributes['data-desc']; /*Get the clicked element, yet to check whether all cases will handle by this approach or not.*/
            if (((data && data.value !== "moremenu") || !data) && !container.is(e.target) && container.has(e.target).length === 0) {
                closeMoreMenu();
            }
        }
    });

    $('a[data-desc$="moremenu"]').on("click", function (e) {
        e.preventDefault

        var menuid = $(this).attr("data-menuid");
        //var menuContainerID = "moremenu-" + menuid.replaceAll(".", ""); /*replaceAll doesnot support in old browser*/
        var menuContainerID = "moremenu-" + menuid.replace(/\./g, "");


        if ($(this).hasClass("active")) {
            closeMoreMenu();
        } else {
            /*Remove all active status of more menu, handle click on different more menu while one menu is active.*/
            $('.moremenu-container').removeClass("active left-zero left-module-list left-minus left-minus-mini");
            $('a[data-desc$="moremenu"]').removeClass("active moremenu-selected");

            /*TODO: Check possibilities for toggle or animation, currently that causing functional break of bindMesonary.*/
            //$('.moremenu-container').toggle("active");

            var isLeftMenuAvailable = $('.main-sidebar').length > 0;
            var isLeftMenuCollapsed = $('.sidebar-mini.sidebar-collapse').length > 0;


            var isTopMenuClicked = $(this).hasClass("sidebar-module-top-mm");
            if (isTopMenuClicked) { handleCloseServiceMenu(); }
            var isModuleListingOpen = $('.sidebar-module-icon-mm.active').length > 0;

            if (isLeftMenuAvailable && !isModuleListingOpen) {
                /*Handle collapse menu while more menu is open*/
                var x = window.matchMedia("(max-width: 768px)")
                //if (!x.matches) {
                //    $('body').removeClass('sidebar-collapse')
                //    $('body').removeClass('sidebar-expanded-on-hover')
                //}
                if (isLeftMenuCollapsed)
                    $('#' + menuContainerID).addClass("left-minus-mini");
                else
                    $('#' + menuContainerID).addClass("left-minus");
            }
            else {
                if (!isModuleListingOpen)
                    $('#' + menuContainerID).addClass("left-zero");
                else
                    $('#' + menuContainerID).addClass("left-module-list");
            }


            $('#' + menuContainerID).addClass("active");
            $(this).addClass("active moremenu-selected");

            bindMasonary();
            disableScroll();
        }
    });
}

var closeMoreMenu = function () {
    enableScroll();
    $('.moremenu-container').removeClass("active");
    $('a[data-desc$="moremenu"]').removeClass("active moremenu-selected");
}

function disableScroll() {
    $('body').css('top', - ($(window).scrollTop()) + 'px').addClass('stop-scrolling');
}

function enableScroll() {
    var top = $('body').position().top;
    $('body').removeClass('stop-scrolling').css('top', 0).scrollTop(Math.abs(top));
}

var handleBindCloseMoreMenu = function () {
    $('.close-moremenu').on("click", function () {
        closeMoreMenu();
    });
}

var bindMasonary = function () {
    for (var i = 1; i < 20; i++) {
        var $grid = $('.grid' + i).masonry({
            itemSelector: '.grid-item1',
        });
    }

}

//  Left section on click panel module open   
var handleSidebarModuleSectionForMoreMenu = function () {
    $('a.sidebar-module-icon-mm').on("click", function (e) {
        e.preventDefault();
        if ($('.module-listing-wrap-mm' && '.sidebar-module-icon-mm').hasClass("active")) {
            $('.sidebar-module-icon-mm').removeClass("active");
            $('.module-listing-wrap-mm').animate({
                left: "-300px"
            }, 300);
        }
        else {
            $('.sidebar-module-icon-mm').addClass("active");
            $('.module-listing-wrap-mm').animate({
                left: "0px"
            }, 300).addClass("active");
        }

    });

    //When Outer body click left pannel hide
    $(document).mouseup(function (e) {
        if ($(event.target).closest(".sidebar-module-icon-mm").length === 1 || $(event.target).closest(".module-listing-wrap-mm").length === 1 || $(event.target).closest(".moremenu-container").length === 1) {
            return;
        } else {
            handleCloseServiceMenu();
        }
    });

}

handleCloseServiceMenu = function () {
    if ($('.module-listing-wrap-mm' && '.sidebar-module-icon-mm').hasClass("active")) {
        $('.sidebar-module-icon-mm').removeClass("active");
        $('.module-listing-wrap-mm').animate({
            left: "-300px"
        }, 300).removeClass("active");
        return true;
    };
    return false;
}
handleFavouriteMenu = function () {

    $(function () {
        $('._menu-item-fav').unbind('hover');
    })

    $('._menu-item-fav').hover(function () {
        var elm = $(this).find('.span-favourite-menuitem');
        if (elm.attr('data-is-favourite').toLowerCase() == "false") elm.show();
    }, function () {
        var elm = $(this).find('.span-favourite-menuitem');
        if (elm.attr('data-is-favourite').toLowerCase() == "false") elm.hide();
    });




    $('.span-favourite-menuitem').on('click', function () {
        $this = $(this);
        let menuId = $(this).attr('data-id')
        let _currFavStatus = $this.attr('data-is-favourite').toLowerCase();
        console.log({ _currFavStatus });
        $this.find('i').removeClass('fa-star-o fa-star').addClass(_currFavStatus == 'false' ? 'fa-star' : 'fa-star-o');
        $this.attr('data-is-favourite', _currFavStatus == 'false' ? 'true' : 'false')
        $.ajax({
            method: 'POST',
            url: "/coreextension/MenuManagement/UpdateFavouriteMenuItem",
            dataType: "json",
            contentType: 'application/json; charset=utf-8',
            data: JSON.stringify({ MenuId: menuId }),
            success: function (d) {
                if (d && d.isSuccess) {
                    $this.attr('data-is-favourite', d.favouriteMenuStatus);
                    $this.attr('title', d.favouriteMenuStatus ? "Remove item from favourite menu" : "Add item to favourite menu");
                    $this.find('i').removeClass('fa-star-o fa-star').addClass(d.favouriteMenuStatus ? 'fa-star' : 'fa-star-o');
                }
                else {
                    $this.find('i').removeClass('fa-star-o fa-star').addClass(d._currFavStatus ? 'fa-star' : 'fa-star-o');
                    showClientMsg(d.outputMessage, d.isSuccess ? "success" : "error", "Favourite Menu Management");
                }
            },
            error: function (d) {
                showClientMsg("Something went wrong. Please try again later", "error", "Favourite Menu Management");
            }
        });
    });
}

