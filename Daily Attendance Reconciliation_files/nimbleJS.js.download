//Global Variables
var IsDirty = { FormName: "", IsDirty: false };

//function only for reporting
var SortChartData = {
    // sort a dataset
    sort: function (chart, datasetIndex, sortOrder) {

        var data = [];
        var order = 'asc';
        switch (sortOrder) {
            case '0':
                order = 'asc';
                break;
            case 'asc':
                order = 'desc';
                break;
            case 'desc':
            default:
                order = '0';
                break;

        }

        $this.attr('data-sortorder', order);
        const multiplier = order === 'asc' ? 1 : -1;
        chart.data.datasets.forEach(function (dataset, i) {
            dataset.data.forEach(function (bar, j) {
                if (i === 0) {
                    data.push({
                        label: chart.data.labels[j],
                        values: [bar]
                    })
                } else
                    data[j].values.push(bar);
            });
        })


        data.sort(function (a, b) {
            const a1 = handleFormatNumber(a.values[datasetIndex]);
            const b1 = handleFormatNumber(b.values[datasetIndex]);
            if (a1 > b1)
                return 1 * multiplier;
            else if (a1 < b1)
                return -1 * multiplier;
            else return 0;

        })

        chart.data.datasets.forEach(function (dataset, i) {
            dataset.data.forEach(function (bar, j) {
                if (i === 0)
                    chart.data.labels[j] = data[j].label;
                dataset.data[j] = data[j].values[i];

            })
        });
        chart.update();
    },
}

var setLeftMenuHeight = function () {
    $(".sidebar-menu").height($(window).height() - 148);
    $(".nim-small-logo").attr("style", "display:block;");
}

var waitForFinalEvent = (function () {
    var timers = {};
    return function (callback, ms, uniqueId) {
        if (!uniqueId) {
            uniqueId = "Don't call this twice without a uniqueId";
        }
        if (timers[uniqueId]) {
            clearTimeout(timers[uniqueId]);
        }
        timers[uniqueId] = setTimeout(callback, ms);
    };
})();

//call this listener function combined with denounced function 
//such that performance doesnot get impacted
var listenWindowResize = function () {
    $(window).resize(function () {
        waitForFinalEvent(function () {
            setLeftMenuHeight();
        }, 500, "leftMenuScrollFix");
    });
}

var setLeftMenuScrollPosition = function () {
    var menuHeight = $(".sidebar-menu").height();
    var activeParentItem = $('.sidebar-menu').parents('div:eq(0)').find('li.treeview.active');
    var parentTop = activeParentItem.length > 0 ? $(activeParentItem).offset().top : 0;

    var activeChildTreeItem = $('.sidebar-menu').parents('div:eq(0)').find('li.treeview.active.ml-3');
    var itemChildTreeTop = activeChildTreeItem.length > 0 ? $(activeChildTreeItem).offset().top : 0;

    var activeItem = $('.sidebar-menu').parents('div:eq(0)').find('li.active.ml-3').last();
    var itemTop = activeItem.length > 0 ? $(activeItem).offset().top : 0;

    var top = parentTop > 0 && itemTop - parentTop + 60 < menuHeight ? parentTop :
        itemChildTreeTop > 0 ? itemChildTreeTop :
            itemTop;

    $('.sidebar-menu').scrollTop(top - 100);
}

var ensureUDSel = function () {
    if ($("#UDSel").length <= 0) {
        var UDSel = document.createElement('UDSel');
        UDSel.type = 'hidden';
        UDSel.id = "UDSel";
        $(".wrapper").append(UDSel);
    }
}

var customPascalCase = function () {
    /*Replace Pascal case with Space character*/
    $('.mypascal').each(function () {
        var text = $(this).text().replace(/([A-Z])/g, ' $1').replace(/^./, function (str) { return str.toUpperCase(); });
        $(this).empty().text(text);
    });
};

var bindTableSorter = function () {
    // Define a custom parser for numbers with commas
    $.tablesorter.addParser({
        id: 'commaNumber',
        is: function (s) {
            return /\d{1,3}(,\d{3})+/.test(s); // Check if the string contains commas
        },
        format: function (s) {
            s = $.trim(s);
            if (!s || s === '-' || s === '—') return 0;
            s = s.replace(/,/g, '');
            var n = parseFloat(s);
            return isNaN(n) ? 0 : n; // Remove commas, treated null (-) as 0 and parse as a number for sorting
        },
        type: 'numeric'
    });

    // Dynamically set up parsers for columns
    let headers = {};
    $(".tablesorter-table thead tr th").each(function (index) {
        // Check if any cell in the column contains commas
        let isCommaColumn = false;
        $(".tablesorter-table tbody tr").each(function () {
            let cellText = $(this).find("td").eq(index).text();
            if (/\d{1,3}(,\d{3})+/.test(cellText)) {
                isCommaColumn = true;
                return false; // Exit loop early if match is found
            }
        });
        if (isCommaColumn) {
            headers[index] = { sorter: 'commaNumber' }; // Apply the custom parser
        }
    });


    $(".tablesorter-table").tablesorter({
        headers: headers
    });
}

