// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(255)
  code        String    @unique @db.VarChar(10)
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  users       User[]
  sections    Section[]
  staff       StaffDetail[]

  @@map("departments")
}

model Section {
  id          Int          @id @default(autoincrement())
  name        String       @unique @db.VarChar(255)
  code        String       @unique @db.VarChar(50)
  departmentId Int         @map("department_id")
  department  Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  description String?
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  staff       StaffDetail[]

  @@map("sections")
}

model User {
  id           Int            @id @default(autoincrement())
  username     String         @unique @db.VarChar(150)
  password     String         @db.VarChar(255)
  email        String         @unique @db.VarChar(254)
  firstName    String         @map("first_name") @db.VarChar(150)
  lastName     String         @map("last_name") @db.VarChar(150)
  departmentId Int?           @map("department_id")
  department   Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  isActive     Boolean        @default(true) @map("is_active")
  isStaff      Boolean        @default(false) @map("is_staff")
  isSuperuser  Boolean        @default(false) @map("is_superuser")
  dateJoined   DateTime       @default(now()) @map("date_joined")
  lastLogin    DateTime?      @map("last_login")
  files        ProcessedFile[]

  @@map("users")
}

model ProcessedFile {
  id            Int                 @id @default(autoincrement())
  userId        Int?                @map("user_id")
  user          User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalFile  String              @map("original_file")
  processedFile String?             @map("processed_file")
  status        String              @default("pending") @db.VarChar(20)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  errorMessage  String?             @map("error_message")

  @@map("processor_processedfile")
}

model StaffDetail {
  id               Int            @id @default(autoincrement())
  staffid          String         @unique @db.VarChar(255)
  name             String         @db.VarChar(255)
  sectionId        Int?           @map("section_id")
  section          Section?       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  designation      String         @default("") @db.VarChar(255)
  departmentId     Int?           @map("department_id")
  department       Department?    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  weeklyOff        String         @default("sun") @map("weekly_off") @db.VarChar(10)
  level            Int            @default(1)
  typeOfEmployment String         @default("permanent") @map("type_of_employment") @db.VarChar(20)
  priority         Int            @default(1)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@map("staff_details")
}
